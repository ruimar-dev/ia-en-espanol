---
import Layout from '../layouts/Layout.astro';
import ArticuloCard from '../components/ArticuloCard.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import { getCollection } from 'astro:content';

const todosLosArticulos = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const totalArticulos = todosLosArticulos.length;
const herramientasUnicas = new Set(todosLosArticulos.flatMap(a => a.data.herramientas)).size;

const [featured, ...rest] = todosLosArticulos;
const grid2x2 = rest.slice(0, 4);
const gridRest = rest.slice(4);

function readingTime(body: string) {
  return Math.max(1, Math.ceil(body.split(/\s+/).length / 200));
}

const categorias = [
  {
    slug: 'generacion-texto',
    label: 'Generación de texto',
    color: 'text-[#7C3AED]',
    bg: 'bg-[#7C3AED]/10',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
  },
  {
    slug: 'generacion-imagen',
    label: 'Generación de imagen',
    color: 'text-[#2563EB]',
    bg: 'bg-[#2563EB]/10',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>`,
  },
  {
    slug: 'codigo',
    label: 'Código',
    color: 'text-[#16A34A]',
    bg: 'bg-[#16A34A]/10',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  },
  {
    slug: 'audio',
    label: 'Audio',
    color: 'text-[#EA580C]',
    bg: 'bg-[#EA580C]/10',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>`,
  },
  {
    slug: 'video',
    label: 'Video',
    color: 'text-[#DC2626]',
    bg: 'bg-[#DC2626]/10',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>`,
  },
  {
    slug: 'productividad',
    label: 'Productividad',
    color: 'text-[#0D9488]',
    bg: 'bg-[#0D9488]/10',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
  },
];
---

<Layout
  title="IA en Español — Reviews y comparativas de herramientas de IA"
  description="Reviews y comparativas de herramientas de inteligencia artificial en español. Sin anglicismos, con criterio."
>
  <!-- Hero -->
  <section class="relative overflow-hidden py-24 px-4">
    <div
      class="absolute inset-0 bg-gradient-to-b from-[#f0ebff] to-[#fafafa] dark:from-[#0f0f0f] dark:via-[#1a0a2e] dark:to-[#0f0f0f]"
      aria-hidden="true"
    ></div>
    <div class="relative max-w-4xl mx-auto text-center">
      <span class="inline-block bg-[#7C3AED]/10 dark:bg-white/10 text-[#7C3AED] dark:text-white/80 text-sm font-semibold px-4 py-1.5 rounded-full mb-6 border border-[#7C3AED]/20 dark:border-white/10">
        Reviews de IA en español
      </span>
      <h1
        class="font-extrabold text-gray-900 dark:text-white mb-6 leading-tight tracking-tight"
        style="font-size: clamp(2.5rem, 5vw, 4rem);"
      >
        Reviews y comparativas de herramientas IA.<br />
        <span class="text-[#7C3AED] dark:text-[#A78BFA]">Sin humo, en español.</span>
      </h1>
      <p class="text-lg sm:text-xl text-gray-600 dark:text-white/70 mb-8 max-w-2xl mx-auto leading-relaxed">
        Analizamos cada semana las mejores herramientas de inteligencia artificial para que tú no pierdas el tiempo.
      </p>

      <div class="flex items-center justify-center gap-3 mb-10 text-sm text-gray-500 dark:text-white/60">
        <span>
          <span class="text-gray-900 dark:text-white font-bold text-base">{herramientasUnicas}</span> herramientas analizadas
        </span>
        <span aria-hidden="true" class="text-gray-300 dark:text-white/30">·</span>
        <span>
          <span class="text-gray-900 dark:text-white font-bold text-base">{totalArticulos}</span> artículos publicados
        </span>
      </div>

      <a
        href="/blog"
        class="inline-flex items-center justify-center gap-2 bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-semibold px-6 py-3 rounded-xl transition-colors shadow-lg shadow-[#7C3AED]/30"
      >
        Ver todos los artículos
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Quiz CTA -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <a
      href="/que-ia-necesito"
      class="group flex flex-col sm:flex-row items-start sm:items-center gap-5 sm:gap-8 bg-white dark:bg-[#1A1A1A] rounded-2xl border border-gray-200 dark:border-gray-800 hover:border-[#7C3AED]/50 dark:hover:border-[#7C3AED]/40 p-6 sm:p-8 transition-all duration-300 hover:shadow-lg hover:shadow-[#7C3AED]/10"
    >
      <div class="flex-shrink-0 w-12 h-12 bg-[#7C3AED]/10 dark:bg-[#7C3AED]/15 rounded-xl flex items-center justify-center">
        <svg class="w-6 h-6 text-[#7C3AED]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
        </svg>
      </div>

      <div class="flex-1 min-w-0">
        <div class="flex flex-wrap items-center gap-2 mb-1">
          <h2 class="font-bold text-gray-900 dark:text-white">¿No sabes qué IA usar?</h2>
          <span class="text-[10px] font-bold uppercase tracking-wider text-[#7C3AED] bg-[#7C3AED]/10 px-2 py-0.5 rounded-full leading-none">Nuevo</span>
        </div>
        <p class="text-sm text-gray-500 dark:text-gray-400">
          Responde 5 preguntas y te recomendamos la herramienta perfecta para tu caso de uso.
        </p>
      </div>

      <span class="flex-shrink-0 inline-flex items-center gap-2 text-sm font-semibold text-[#7C3AED] group-hover:gap-3 transition-all duration-200 whitespace-nowrap">
        Hacer el test
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </span>
    </a>
  </section>

  <!-- Articles: Magazine Layout -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Últimos artículos</h2>
      <a href="/blog" class="text-sm text-[#7C3AED] hover:text-[#6D28D9] font-medium transition-colors">
        Ver todos →
      </a>
    </div>

    {todosLosArticulos.length > 0 ? (
      <div class="space-y-6">
        {featured && (
          <ArticuloCard
            title={featured.data.title}
            description={featured.data.description}
            date={featured.data.date}
            category={featured.data.category}
            slug={featured.slug}
            imagen={featured.data.imagen}
            readingTime={readingTime(featured.body)}
            variant="featured"
          />
        )}

        {grid2x2.length > 0 && (
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            {grid2x2.map((articulo) => (
              <ArticuloCard
                title={articulo.data.title}
                description={articulo.data.description}
                date={articulo.data.date}
                category={articulo.data.category}
                slug={articulo.slug}
                imagen={articulo.data.imagen}
                readingTime={readingTime(articulo.body)}
              />
            ))}
          </div>
        )}

        {gridRest.length > 0 && (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {gridRest.map((articulo) => (
              <ArticuloCard
                title={articulo.data.title}
                description={articulo.data.description}
                date={articulo.data.date}
                category={articulo.data.category}
                slug={articulo.slug}
                imagen={articulo.data.imagen}
                readingTime={readingTime(articulo.body)}
              />
            ))}
          </div>
        )}
      </div>
    ) : (
      <p class="text-center text-gray-500 dark:text-gray-400 py-12">Próximamente los primeros artículos.</p>
    )}
  </section>

  <!-- Newsletter -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-8">
    <NewsletterForm />
  </section>

  <!-- Categories with Lucide SVG icons -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
    <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-8">Explora por categoría</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
      {categorias.map(({ slug, label, icon, color, bg }) => (
        <a
          href={`/blog?cat=${slug}`}
          class="flex flex-col items-center gap-3 p-5 bg-white dark:bg-[#1A1A1A] rounded-2xl border border-gray-200 dark:border-gray-800 hover:border-[#7C3AED]/50 hover:shadow-lg hover:shadow-[#7C3AED]/10 transition-all duration-300 text-center group"
        >
          <span
            class={`p-2.5 rounded-xl ${bg} ${color} group-hover:scale-110 transition-transform duration-200`}
            set:html={icon}
          />
          <span class="text-xs font-medium text-gray-700 dark:text-gray-300 leading-tight">{label}</span>
        </a>
      ))}
    </div>
  </section>
</Layout>
