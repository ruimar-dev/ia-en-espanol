---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { herramientas } from '../data/herramientas';
import { CATEGORIA_LABELS, CATEGORIAS } from '../content/config';
import type { Categoria } from '../content/config';

const todosLosArticulos = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const totalArticulos = todosLosArticulos.length;

function readingTime(body: string) {
  return Math.max(1, Math.ceil(body.split(/\s+/).length / 200));
}

const [featuredArticulo, ...restArticulos] = todosLosArticulos;
const gridArticulos = restArticulos.slice(0, 6);

const topRanking = [...herramientas]
  .sort((a, b) => b.rating - a.rating)
  .slice(0, 4)
  .map((h, i) => ({
    rank: String(i + 1).padStart(2, '0'),
    name: h.nombre,
    cat: CATEGORIA_LABELS[h.categoria],
    score: h.rating.toFixed(1),
  }));

const mesLabel = new Date()
  .toLocaleDateString('es-ES', { month: 'short', year: 'numeric' })
  .toUpperCase()
  .replace('.', '');

const categorias = CATEGORIAS.map((slug: Categoria) => ({
  slug,
  label: CATEGORIA_LABELS[slug],
  count: todosLosArticulos.filter(a => a.data.category === slug).length,
}));

function formatDateShort(date: Date) {
  const d = date.getDate();
  const m = date.toLocaleDateString('es-ES', { month: 'short' }).toUpperCase().replace('.', '');
  return `${d} ${m}`;
}

function formatDateFull(date: Date) {
  const d = date.getDate();
  const m = date.toLocaleDateString('es-ES', { month: 'short' }).toUpperCase().replace('.', '');
  const y = date.getFullYear();
  return `${d} ${m} ${y}`;
}
---

<Layout
  title="IA en Español — Reviews y comparativas de herramientas de IA"
  description="Reviews y comparativas de herramientas de inteligencia artificial en español. Sin anglicismos, con criterio."
>
  <!-- HERO -->
  <section class="wrap" style="padding-top:72px; padding-bottom:64px;">
    <div style="display:flex; gap:64px; align-items:center; flex-wrap:wrap;">

      <!-- Texto -->
      <div style="flex:1; min-width:320px; animation:fadeUp .6s ease both;">
        <div style="display:inline-flex; align-items:center; gap:8px; margin-bottom:24px;">
          <span style="width:7px; height:7px; border-radius:50%; background:var(--accent); flex-shrink:0;"></span>
          <span style="font-family:'Geist Mono',monospace; font-size:12px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink2);">Reviews de IA en español</span>
        </div>
        <h1 style="margin:0; font-family:'Newsreader',serif; font-weight:500; font-size:clamp(2.4rem,4.5vw,3.875rem); line-height:1.02; letter-spacing:-0.025em; color:var(--ink);">
          Reviews y comparativas de herramientas de IA.<br>
          <span style="font-style:italic; color:var(--accent);">Sin humo</span>, en español.
        </h1>
        <p style="margin:26px 0 0; font-size:19px; line-height:1.6; color:var(--ink2); max-width:520px;">
          Analizamos cada semana las mejores herramientas de inteligencia artificial para que tú no pierdas el tiempo. Sin anglicismos, con criterio.
        </p>
        <div style="display:flex; align-items:center; gap:14px; margin-top:34px; flex-wrap:wrap;">
          <a href="/blog" class="btn-primary">Ver todos los artículos <span style="font-size:17px;">→</span></a>
          <a href="/que-ia-necesito" class="btn-secondary">Hacer el test</a>
        </div>
        <div style="display:flex; align-items:center; gap:28px; margin-top:42px; flex-wrap:wrap;">
          <div>
            <div style="font-family:'Newsreader',serif; font-size:34px; font-weight:600; line-height:1; color:var(--ink);">{herramientas.length}</div>
            <div style="font-family:'Geist Mono',monospace; font-size:12px; letter-spacing:0.04em; color:var(--ink3); margin-top:6px;">herramientas analizadas</div>
          </div>
          <div style="width:1px; height:38px; background:var(--border2);"></div>
          <div>
            <div style="font-family:'Newsreader',serif; font-size:34px; font-weight:600; line-height:1; color:var(--ink);">{totalArticulos}</div>
            <div style="font-family:'Geist Mono',monospace; font-size:12px; letter-spacing:0.04em; color:var(--ink3); margin-top:6px;">artículos publicados</div>
          </div>
          <div style="width:1px; height:38px; background:var(--border2);"></div>
          <div>
            <div style="font-family:'Newsreader',serif; font-size:34px; font-weight:600; line-height:1; color:var(--ink);">1×<span style="font-size:20px;">/sem</span></div>
            <div style="font-family:'Geist Mono',monospace; font-size:12px; letter-spacing:0.04em; color:var(--ink3); margin-top:6px;">reviews nuevas</div>
          </div>
        </div>
      </div>

      <!-- Ranking card -->
      <div style="width:min(380px, 100%); animation:fadeUp .6s ease .12s both;">
        <div style="background:var(--surface); border:1px solid var(--border); border-radius:18px; padding:8px; box-shadow:0 1px 2px var(--shadow), 0 12px 32px var(--shadow);">
          <div style="display:flex; align-items:center; justify-content:space-between; padding:16px 16px 14px;">
            <div style="display:flex; align-items:center; gap:9px;">
              <span style="width:8px; height:8px; border-radius:50%; background:#22c55e; box-shadow:0 0 0 3px rgba(34,197,94,0.16); flex-shrink:0;"></span>
              <span style="font-size:14px; font-weight:600; color:var(--ink);">Ranking de la semana</span>
            </div>
            <span style="font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.06em; color:var(--muted);">{mesLabel}</span>
          </div>
          <div style="display:flex; flex-direction:column; gap:2px;">
            {topRanking.map(row => (
              <a href="/ranking" class="ranking-row" style="display:flex; align-items:center; gap:14px; padding:13px 16px; border-radius:12px; text-decoration:none; transition:background .15s;">
                <span style="font-family:'Newsreader',serif; font-size:20px; font-weight:600; color:var(--muted); width:24px; flex-shrink:0;">{row.rank}</span>
                <div style="flex:1; min-width:0;">
                  <div style="font-size:15px; font-weight:600; color:var(--ink); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">{row.name}</div>
                  <div style="font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.03em; color:var(--muted); margin-top:2px;">{row.cat}</div>
                </div>
                <span style="font-family:'Newsreader',serif; font-size:18px; font-weight:600; color:var(--accent); flex-shrink:0;">{row.score}</span>
              </a>
            ))}
          </div>
          <a href="/ranking" class="ranking-footer" style="display:flex; align-items:center; justify-content:center; gap:7px; margin:8px; padding:12px; background:var(--bg); border-radius:12px; font-size:13px; font-weight:600; color:var(--ink2); text-decoration:none; transition:background .15s;">
            Ver ranking completo <span>→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- TEST BAND -->
  <section class="wrap" style="padding-bottom:80px;">
    <div style="position:relative; overflow:hidden; background:var(--band-bg); border:1px solid var(--band-border); border-radius:22px; padding:48px 52px; display:flex; align-items:center; justify-content:space-between; gap:40px; flex-wrap:wrap;">
      <div style="position:absolute; right:-60px; top:-60px; width:280px; height:280px; border-radius:50%; background:radial-gradient(circle, rgba(120,110,255,0.4), transparent 70%); pointer-events:none;" aria-hidden="true"></div>
      <div style="position:relative; max-width:560px;">
        <div style="display:inline-flex; align-items:center; gap:8px; margin-bottom:18px;">
          <span style="font-family:'Geist Mono',monospace; font-size:11px; font-weight:500; letter-spacing:0.1em; text-transform:uppercase; color:#0b0b0d; background:#a5f3a0; padding:4px 9px; border-radius:6px;">Nuevo</span>
          <span style="font-family:'Geist Mono',monospace; font-size:12px; letter-spacing:0.12em; text-transform:uppercase; color:#a1a1aa;">Recomendador</span>
        </div>
        <h2 style="margin:0; font-family:'Newsreader',serif; font-weight:500; font-size:38px; line-height:1.08; letter-spacing:-0.02em; color:#fafaf9;">¿No sabes qué IA usar?</h2>
        <p style="margin:14px 0 0; font-size:17px; line-height:1.6; color:#a1a1aa;">Responde 5 preguntas rápidas y te recomendamos la herramienta perfecta para tu caso de uso concreto.</p>
        <div style="display:flex; align-items:center; gap:7px; margin-top:22px;">
          {[1,2,3,4,5].map(n => (
            <span style="width:30px; height:30px; border-radius:8px; border:1px solid #3f3f46; display:flex; align-items:center; justify-content:center; font-family:'Geist Mono',monospace; font-size:12px; color:#71717a; flex-shrink:0;">{n}</span>
          ))}
        </div>
      </div>
      <a href="/que-ia-necesito" class="btn-quiz" style="position:relative; display:inline-flex; align-items:center; gap:10px; background:#4f46e5; color:#fff; padding:16px 26px; border-radius:12px; font-size:16px; font-weight:600; text-decoration:none; flex-shrink:0; transition:all .18s;">
        Hacer el test <span style="font-size:18px;">→</span>
      </a>
    </div>
  </section>

  <!-- ARTÍCULOS -->
  <section id="articulos" class="wrap" style="padding-bottom:40px;">
    <div style="display:flex; align-items:flex-end; justify-content:space-between; gap:20px; margin-bottom:32px;">
      <div>
        <span style="font-family:'Geist Mono',monospace; font-size:12px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink3);">El blog</span>
        <h2 style="margin:8px 0 0; font-family:'Newsreader',serif; font-weight:500; font-size:40px; line-height:1; letter-spacing:-0.02em; color:var(--ink);">Últimos artículos</h2>
      </div>
      <a href="/blog" style="font-size:14px; font-weight:600; color:var(--accent); text-decoration:none; white-space:nowrap; padding-bottom:6px;">Ver todos →</a>
    </div>

    {featuredArticulo && (
      <a href={`/blog/${featuredArticulo.slug}`} style="display:block; text-decoration:none; margin-bottom:40px;" class="featured-link">
        <article style="display:flex; gap:40px; background:var(--surface); border:1px solid var(--border); border-radius:20px; padding:14px; align-items:stretch; transition:all .2s; flex-wrap:wrap;" class="article-featured">
          <div style="flex:1; min-width:280px; border-radius:13px; border:1px solid var(--border); min-height:300px; position:relative; overflow:hidden;">
            {featuredArticulo.data.imagen ? (
              <img
                src={featuredArticulo.data.imagen}
                alt={featuredArticulo.data.title}
                style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover;"
                loading="eager"
                decoding="async"
              />
            ) : (
              <div style="position:absolute; inset:0; background-image:repeating-linear-gradient(135deg,var(--stripe-a),var(--stripe-a) 11px,var(--stripe-b) 11px,var(--stripe-b) 22px);" aria-hidden="true"></div>
            )}
            <span style="position:absolute; top:16px; left:16px; font-family:'Geist Mono',monospace; font-size:11px; font-weight:500; letter-spacing:0.06em; text-transform:uppercase; background:var(--ink); color:var(--bg); padding:5px 10px; border-radius:7px; z-index:1;">Destacado</span>
          </div>
          <div style="flex:1; min-width:280px; padding:22px 24px 24px 8px; display:flex; flex-direction:column; justify-content:center;">
            <div style="display:flex; align-items:center; gap:10px; margin-bottom:16px; flex-wrap:wrap;">
              <span style="font-size:12px; font-weight:600; color:var(--accent); background:var(--accent-tint); padding:5px 11px; border-radius:7px;">{CATEGORIA_LABELS[featuredArticulo.data.category]}</span>
              <span style="font-family:'Geist Mono',monospace; font-size:12px; color:var(--muted);">{formatDateFull(featuredArticulo.data.date)} · {readingTime(featuredArticulo.body)} MIN</span>
            </div>
            <h3 style="margin:0; font-family:'Newsreader',serif; font-weight:500; font-size:34px; line-height:1.12; letter-spacing:-0.02em; color:var(--ink);">{featuredArticulo.data.title}</h3>
            <p style="margin:16px 0 0; font-size:16px; line-height:1.6; color:var(--ink2);">{featuredArticulo.data.description}</p>
            <span style="display:inline-flex; align-items:center; gap:8px; margin-top:24px; font-size:14px; font-weight:600; color:var(--ink);">
              Leer artículo completo <span style="color:var(--accent);">→</span>
            </span>
          </div>
        </article>
      </a>
    )}

    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:28px;">
      {gridArticulos.map(articulo => (
        <a href={`/blog/${articulo.slug}`} style="display:block; text-decoration:none;">
          <article style="background:var(--surface); border:1px solid var(--border); border-radius:16px; padding:12px; height:100%; display:flex; flex-direction:column; transition:all .2s;" class="article-card">
            <div style="border-radius:11px; border:1px solid var(--border); height:178px; position:relative; overflow:hidden; flex-shrink:0;">
              {articulo.data.imagen ? (
                <img
                  src={articulo.data.imagen}
                  alt={articulo.data.title}
                  style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover;"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div style="position:absolute; inset:0; background-image:repeating-linear-gradient(135deg,var(--stripe-a),var(--stripe-a) 11px,var(--stripe-b) 11px,var(--stripe-b) 22px);" aria-hidden="true"></div>
              )}
            </div>
            <div style="padding:18px 10px 12px; flex:1; display:flex; flex-direction:column;">
              <div style="display:flex; align-items:center; gap:9px; margin-bottom:13px; flex-wrap:wrap;">
                <span style="font-size:11px; font-weight:600; color:var(--accent); background:var(--accent-tint); padding:4px 9px; border-radius:6px;">{CATEGORIA_LABELS[articulo.data.category]}</span>
                <span style="font-family:'Geist Mono',monospace; font-size:11px; color:var(--muted);">{formatDateShort(articulo.data.date)} · {readingTime(articulo.body)} MIN</span>
              </div>
              <h3 style="margin:0; font-family:'Newsreader',serif; font-weight:500; font-size:21px; line-height:1.2; letter-spacing:-0.01em; color:var(--ink);">{articulo.data.title}</h3>
              <p style="margin:11px 0 0; font-size:14px; line-height:1.55; color:var(--ink3); flex:1;">{articulo.data.description}</p>
            </div>
          </article>
        </a>
      ))}
    </div>
  </section>

  <!-- CATEGORÍAS -->
  <section class="wrap" style="padding-top:64px; padding-bottom:24px;">
    <div style="margin-bottom:28px;">
      <span style="font-family:'Geist Mono',monospace; font-size:12px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink3);">Navega</span>
      <h2 style="margin:8px 0 0; font-family:'Newsreader',serif; font-weight:500; font-size:32px; line-height:1; letter-spacing:-0.02em; color:var(--ink);">Explora por categoría</h2>
    </div>
    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:14px;">
      {categorias.map(c => (
        <a href={`/blog?cat=${c.slug}`} class="cat-card" style="display:flex; align-items:center; justify-content:space-between; background:var(--surface); border:1px solid var(--border); border-radius:13px; padding:18px 20px; text-decoration:none; transition:all .16s;">
          <span style="font-size:15px; font-weight:600; color:var(--ink);">{c.label}</span>
          <span style="font-family:'Geist Mono',monospace; font-size:12px; color:var(--muted);">{String(c.count).padStart(2, '0')}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section id="newsletter" class="wrap" style="padding-top:56px; padding-bottom:80px;">
    <div style="background:var(--surface); border:1px solid var(--border); border-radius:22px; padding:56px 40px; text-align:center;">
      <span style="font-family:'Geist Mono',monospace; font-size:12px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink3);">Newsletter</span>
      <h2 style="margin:14px 0 0; font-family:'Newsreader',serif; font-weight:500; font-size:38px; line-height:1.06; letter-spacing:-0.02em; color:var(--ink);">Mantente al día con la IA</h2>
      <p style="margin:14px auto 0; font-size:17px; line-height:1.55; color:var(--ink2); max-width:460px;">Reviews, comparativas y guías directamente en tu bandeja de entrada. Sin spam, cancela cuando quieras.</p>
      <form id="nl-form" style="display:flex; gap:10px; max-width:440px; margin:28px auto 0; flex-wrap:wrap; justify-content:center;">
        <input
          id="nl-email"
          type="email"
          required
          placeholder="tu@correo.com"
          style="flex:1; min-width:220px; padding:14px 18px; border:1px solid var(--border2); border-radius:11px; font-family:'Geist',sans-serif; font-size:15px; color:var(--ink); outline:none; background:var(--bg); transition:border-color .18s;"
          class="nl-input"
        />
        <button
          id="nl-btn"
          type="submit"
          style="background:var(--ink); color:var(--bg); border:none; padding:14px 24px; border-radius:11px; font-family:'Geist',sans-serif; font-size:15px; font-weight:600; cursor:pointer; transition:all .18s; white-space:nowrap;"
          class="nl-btn"
        >Suscribirme</button>
      </form>
      <p id="nl-error" style="display:none; margin-top:16px; font-size:14px; color:#ef4444;"></p>
      <div id="nl-success" style="display:none; align-items:center; justify-content:center; gap:10px; margin-top:28px; background:var(--accent-tint); color:var(--accent); padding:14px 22px; border-radius:11px; font-size:15px; font-weight:600; max-width:440px; margin-left:auto; margin-right:auto;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
        ¡Listo! Revisa tu correo para confirmar.
      </div>
    </div>
  </section>
</Layout>

<style>
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    background: var(--ink);
    color: var(--bg);
    padding: 14px 22px;
    border-radius: 11px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    transition: all .18s;
  }
  .btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 10px 24px var(--shadow);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    background: var(--surface);
    color: var(--ink);
    padding: 14px 22px;
    border: 1px solid var(--border2);
    border-radius: 11px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    transition: all .18s;
  }
  .btn-secondary:hover { border-color: var(--ink); }

  .ranking-row:hover { background: var(--hover); }
  .ranking-footer:hover { background: var(--hover); }

  .btn-quiz:hover {
    transform: translateY(-1px);
    filter: brightness(1.08);
  }

  .article-featured:hover {
    box-shadow: 0 18px 40px var(--shadow);
    transform: translateY(-2px);
  }
  .featured-link:hover .article-featured {
    box-shadow: 0 18px 40px var(--shadow);
    transform: translateY(-2px);
  }

  .article-card:hover {
    box-shadow: 0 14px 32px var(--shadow);
    transform: translateY(-3px);
  }

  .cat-card:hover {
    border-color: var(--ink);
    transform: translateY(-2px);
  }

  .nl-input:focus { border-color: var(--accent); background: var(--surface); }
  .nl-btn:hover { transform: translateY(-1px); box-shadow: 0 10px 24px var(--shadow); }
  .nl-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; box-shadow: none; }

</style>

<script>
  const form = document.getElementById('nl-form') as HTMLFormElement | null;
  const emailInput = document.getElementById('nl-email') as HTMLInputElement | null;
  const btn = document.getElementById('nl-btn') as HTMLButtonElement | null;
  const errorEl = document.getElementById('nl-error') as HTMLElement | null;
  const successEl = document.getElementById('nl-success') as HTMLElement | null;

  if (window.location.hash === '#newsletter') {
    emailInput?.focus();
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!btn || !emailInput || !errorEl || !successEl) return;

    btn.disabled = true;
    btn.textContent = 'Enviando…';
    errorEl.style.display = 'none';

    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: emailInput.value.trim() }),
      });
      const data = await res.json();

      if (res.ok) {
        form.style.display = 'none';
        successEl.style.display = 'flex';
      } else {
        errorEl.textContent = data.error ?? 'Error al suscribirse. Inténtalo de nuevo.';
        errorEl.style.display = 'block';
        btn.disabled = false;
        btn.textContent = 'Suscribirme';
      }
    } catch {
      errorEl.textContent = 'Error de conexión. Inténtalo de nuevo.';
      errorEl.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Suscribirme';
    }
  });
</script>
