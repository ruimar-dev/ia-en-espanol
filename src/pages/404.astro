---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { CATEGORIA_LABELS } from '../content/config';

const recientes = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

function formatDate(date: Date) {
  return date.toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' }).toUpperCase().replace('.', '');
}
---

<Layout
  title="Página no encontrada — IA en Español"
  description="Esta página no existe, pero tenemos cientos de reviews y comparativas de herramientas de IA en español que sí existen."
>
  <div class="wrap" style="padding-top:80px; padding-bottom:100px; text-align:center;">

    <!-- Número 404 -->
    <div style="font-family:'Newsreader',serif; font-size:clamp(7rem,20vw,11rem); font-weight:600; line-height:1; letter-spacing:-0.04em; color:var(--accent); opacity:0.18; user-select:none;" aria-hidden="true">
      404
    </div>

    <!-- Mensaje -->
    <div style="max-width:520px; margin:-24px auto 0;">
      <h1 style="margin:0; font-family:'Newsreader',serif; font-weight:500; font-size:clamp(1.8rem,4vw,2.5rem); line-height:1.1; letter-spacing:-0.02em; color:var(--ink);">
        Esta página no existe
      </h1>
      <p style="margin:18px 0 0; font-size:17px; line-height:1.6; color:var(--ink2);">
        Puede que el enlace esté roto o que la URL haya cambiado. No te vayas — seguro que lo que buscas está por aquí.
      </p>

      <!-- Botones -->
      <div style="display:flex; align-items:center; justify-content:center; gap:12px; margin-top:32px; flex-wrap:wrap;">
        <a href="/" style="display:inline-flex; align-items:center; gap:8px; background:var(--ink); color:var(--bg); padding:13px 22px; border-radius:11px; font-family:'Geist',sans-serif; font-size:15px; font-weight:600; text-decoration:none; transition:all .18s;">
          ← Ir al inicio
        </a>
        <a href="/buscar" style="display:inline-flex; align-items:center; gap:8px; background:var(--surface); color:var(--ink); border:1px solid var(--border2); padding:13px 22px; border-radius:11px; font-family:'Geist',sans-serif; font-size:15px; font-weight:600; text-decoration:none; transition:all .18s;">
          Buscar contenido
        </a>
      </div>
    </div>

    <!-- Divisor -->
    <div style="max-width:560px; margin:64px auto 0; border-top:1px solid var(--border);"></div>

    <!-- Artículos recientes -->
    <div style="max-width:880px; margin:52px auto 0; text-align:left;">
      <p style="margin:0 0 28px; font-family:'Geist Mono',monospace; font-size:12px; letter-spacing:0.14em; text-transform:uppercase; color:var(--ink3); text-align:center;">
        Mientras tanto, lee esto
      </p>
      <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:20px;">
        {recientes.map(a => (
          <a href={`/blog/${a.slug}`} class="card-link" style="display:block; text-decoration:none;">
            <article class="article-card-404" style="background:var(--surface); border:1px solid var(--border); border-radius:16px; padding:12px; height:100%; display:flex; flex-direction:column; transition:all .2s;">
              <div style="border-radius:11px; border:1px solid var(--border); height:160px; position:relative; overflow:hidden; flex-shrink:0;">
                {a.data.imagen ? (
                  <img
                    src={a.data.imagen}
                    alt={a.data.title}
                    style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover;"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <div style="position:absolute; inset:0; background-image:repeating-linear-gradient(135deg,var(--stripe-a),var(--stripe-a) 11px,var(--stripe-b) 11px,var(--stripe-b) 22px);" aria-hidden="true"></div>
                )}
              </div>
              <div style="padding:16px 10px 10px; flex:1; display:flex; flex-direction:column;">
                <div style="display:flex; align-items:center; gap:8px; margin-bottom:10px; flex-wrap:wrap;">
                  <span style="font-size:11px; font-weight:600; color:var(--accent); background:var(--accent-tint); padding:3px 9px; border-radius:6px;">{CATEGORIA_LABELS[a.data.category]}</span>
                  <span style="font-family:'Geist Mono',monospace; font-size:11px; color:var(--muted);">{formatDate(a.data.date)}</span>
                </div>
                <h3 style="margin:0; font-family:'Newsreader',serif; font-weight:500; font-size:19px; line-height:1.2; letter-spacing:-0.01em; color:var(--ink); flex:1;">{a.data.title}</h3>
                <p style="margin:10px 0 0; font-size:13px; line-height:1.5; color:var(--ink3);">{a.data.description}</p>
              </div>
            </article>
          </a>
        ))}
      </div>

      <div style="text-align:center; margin-top:36px;">
        <a href="/blog" style="display:inline-flex; align-items:center; gap:7px; font-size:14px; font-weight:600; color:var(--accent); text-decoration:none;">
          Ver todos los artículos →
        </a>
      </div>
    </div>

  </div>
</Layout>

<style>
  .article-card-404:hover {
    box-shadow: 0 14px 32px var(--shadow);
    transform: translateY(-3px);
  }
  .card-link:hover .article-card-404 {
    box-shadow: 0 14px 32px var(--shadow);
    transform: translateY(-3px);
  }
</style>
