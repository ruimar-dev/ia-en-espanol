---
import Layout from '../../layouts/Layout.astro';
import { ranking } from '../../data/ranking';
import type { Tendencia } from '../../data/ranking';

const { semana, actualizadoEl, herramientas } = ranking;

const fechaLabel = new Date(actualizadoEl)
  .toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' })
  .toUpperCase()
  .replace('.', '');

function cambioTexto(t: Tendencia, n: number): string {
  if (t === 'nueva') return '✦ NUEVA';
  if (t === 'sube')  return `↑ ${n}`;
  if (t === 'baja')  return `↓ ${n}`;
  return '—';
}

function cambioColor(t: Tendencia): string {
  if (t === 'sube')  return 'var(--good)';
  if (t === 'baja')  return 'var(--bad)';
  if (t === 'nueva') return 'var(--accent)';
  return 'var(--muted)';
}

// Scores de presentación basados en posición (escala 10)
const SCORES = [9.4, 9.2, 9.0, 8.8, 8.7, 8.6, 8.5, 8.4, 8.3, 8.2];
function nota(pos: number): string {
  return (SCORES[pos - 1] ?? (10 - pos * 0.2)).toFixed(1);
}
---

<Layout
  title={`Ranking semanal de herramientas IA — Semana del ${semana}`}
  description={`Las 10 mejores herramientas de IA según calidad, precio y experiencia. Ranking actualizado el ${fechaLabel}.`}
>
  <!-- Cabecera -->
  <section class="wrap--mid" style="padding-top:64px;">
    <div style="display:flex; align-items:center; gap:9px; margin-bottom:14px;">
      <span style="width:8px; height:8px; border-radius:50%; background:#22c55e; box-shadow:0 0 0 3px rgba(34,197,94,0.16); flex-shrink:0;"></span>
      <span style="font-family:'Geist Mono',monospace; font-size:12px; letter-spacing:0.14em; text-transform:uppercase; color:var(--ink3);">Actualizado · Semana del {semana}</span>
    </div>
    <h1 style="margin:0; font-family:'Newsreader',serif; font-weight:500; font-size:clamp(2.5rem,5vw,3.375rem); line-height:1.02; letter-spacing:-0.025em; color:var(--ink);">Ranking semanal</h1>
    <p style="margin:18px 0 0; font-size:19px; line-height:1.55; color:var(--ink2); max-width:560px;">Nuestra clasificación de las mejores herramientas de IA según calidad, precio y experiencia de uso. Se recalcula cada semana con cada review nueva.</p>
  </section>

  <!-- Tabla -->
  <section class="wrap--mid" style="padding-top:36px;">
    <div style="background:var(--surface); border:1px solid var(--border); border-radius:18px; overflow:hidden; box-shadow:0 1px 2px var(--shadow), 0 12px 32px var(--shadow);">

      <!-- Cabecera tabla -->
      <div class="tabla-head" style="display:grid; grid-template-columns:56px 1fr 140px 80px 72px; gap:16px; padding:14px 24px; border-bottom:1px solid var(--border); font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.08em; text-transform:uppercase; color:var(--muted);">
        <span>#</span>
        <span>Herramienta</span>
        <span class="hide-mobile">Categoría</span>
        <span style="text-align:right;">Nota</span>
        <span style="text-align:right;">Var.</span>
      </div>

      <!-- Filas -->
      {herramientas.map((h, i) => (
        <a
          href={h.url}
          target="_blank"
          rel="noopener noreferrer"
          class="tabla-row"
          style="display:grid; grid-template-columns:56px 1fr 140px 80px 72px; gap:16px; align-items:center; padding:18px 24px; border-bottom:1px solid var(--border); text-decoration:none; transition:background .15s;"
        >
          <span style={`font-family:'Newsreader',serif; font-size:26px; font-weight:600; color:${i < 3 ? 'var(--ink)' : 'var(--muted)'};`}>
            {String(h.posicion).padStart(2, '0')}
          </span>
          <div>
            <div style="font-size:16px; font-weight:600; color:var(--ink); line-height:1.2;">{h.nombre}</div>
            <div style="font-family:'Geist Mono',monospace; font-size:11px; color:var(--muted); margin-top:3px;">{h.empresa}</div>
          </div>
          <span class="hide-mobile" style="font-family:'Geist Mono',monospace; font-size:12px; color:var(--ink3);">{h.categoria}</span>
          <span style="text-align:right; font-family:'Newsreader',serif; font-size:20px; font-weight:600; color:var(--accent);">
            {nota(h.posicion)}
          </span>
          <span style={`text-align:right; font-family:'Geist Mono',monospace; font-size:12px; font-weight:500; color:${cambioColor(h.tendencia)};`}>
            {cambioTexto(h.tendencia, h.cambio)}
          </span>
        </a>
      ))}
    </div>
    <p style="margin:20px 0 0; font-family:'Geist Mono',monospace; font-size:12px; line-height:1.6; color:var(--muted); text-align:center;">
      La nota combina calidad de resultados, relación calidad/precio y facilidad de uso. Metodología en <a href="/sobre-mi" style="color:var(--accent); text-decoration:none;">Sobre mí</a>.
    </p>
  </section>

  <!-- Por qué están en tendencia -->
  <section class="wrap--mid" style="padding-top:56px;">
    <span style="font-family:'Geist Mono',monospace; font-size:12px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink3);">Contexto</span>
    <h2 style="margin:8px 0 28px; font-family:'Newsreader',serif; font-weight:500; font-size:32px; letter-spacing:-0.02em; color:var(--ink);">Por qué están en el ranking</h2>
    <div style="display:flex; flex-direction:column; gap:16px;">
      {herramientas.map(h => (
        <div style="display:flex; gap:20px; padding:22px 24px; background:var(--surface); border:1px solid var(--border); border-radius:16px;">
          <div style="flex-shrink:0; display:flex; align-items:center; justify-content:center; width:36px; height:36px; border-radius:10px; background:var(--accent-tint);">
            <span style="font-family:'Newsreader',serif; font-size:16px; font-weight:600; color:var(--accent);">{h.posicion}</span>
          </div>
          <div style="flex:1; min-width:0;">
            <div style="display:flex; align-items:center; gap:10px; margin-bottom:6px; flex-wrap:wrap;">
              <span style="font-size:15px; font-weight:600; color:var(--ink);">{h.nombre}</span>
              <span style={`font-family:'Geist Mono',monospace; font-size:11px; font-weight:500; color:${cambioColor(h.tendencia)};`}>
                {cambioTexto(h.tendencia, h.cambio)}
              </span>
              <span style="font-family:'Geist Mono',monospace; font-size:11px; color:var(--muted);">{h.precio}</span>
            </div>
            <p style="margin:0; font-size:14px; line-height:1.6; color:var(--ink2);">{h.razonTrending}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Metodología -->
  <section class="wrap--mid" style="padding-top:32px; padding-bottom:80px;">
    <div style="padding:22px 24px; background:var(--surface); border:1px solid var(--border); border-radius:16px;">
      <p style="margin:0 0 6px; font-size:14px; font-weight:600; color:var(--ink);">¿Cómo se elabora este ranking?</p>
      <p style="margin:0; font-size:14px; line-height:1.65; color:var(--ink2);">Cada lunes reviso tendencias de búsqueda, lanzamientos oficiales, menciones en comunidades de IA en español y novedades en Product Hunt. El ranking refleja mi criterio editorial y no está patrocinado. Si crees que falta alguna herramienta, escríbeme.</p>
    </div>
  </section>
</Layout>

<style>
  .tabla-row:hover { background: var(--hover); }
  .tabla-row:last-child { border-bottom: none; }

  @media (max-width: 600px) {
    .tabla-head { grid-template-columns: 44px 1fr 72px 60px !important; }
    .tabla-row  { grid-template-columns: 44px 1fr 72px 60px !important; padding: 14px 16px !important; }
    .hide-mobile { display: none; }
  }
</style>
