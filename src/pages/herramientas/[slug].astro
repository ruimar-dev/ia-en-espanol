---
import Layout from '../../layouts/Layout.astro';
import ArticuloCard from '../../components/ArticuloCard.astro';
import BannerAfiliado from '../../components/BannerAfiliado.astro';
import { herramientas } from '../../data/herramientas';
import { getCollection } from 'astro:content';
import { CATEGORIA_LABELS } from '../../content/config';

export async function getStaticPaths() {
  const articulos = await getCollection('blog', ({ data }) => !data.draft);

  return herramientas.map((herramienta) => {
    const articulosRelacionados = articulos
      .filter((a) =>
        a.data.herramientas.some((h) => {
          const hl = h.toLowerCase();
          const nl = herramienta.nombre.toLowerCase();
          return hl === nl || hl.includes(nl) || nl.includes(hl);
        })
      )
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

    return {
      params: { slug: herramienta.slug },
      props: { herramienta, articulosRelacionados },
    };
  });
}

const { herramienta, articulosRelacionados } = Astro.props;
const siteUrl = import.meta.env.SITE_URL || Astro.site?.toString() || 'https://iaenespanol.es';
const canonical = `${siteUrl}/herramientas/${herramienta.slug}`;

const stars = Array.from({ length: 5 }, (_, i) => i < Math.round(herramienta.rating));

const APP_CATEGORY: Record<string, string> = {
  'generacion-texto': 'Productivity',
  'generacion-imagen': 'DesignApplication',
  'codigo': 'DeveloperApplication',
  'audio': 'MultimediaApplication',
  'video': 'MultimediaApplication',
  'productividad': 'ProductivityApplication',
};

const softwareAppLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: herramienta.nombre,
  applicationCategory: APP_CATEGORY[herramienta.categoria],
  operatingSystem: 'Web',
  description: herramienta.descripcion,
  url: herramienta.url,
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: herramienta.rating.toFixed(1),
    bestRating: '5',
    worstRating: '1',
    ratingCount: String(Math.max(articulosRelacionados.length, 1)),
  },
});

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Herramientas', item: `${siteUrl}/herramientas` },
    { '@type': 'ListItem', position: 3, name: herramienta.nombre, item: canonical },
  ],
});
---

<Layout
  title={`${herramienta.nombre}: análisis, reviews y comparativas`}
  description={`Análisis completo de ${herramienta.nombre}. Puntuación editorial: ${herramienta.rating}/5. ${herramienta.descripcion}`}
  canonicalUrl={canonical}
>
  <script type="application/ld+json" set:html={softwareAppLd} />
  <script type="application/ld+json" set:html={breadcrumbLd} />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mb-8" aria-label="Migas de pan">
      <a href="/" class="hover:text-[#7C3AED] transition-colors">Inicio</a>
      <span aria-hidden="true">/</span>
      <a href="/herramientas" class="hover:text-[#7C3AED] transition-colors">Herramientas</a>
      <span aria-hidden="true">/</span>
      <span class="text-gray-700 dark:text-gray-300">{herramienta.nombre}</span>
    </nav>

    <!-- Hero -->
    <div class="bg-white dark:bg-[#1A1A1A] rounded-2xl p-6 sm:p-8 border border-gray-200 dark:border-gray-800 mb-8">
      <div class="flex items-start gap-5">
        <div class="w-16 h-16 sm:w-20 sm:h-20 rounded-2xl bg-gradient-to-br from-[#7C3AED]/20 to-[#6D28D9]/30 flex items-center justify-center flex-shrink-0 overflow-hidden">
          {herramienta.logo ? (
            <img
              src={herramienta.logo}
              alt={`Logo de ${herramienta.nombre}`}
              width="80"
              height="80"
              class="w-full h-full object-cover rounded-2xl"
              loading="eager"
            />
          ) : (
            <span class="text-[#7C3AED] font-bold text-2xl" aria-hidden="true">{herramienta.nombre[0]}</span>
          )}
        </div>

        <div class="flex-1 min-w-0">
          <div class="flex flex-wrap items-center gap-2 mb-2">
            <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white">{herramienta.nombre}</h1>
            <span class="text-xs font-semibold bg-[#7C3AED]/10 text-[#7C3AED] px-2.5 py-1 rounded-full">
              {CATEGORIA_LABELS[herramienta.categoria]}
            </span>
          </div>

          <div
            class="flex items-center gap-1 mb-3"
            role="img"
            aria-label={`Puntuación: ${herramienta.rating} de 5 estrellas`}
          >
            {stars.map((filled) => (
              <svg
                class:list={['w-5 h-5', filled ? 'text-yellow-400' : 'text-gray-300 dark:text-gray-600']}
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
              </svg>
            ))}
            <span class="text-sm font-semibold text-gray-700 dark:text-gray-300 ml-1">
              {herramienta.rating.toFixed(1)}
            </span>
            <span class="text-sm text-gray-500 dark:text-gray-400">/ 5</span>
          </div>

          <p class="text-gray-600 dark:text-gray-400 leading-relaxed">{herramienta.descripcion}</p>
        </div>
      </div>

      {herramienta.url && (
        <div class="mt-6 pt-5 border-t border-gray-100 dark:border-gray-800 flex items-center gap-3 flex-wrap">
          <a
            href={herramienta.afiliado ?? herramienta.url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-semibold px-5 py-2.5 rounded-xl transition-colors"
          >
            Ir a {herramienta.nombre}
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
          {herramienta.afiliado && (
            <span class="text-xs text-gray-400 dark:text-gray-500">Enlace de afiliado</span>
          )}
        </div>
      )}
    </div>

    <!-- Banner afiliado (solo si tiene programa) -->
    {herramienta.afiliado && (
      <div class="mb-8">
        <BannerAfiliado
          titulo={`Prueba ${herramienta.nombre}`}
          descripcion="Si este análisis te ha sido útil, considera usar el enlace de afiliado. Sin coste adicional para ti."
          cta={`Probar ${herramienta.nombre}`}
          url={herramienta.afiliado}
          badge="Enlace de afiliado"
        />
      </div>
    )}

    <!-- Artículos relacionados -->
    <section>
      <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-6">
        Artículos sobre {herramienta.nombre}
        <span class="text-base font-normal text-gray-500 dark:text-gray-400 ml-2">
          ({articulosRelacionados.length})
        </span>
      </h2>

      {articulosRelacionados.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          {articulosRelacionados.map((a) => (
            <ArticuloCard
              title={a.data.title}
              description={a.data.description}
              date={a.data.date}
              category={a.data.category}
              slug={a.slug}
              imagen={a.data.imagen}
            />
          ))}
        </div>
      ) : (
        <p class="text-gray-500 dark:text-gray-400">
          Aún no tenemos artículos específicos sobre {herramienta.nombre}. Vuelve pronto.
        </p>
      )}
    </section>

    <div class="mt-10">
      <a
        href="/herramientas"
        class="inline-flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-[#7C3AED] transition-colors"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Ver todas las herramientas
      </a>
    </div>
  </div>
</Layout>
