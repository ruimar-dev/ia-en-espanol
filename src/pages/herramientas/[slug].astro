---
import Layout from '../../layouts/Layout.astro';
import ArticuloCard from '../../components/ArticuloCard.astro';
import BannerAfiliado from '../../components/BannerAfiliado.astro';
import { herramientas } from '../../data/herramientas';
import { getCollection } from 'astro:content';
import { CATEGORIA_LABELS } from '../../content/config';

export async function getStaticPaths() {
  // Coincidencia entre un tag de herramienta de un artículo y la herramienta del hub.
  // Acepta: nombre exacto, variantes de marca (Google Gemini → Gemini, Perplexity AI →
  // Perplexity), versiones numéricas (Stable Diffusion 3 → Stable Diffusion) y nombres
  // más largos del producto (Runway ⊂ RunwayML).
  // Rechaza: sub-modelos con tier (Gemini 2.5 Pro, Claude Sonnet 4.6), que son menciones
  // de pasada del motor, no del producto que da nombre al hub.
  const TIER_WORDS = new Set(['pro', 'sonnet', 'opus', 'haiku', 'flash', 'mini', 'turbo', 'max', 'ultra', 'plus', 'nano', 'lite', 'thinking', 'instant', 'preview', 'reasoner']);
  const BRAND_WORDS = new Set(['google', 'openai', 'microsoft', 'anthropic', 'adobe', 'meta', 'ai', 'the']);

  const norm = (s: string) => s.toLowerCase().trim().replace(/\s+/g, ' ');
  const allNombres = new Set(herramientas.map((h) => norm(h.nombre)));

  const subseqIndex = (hay: string[], needle: string[]): number => {
    if (needle.length === 0 || needle.length > hay.length) return -1;
    for (let i = 0; i + needle.length <= hay.length; i++) {
      if (needle.every((tok, j) => hay[i + j] === tok)) return i;
    }
    return -1;
  };

  const tagMatchesTool = (tag: string, tool: string): boolean => {
    const h = norm(tag);
    const n = norm(tool);
    if (h === n) return true;
    const ht = h.split(' ');
    const nt = n.split(' ');
    const idx = subseqIndex(ht, nt);
    if (idx !== -1) {
      // El nombre de la herramienta aparece dentro del tag: solo es válido si los tokens
      // sobrantes son de marca/"ai" o versiones numéricas — nunca un tier de sub-modelo.
      const extra = ht.filter((_, i) => i < idx || i >= idx + nt.length);
      return extra.every((t) => !TIER_WORDS.has(t) && (BRAND_WORDS.has(t) || /\d/.test(t)));
    }
    // Si el tag coincide exactamente con el nombre de OTRA herramienta del catálogo, es un
    // producto distinto (p. ej. "Claude" vs "Claude Code") y no debe caer en el caso inverso.
    if (allNombres.has(h)) return false;
    // Caso inverso: el nombre de la herramienta contiene el tag (Runway ⊂ RunwayML).
    return h.length >= 4 && n.includes(h);
  };

  const articulos = await getCollection('blog', ({ data }) => !data.draft);

  return herramientas.map((herramienta) => {
    const articulosRelacionados = articulos
      .filter((a) =>
        a.data.herramientas.some((h) => tagMatchesTool(h, herramienta.nombre))
      )
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

    return {
      params: { slug: herramienta.slug },
      props: { herramienta, articulosRelacionados },
    };
  });
}

const { herramienta, articulosRelacionados } = Astro.props;
const siteUrl = import.meta.env.SITE_URL || Astro.site?.toString() || 'https://iaenespanol.es';
const canonical = `${siteUrl}/herramientas/${herramienta.slug}`;

// Nota en escala /10 (convención del sitio) + estrellas decorativas /5
const rating10 = (herramienta.rating * 2).toFixed(1);
const stars = Array.from({ length: 5 }, (_, i) => i < Math.round(herramienta.rating));

// Color por categoría — mismo sistema que /comparativas
const CATEGORIA_COLOR: Record<string, string> = {
  'generacion-texto': '#7C3AED',
  'generacion-imagen': '#2563EB',
  'codigo': '#16A34A',
  'audio': '#EA580C',
  'video': '#DC2626',
  'productividad': '#0D9488',
};
const cColor = CATEGORIA_COLOR[herramienta.categoria] ?? '#7C3AED';

// Dominio legible para la ficha
let dominio = '';
if (herramienta.url) {
  try {
    dominio = new URL(herramienta.url).hostname.replace(/^www\./, '');
  } catch {
    dominio = '';
  }
}

const APP_CATEGORY: Record<string, string> = {
  'generacion-texto': 'Productivity',
  'generacion-imagen': 'DesignApplication',
  'codigo': 'DeveloperApplication',
  'audio': 'MultimediaApplication',
  'video': 'MultimediaApplication',
  'productividad': 'ProductivityApplication',
};

const softwareAppLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: herramienta.nombre,
  applicationCategory: APP_CATEGORY[herramienta.categoria],
  operatingSystem: 'Web',
  description: herramienta.descripcion,
  url: herramienta.url,
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: herramienta.rating.toFixed(1),
    bestRating: '5',
    worstRating: '1',
    ratingCount: String(Math.max(articulosRelacionados.length, 1)),
  },
});

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Herramientas', item: `${siteUrl}/herramientas` },
    { '@type': 'ListItem', position: 3, name: herramienta.nombre, item: canonical },
  ],
});
---

<Layout
  title={`${herramienta.nombre}: análisis, reviews y comparativas`}
  description={`Análisis completo de ${herramienta.nombre}. Puntuación editorial: ${rating10}/10. ${herramienta.descripcion}`}
  canonicalUrl={canonical}
>
  <script type="application/ld+json" set:html={softwareAppLd} />
  <script type="application/ld+json" set:html={breadcrumbLd} />

  <!-- ── HERO ───────────────────────────────────────── -->
  <section class="tool-hero" style={`--c:${cColor};`}>
    <div class="wrap" style="position:relative; z-index:1; padding-top:40px; padding-bottom:8px;">
      <!-- Breadcrumb -->
      <nav class="tool-bc" aria-label="Migas de pan">
        <a href="/">Inicio</a>
        <span aria-hidden="true">/</span>
        <a href="/herramientas">Herramientas</a>
        <span aria-hidden="true">/</span>
        <span class="tool-bc-current">{herramienta.nombre}</span>
      </nav>

      <div class="hero-grid">
        <!-- Columna izquierda: identidad -->
        <div class="hero-main">
          <div class="hero-id">
            <div class="hero-logo">
              {herramienta.logo ? (
                <img
                  src={herramienta.logo}
                  alt={`Logo de ${herramienta.nombre}`}
                  width="64"
                  height="64"
                  loading="eager"
                  decoding="async"
                />
              ) : (
                <span aria-hidden="true">{herramienta.nombre[0]}</span>
              )}
            </div>
            <span class="hero-cat">{CATEGORIA_LABELS[herramienta.categoria]}</span>
          </div>

          <h1 class="hero-title">{herramienta.nombre}</h1>
          <p class="hero-desc">{herramienta.descripcion}</p>

          {herramienta.url && (
            <div class="hero-cta-row">
              <a
                href={herramienta.afiliado ?? herramienta.url}
                target="_blank"
                rel="noopener noreferrer"
                class="hero-cta"
              >
                Ir a {herramienta.nombre}
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
              {herramienta.afiliado && <span class="hero-aff">Enlace de afiliado</span>}
            </div>
          )}
        </div>

        <!-- Columna derecha: ficha técnica -->
        <aside class="hero-card" aria-label="Ficha de la herramienta">
          <div class="ficha-score">
            <span class="ficha-num">{rating10}</span>
            <span class="ficha-den">/10</span>
          </div>
          <div class="ficha-stars" role="img" aria-label={`Puntuación: ${rating10} de 10`}>
            {stars.map((filled) => (
              <svg class:list={['star', filled && 'star--on']} width="16" height="16" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
              </svg>
            ))}
          </div>
          <span class="ficha-score-label">Nota editorial</span>

          <div class="ficha-rows">
            <div class="ficha-row">
              <span class="ficha-k">Categoría</span>
              <span class="ficha-v">{CATEGORIA_LABELS[herramienta.categoria]}</span>
            </div>
            <div class="ficha-row">
              <span class="ficha-k">Análisis</span>
              <span class="ficha-v">{articulosRelacionados.length} {articulosRelacionados.length === 1 ? 'artículo' : 'artículos'}</span>
            </div>
            {dominio && (
              <div class="ficha-row">
                <span class="ficha-k">Web</span>
                <span class="ficha-v">{dominio}</span>
              </div>
            )}
            <div class="ficha-row">
              <span class="ficha-k">Afiliado</span>
              <span class="ficha-v">{herramienta.afiliado ? 'Disponible' : 'No'}</span>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ── CUERPO ─────────────────────────────────────── -->
  <div class="wrap" style="padding-top:48px; padding-bottom:80px;">

    <!-- Banner afiliado (solo si tiene programa) -->
    {herramienta.afiliado && (
      <div style="margin-bottom:48px;">
        <BannerAfiliado
          titulo={`Prueba ${herramienta.nombre}`}
          descripcion="Si este análisis te ha sido útil, considera usar el enlace de afiliado. Sin coste adicional para ti."
          cta={`Probar ${herramienta.nombre}`}
          url={herramienta.afiliado}
          badge="Enlace de afiliado"
        />
      </div>
    )}

    <!-- Artículos relacionados -->
    <section>
      <span class="sec-eyebrow">{articulosRelacionados.length} {articulosRelacionados.length === 1 ? 'análisis' : 'análisis'} publicados</span>
      <h2 class="sec-title">Artículos sobre {herramienta.nombre}</h2>

      {articulosRelacionados.length > 0 ? (
        <div class="arts-grid">
          {articulosRelacionados.map((a) => (
            <div class="reveal">
              <ArticuloCard
                title={a.data.title}
                description={a.data.description}
                date={a.data.date}
                category={a.data.category}
                slug={a.slug}
                imagen={a.data.imagen}
              />
            </div>
          ))}
        </div>
      ) : (
        <div class="arts-empty">
          <p>Aún no tenemos artículos específicos sobre {herramienta.nombre}. Vuelve pronto — estamos publicando nuevos análisis cada semana.</p>
          <a href="/blog">Ver todos los artículos →</a>
        </div>
      )}
    </section>

    <div style="margin-top:48px;">
      <a href="/herramientas" class="back-link">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Ver todas las herramientas
      </a>
    </div>
  </div>
</Layout>

<style>
  /* ── Hero ─────────────────────────────────────────── */
  .tool-hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }
  /* Glow de color de categoría */
  .tool-hero::before {
    content: '';
    position: absolute;
    top: -180px;
    right: -120px;
    width: 520px;
    height: 520px;
    background: radial-gradient(circle, color-mix(in srgb, var(--c) 26%, transparent), transparent 68%);
    filter: blur(20px);
    pointer-events: none;
    z-index: 0;
  }

  .tool-bc {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'Geist Mono', monospace;
    font-size: 12px;
    color: var(--ink3);
    margin-bottom: 28px;
  }
  .tool-bc a { color: var(--ink3); text-decoration: none; transition: color .15s; }
  .tool-bc a:hover { color: var(--c); }
  .tool-bc-current { color: var(--ink2); }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 280px;
    gap: 40px;
    align-items: start;
    padding-bottom: 44px;
  }

  .hero-id {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 22px;
  }
  .hero-logo {
    width: 64px;
    height: 64px;
    border-radius: 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    overflow: hidden;
    box-shadow: 0 6px 18px var(--shadow);
  }
  .hero-logo img { width: 100%; height: 100%; object-fit: contain; padding: 10px; }
  .hero-logo span { font-family: 'Newsreader', serif; font-weight: 600; font-size: 28px; color: var(--c); }

  .hero-cat {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--c);
    background: color-mix(in srgb, var(--c) 12%, transparent);
    padding: 6px 12px;
    border-radius: 99px;
  }

  .hero-title {
    margin: 0;
    font-family: 'Newsreader', serif;
    font-weight: 500;
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    line-height: 1.02;
    letter-spacing: -0.025em;
    color: var(--ink);
  }
  .hero-desc {
    margin: 18px 0 0;
    font-size: 18px;
    line-height: 1.6;
    color: var(--ink2);
    max-width: 560px;
  }

  .hero-cta-row {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 28px;
  }
  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--c);
    color: #fff;
    font-family: 'Geist', sans-serif;
    font-weight: 600;
    font-size: 15px;
    padding: 12px 22px;
    border-radius: 12px;
    text-decoration: none;
    transition: transform .15s, box-shadow .15s, filter .15s;
  }
  .hero-cta:hover {
    transform: translateY(-2px);
    filter: brightness(1.06);
    box-shadow: 0 12px 26px color-mix(in srgb, var(--c) 40%, transparent);
  }
  .hero-aff { font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--muted); }

  /* ── Ficha técnica ───────────────────────────────── */
  .hero-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 24px;
    box-shadow: 0 14px 36px var(--shadow);
  }
  .hero-card { border-top: 3px solid var(--c); }
  .ficha-score { display: flex; align-items: baseline; gap: 4px; }
  .ficha-num { font-family: 'Newsreader', serif; font-weight: 600; font-size: 44px; line-height: 1; color: var(--c); }
  .ficha-den { font-family: 'Geist Mono', monospace; font-size: 15px; color: var(--muted); }
  .ficha-stars { display: flex; gap: 2px; margin-top: 10px; }
  .star { color: var(--border2); }
  .star--on { color: #f5b301; }
  .ficha-score-label {
    display: block;
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink3);
    margin-top: 10px;
  }
  .ficha-rows {
    margin-top: 20px;
    padding-top: 18px;
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 13px;
  }
  .ficha-row { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
  .ficha-k { font-size: 13px; color: var(--ink3); }
  .ficha-v { font-size: 13px; font-weight: 600; color: var(--ink); text-align: right; }

  /* ── Sección artículos ───────────────────────────── */
  .sec-eyebrow {
    font-family: 'Geist Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink3);
  }
  .sec-title {
    margin: 10px 0 28px;
    font-family: 'Newsreader', serif;
    font-weight: 500;
    font-size: clamp(1.7rem, 3.5vw, 2.2rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .arts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 22px;
  }

  .arts-empty {
    background: var(--surface);
    border: 1px dashed var(--border2);
    border-radius: 16px;
    padding: 32px;
    text-align: center;
  }
  .arts-empty p { margin: 0; color: var(--ink2); font-size: 15px; line-height: 1.6; }
  .arts-empty a {
    display: inline-block;
    margin-top: 14px;
    color: var(--accent);
    font-weight: 600;
    font-size: 14px;
    text-decoration: none;
  }
  .arts-empty a:hover { text-decoration: underline; }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--ink3);
    text-decoration: none;
    transition: color .15s;
  }
  .back-link:hover { color: var(--accent); }

  /* ── Reveal ──────────────────────────────────────── */
  .reveal { opacity: 0; transform: translateY(22px); transition: opacity .6s ease, transform .6s ease; }
  .reveal.is-visible { opacity: 1; transform: none; }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 860px) {
    .hero-grid { grid-template-columns: 1fr; gap: 28px; }
    .hero-card { max-width: 420px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal { opacity: 1; transform: none; transition: none; }
    .hero-cta { transition: none; }
  }
</style>

<script>
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const items = document.querySelectorAll('.reveal');
    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          el.style.transitionDelay = `${(i % 3) * 80}ms`;
          el.classList.add('is-visible');
          io.unobserve(el);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
    items.forEach((el) => io.observe(el));
  } else {
    document.querySelectorAll('.reveal').forEach((el) => el.classList.add('is-visible'));
  }
</script>
