---
import Layout from '../../layouts/Layout.astro';
import { CATEGORIA_LABELS, CATEGORIAS } from '../../content/config';
import type { Categoria } from '../../content/config';
import { herramientas } from '../../data/herramientas';
import { tagMatchesTool } from '../../data/hubMatching';
import { getCollection } from 'astro:content';

// Mismo criterio que getStaticPaths de [slug].astro: solo tienen hub las herramientas
// con al menos un artículo publicado. Las demás enlazan a su web oficial.
const articulos = await getCollection('blog', ({ data }) => !data.draft);
const conHub = new Set(
  herramientas
    .filter((h) => articulos.some((a) => a.data.herramientas.some((t) => tagMatchesTool(t, h.nombre))))
    .map((h) => h.slug)
);
---

<Layout
  title="Directorio de herramientas IA — IA en Español"
  description="El catálogo completo de herramientas de IA que hemos probado, con su nota y enlace a la review o a su web oficial. Filtra por categoría."
>
  <!-- Cabecera -->
  <section class="wrap" style="padding-top:64px;">
    <span style="font-family:'Geist Mono',monospace; font-size:12px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink3);">{herramientas.length} herramientas analizadas</span>
    <h1 style="margin:10px 0 0; font-family:'Newsreader',serif; font-weight:500; font-size:clamp(2.5rem,5vw,3.375rem); line-height:1.02; letter-spacing:-0.025em; color:var(--ink);">Herramientas</h1>
    <p style="margin:18px 0 0; font-size:19px; line-height:1.55; color:var(--ink2); max-width:560px;">El catálogo completo de herramientas que hemos probado, con su nota y enlace a la review o a su web oficial. Filtra por categoría.</p>

    <!-- Filtros -->
    <div style="display:flex; flex-wrap:wrap; gap:9px; margin-top:36px;" role="group" aria-label="Filtrar por categoría">
      <button
        data-cat=""
        class="filter-btn"
        style="padding:9px 16px; border-radius:99px; border:1px solid var(--ink); background:var(--ink); color:var(--bg); font-size:14px; font-weight:600; cursor:pointer; font-family:'Geist',sans-serif;"
      >Todas</button>
      {CATEGORIAS.map((slug: Categoria) => (
        <button
          data-cat={slug}
          class="filter-btn"
          style="padding:9px 16px; border-radius:99px; border:1px solid var(--border2); background:var(--surface); color:var(--ink2); font-size:14px; font-weight:500; cursor:pointer; font-family:'Geist',sans-serif; transition:all .15s;"
        >{CATEGORIA_LABELS[slug]}</button>
      ))}
    </div>
  </section>

  <!-- Grid -->
  <section class="wrap" style="padding-top:36px; padding-bottom:80px;">
    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:18px;">
      {herramientas.map(h => { const tieneHub = conHub.has(h.slug); return (
        <a
          href={tieneHub ? `/herramientas/${h.slug}` : h.url}
          target={tieneHub ? undefined : '_blank'}
          rel={tieneHub ? undefined : (h.afiliado ? 'sponsored noopener noreferrer' : 'noopener noreferrer')}
          style="display:block; text-decoration:none;"
          class="herramienta-item"
          data-category={h.categoria}
        >
          <article style="background:var(--surface); border:1px solid var(--border); border-radius:16px; padding:22px; height:100%; transition:all .2s; display:flex; flex-direction:column;" class="tool-card">
            <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:12px; margin-bottom:16px;">
              {h.logo ? (
                <img
                  src={h.logo}
                  alt={h.nombre}
                  width="46"
                  height="46"
                  style="width:46px; height:46px; border-radius:12px; object-fit:contain; border:1px solid var(--border); background:var(--surface); padding:6px; flex-shrink:0;"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div style="width:46px; height:46px; border-radius:12px; background-image:repeating-linear-gradient(135deg,var(--stripe-a),var(--stripe-a) 6px,var(--stripe-b) 6px,var(--stripe-b) 12px); border:1px solid var(--border); flex-shrink:0;" aria-hidden="true"></div>
              )}
              <span style="font-family:'Newsreader',serif; font-size:20px; font-weight:600; color:var(--accent); flex-shrink:0;">{(h.rating * 2).toFixed(1)}</span>
            </div>
            <h3 style="margin:0; font-size:17px; font-weight:600; color:var(--ink);">{h.nombre}</h3>
            <span style="font-family:'Geist Mono',monospace; font-size:11px; color:var(--muted); margin-top:4px;">{CATEGORIA_LABELS[h.categoria]}</span>
            <p style="margin:12px 0 0; font-size:14px; line-height:1.5; color:var(--ink3); flex:1;">{h.descripcion}</p>
            <span style="display:inline-flex; align-items:center; gap:6px; margin-top:16px; font-size:13px; font-weight:600; color:var(--ink);">
              {tieneHub ? 'Ver review' : 'Visitar web'} <span style="color:var(--accent);">{tieneHub ? '→' : '↗'}</span>
            </span>
          </article>
        </a>
      ); })}
    </div>
  </section>
</Layout>

<style>
  .tool-card:hover {
    box-shadow: 0 14px 32px var(--shadow);
    transform: translateY(-3px);
  }


</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items = document.querySelectorAll<HTMLElement>('.herramienta-item');

  function setActive(btn: HTMLButtonElement) {
    btn.style.background = 'var(--ink)';
    btn.style.color = 'var(--bg)';
    btn.style.borderColor = 'var(--ink)';
    btn.style.fontWeight = '600';
  }

  function setInactive(btn: HTMLButtonElement) {
    btn.style.background = 'var(--surface)';
    btn.style.color = 'var(--ink2)';
    btn.style.borderColor = 'var(--border2)';
    btn.style.fontWeight = '500';
  }

  function setFilter(cat: string) {
    buttons.forEach(btn => (btn.dataset.cat === cat ? setActive(btn) : setInactive(btn)));
    items.forEach(item => {
      item.style.display = !cat || item.dataset.category === cat ? '' : 'none';
    });
  }

  const initialCat = new URLSearchParams(window.location.search).get('cat') ?? '';
  setFilter(initialCat);

  buttons.forEach(btn => btn.addEventListener('click', () => setFilter(btn.dataset.cat ?? '')));
</script>
