---
import Layout from '../../layouts/Layout.astro';
import TarjetaHerramienta from '../../components/TarjetaHerramienta.astro';
import { CATEGORIA_LABELS } from '../../content/config';
import type { Categoria } from '../../content/config';
import { herramientas } from '../../data/herramientas';

const categorias = [
  { slug: '' as const, label: 'Todas' },
  ...Object.entries(CATEGORIA_LABELS).map(([slug, label]) => ({ slug: slug as Categoria, label })),
];
---

<Layout
  title="Directorio de herramientas IA"
  description="Directorio completo de las mejores herramientas de inteligencia artificial con ratings, categorías y enlaces directos."
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">Herramientas</h1>
    <p class="text-gray-600 dark:text-gray-400 mb-8">
      {herramientas.length} herramientas analizadas y clasificadas por categoría.
    </p>

    <!-- Filtros -->
    <div class="flex flex-wrap gap-2 mb-8" role="group" aria-label="Filtrar herramientas por categoría">
      {categorias.map(({ slug, label }, i) => (
        <button
          data-cat={slug}
          class:list={[
            'filter-btn px-4 py-2 rounded-full text-sm font-semibold transition-colors',
            i === 0
              ? 'bg-[#7C3AED] text-white'
              : 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-[#7C3AED] hover:text-white',
          ]}
        >
          {label}
        </button>
      ))}
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5" id="herramientas-grid">
      {herramientas.map((h) => (
        <div data-category={h.categoria} class="herramienta-item">
          <TarjetaHerramienta
            nombre={h.nombre}
            descripcion={h.descripcion}
            categoria={h.categoria}
            rating={h.rating}
            logo={h.logo}
            url={h.url}
            hubUrl={`/herramientas/${h.slug}`}
          />
        </div>
      ))}
    </div>
  </div>
</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items = document.querySelectorAll<HTMLElement>('.herramienta-item');

  const activeClasses = ['bg-[#7C3AED]', 'text-white'];
  const inactiveClasses = ['bg-gray-100', 'dark:bg-gray-800', 'text-gray-700', 'dark:text-gray-300'];

  function setFilter(cat: string) {
    buttons.forEach((btn) => {
      const isActive = btn.dataset.cat === cat;
      activeClasses.forEach((c) => btn.classList.toggle(c, isActive));
      inactiveClasses.forEach((c) => btn.classList.toggle(c, !isActive));
    });
    items.forEach((item) => {
      item.style.display = !cat || item.dataset.category === cat ? '' : 'none';
    });
  }

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => setFilter(btn.dataset.cat ?? ''));
  });
</script>
