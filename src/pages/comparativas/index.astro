---
import Layout from '../../layouts/Layout.astro';
import TablaComparativa from '../../components/TablaComparativa.astro';
import { getCollection } from 'astro:content';

const allArticles = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const articulosPorCategoria = {
  llm:           allArticles.filter(a => a.data.category === 'generacion-texto').slice(0, 3),
  imagen:        allArticles.filter(a => a.data.category === 'generacion-imagen').slice(0, 3),
  codigo:        allArticles.filter(a => a.data.category === 'codigo').slice(0, 3),
  audio:         allArticles.filter(a => a.data.category === 'audio').slice(0, 3),
  video:         allArticles.filter(a => a.data.category === 'video').slice(0, 3),
  productividad: allArticles.filter(a => a.data.category === 'productividad').slice(0, 3),
};

const catMeta: Record<string, { color: string; label: string; icon: string }> = {
  llm:           { color: '#7C3AED', label: 'Texto',          icon: '<path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>' },
  imagen:        { color: '#2563EB', label: 'Imagen',         icon: '<rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>' },
  codigo:        { color: '#16A34A', label: 'Código',         icon: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>' },
  audio:         { color: '#EA580C', label: 'Audio',          icon: '<line x1="12" y1="5" x2="12" y2="19"/><line x1="8" y1="7" x2="8" y2="17"/><line x1="4" y1="9" x2="4" y2="15"/><line x1="16" y1="7" x2="16" y2="17"/><line x1="20" y1="9" x2="20" y2="15"/>' },
  video:         { color: '#DC2626', label: 'Vídeo',          icon: '<polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/>' },
  productividad: { color: '#0D9488', label: 'Productividad',  icon: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>' },
};

const comparativas = [
  {
    id: 'llm',
    titulo: 'Mejores IAs de texto en 2026',
    descripcion: 'Los asistentes y modelos de lenguaje más potentes del mercado, actualizados a julio de 2026.',
    herramientas: [
      { nombre: 'Claude Fable 5', precio: '$20/mes (Pro)', puntuacion: 4.8, idealPara: 'Programación, razonamiento, documentos largos', badge: 'Recomendado' },
      { nombre: 'ChatGPT (GPT-5.5)', precio: '$20/mes (Plus)', puntuacion: 4.7, idealPara: 'Uso general, memoria en tiempo real, plugins', badge: 'Más popular' },
      { nombre: 'Google AI Pro', precio: '$19,99/mes', puntuacion: 4.5, idealPara: 'Integración con Gmail, Docs y Google Workspace' },
      { nombre: 'Jasper', precio: '$39/mes', puntuacion: 4.4, idealPara: 'Redacción de marketing y contenido', enlaceAfiliado: 'https://www.jasper.ai' },
      { nombre: 'Writesonic', precio: '$16/mes', puntuacion: 4.2, idealPara: 'Copywriting y artículos SEO', enlaceAfiliado: 'https://writesonic.com?fp_ref=sergio20', badge: 'Mejor precio' },
      { nombre: 'NeuronWriter', precio: '$19/mes', puntuacion: 4.3, idealPara: 'Optimización SEO con IA, análisis de competidores SERP', enlaceAfiliado: 'https://app.neuronwriter.com/ar/6809702873b807e3a94ed0c0661d7298' },
    ],
  },
  {
    id: 'imagen',
    titulo: 'Mejores generadores de imagen IA',
    descripcion: 'Comparativa de las herramientas de generación de imagen más populares en 2026.',
    herramientas: [
      { nombre: 'Midjourney v8.1', precio: '$10–$60/mes', puntuacion: 4.9, idealPara: 'Arte, calidad máxima, consistencia de personajes', badge: 'Recomendado' },
      { nombre: 'Flux', precio: 'Gratis (local)', puntuacion: 4.6, idealPara: 'Open source sin costes, calidad comparable a MJ', badge: 'Gratis' },
      { nombre: 'Nano Banana 2', precio: 'Gratis / Google AI Pro', puntuacion: 4.5, idealPara: 'Edición conversacional, texto legible; versión Lite más rápida y barata' },
      { nombre: 'Leonardo.ai', precio: 'Freemium', puntuacion: 4.5, idealPara: 'Concept art, videojuegos, plan gratuito generoso', enlaceAfiliado: 'https://leonardo.ai' },
      { nombre: 'Adobe Firefly', precio: 'Con Creative Cloud', puntuacion: 4.4, idealPara: 'Uso comercial 100% seguro, integrado en Photoshop', enlaceAfiliado: 'https://www.adobe.com/es/products/firefly.html' },
    ],
  },
  {
    id: 'codigo',
    titulo: 'Asistentes de programación IA',
    descripcion: 'Las mejores herramientas para escribir, entender y refactorizar código en 2026.',
    herramientas: [
      { nombre: 'Cursor', precio: '$20/mes', puntuacion: 4.8, idealPara: 'IDE completo con IA, ediciones multi-fichero', badge: 'Recomendado' },
      { nombre: 'Windsurf', precio: '$20/mes (Pro)', puntuacion: 4.6, idealPara: 'IDE con IA, comprensión del contexto completo' },
      { nombre: 'Claude Code', precio: 'Incluido en Claude Pro ($20/mes)', puntuacion: 4.3, idealPara: 'Agente de código en terminal, tareas autónomas multi-fichero' },
      { nombre: 'GitHub Copilot', precio: 'Desde $10/mes*', puntuacion: 4.5, idealPara: 'Plugin en tu IDE actual, estándar en empresas' },
      { nombre: 'Codeium', precio: 'Gratis', puntuacion: 4.2, idealPara: 'Alternativa gratuita a Copilot', badge: 'Gratis' },
    ],
  },
  {
    id: 'audio',
    titulo: 'Herramientas de voz y audio IA',
    descripcion: 'Síntesis de voz, clonación y generación de música con inteligencia artificial.',
    herramientas: [
      { nombre: 'ElevenLabs', precio: '$5–$99/mes', puntuacion: 4.8, idealPara: 'Voz + clonación + Music v2 con efectos de sonido', enlaceAfiliado: 'https://try.elevenlabs.io/5pqit62qinao', badge: 'Recomendado' },
      { nombre: 'Murf.ai', precio: '$19/mes', puntuacion: 4.5, idealPara: 'Voiceover profesional para vídeos y presentaciones', enlaceAfiliado: 'https://murf.ai' },
      { nombre: 'Suno', precio: 'Gratis / Pro $10/mes', puntuacion: 4.5, idealPara: 'Música completa desde texto, hasta 4 minutos' },
      { nombre: 'Adobe Podcast', precio: 'Gratis', puntuacion: 4.2, idealPara: 'Mejora automática de calidad de voz y audio', badge: 'Gratis' },
    ],
  },
  {
    id: 'video',
    titulo: 'Mejores generadores de vídeo IA',
    descripcion: 'Herramientas de generación y edición de vídeo con inteligencia artificial en 2026.',
    herramientas: [
      { nombre: 'RunwayML', precio: 'Desde $15/mes', puntuacion: 4.6, idealPara: 'Suite profesional, control de cámara, acceso a Veo integrado', badge: 'Recomendado' },
      { nombre: 'Google Veo 3', precio: 'Con Google AI Pro ($19,99/mes)', puntuacion: 4.6, idealPara: 'Vídeo con audio y diálogos integrados, calidad cinematográfica' },
      { nombre: 'Kling 3.0', precio: 'Gratis / Pro $8/mes', puntuacion: 4.5, idealPara: 'Mejor relación calidad-precio, secuencias multi-plano con audio', badge: 'Mejor precio' },
      { nombre: 'HeyGen', precio: 'Desde $29/mes', puntuacion: 4.5, idealPara: 'Avatares IA, doblaje automático, vídeos corporativos' },
      { nombre: 'Midjourney Video V1', precio: 'Desde $10/mes', puntuacion: 4.3, idealPara: 'Animar tus imágenes de Midjourney en clips de 5s a coste mínimo' },
    ],
  },
  {
    id: 'productividad',
    titulo: 'Herramientas de productividad con IA',
    descripcion: 'Las mejores IAs para organizar tu trabajo, investigar más rápido y automatizar tareas repetitivas.',
    herramientas: [
      { nombre: 'NotebookLM', precio: 'Gratis / Plus $19,99/mes', puntuacion: 4.7, idealPara: 'Investigación, análisis de documentos, podcasts IA', badge: 'Gratis' },
      { nombre: 'Notion AI', precio: '$10/mes (Plus)', puntuacion: 4.5, idealPara: 'Organización, notas, bases de datos con IA', badge: 'Recomendado' },
      { nombre: 'Perplexity AI', precio: 'Gratis / Pro $20/mes', puntuacion: 4.5, idealPara: 'Búsqueda web con fuentes verificadas, síntesis' },
      { nombre: 'Otter.ai', precio: 'Desde $10/mes', puntuacion: 4.2, idealPara: 'Transcripción automática de reuniones y resúmenes' },
    ],
  },
];

const totalHerramientas = comparativas.reduce((sum, c) => sum + c.herramientas.length, 0);
---

<Layout
  title="Comparativas de herramientas IA 2026 — Tablas actualizadas"
  description="Compara las mejores herramientas de inteligencia artificial por categoría. Tablas actualizadas a julio de 2026 con precios, puntuaciones y comparador interactivo."
>

  <!-- ══ HERO ══════════════════════════════════════════ -->
  <section class="comp-hero">
    <div class="wrap" style="padding-top:72px; padding-bottom:64px;">

      <div style="display:inline-flex; align-items:center; gap:8px; margin-bottom:22px;">
        <span style="width:7px; height:7px; border-radius:50%; background:var(--accent); flex-shrink:0;"></span>
        <span style="font-family:'Geist Mono',monospace; font-size:12px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink2);">Comparativas · Julio 2026</span>
      </div>

      <h1 style="margin:0; font-family:'Newsreader',serif; font-weight:500; font-size:clamp(2.2rem,5vw,3.5rem); line-height:1.05; letter-spacing:-0.025em; color:var(--ink);">
        Compara las mejores<br>
        <span style="font-style:italic; color:var(--accent);">herramientas de IA</span>
      </h1>

      <p style="margin:22px 0 0; font-size:18px; line-height:1.6; color:var(--ink2); max-width:540px;">
        Tablas actualizadas sin opinión de marca. Selecciona hasta 3 herramientas y compáralas lado a lado en segundos.
      </p>

      <!-- Stats strip -->
      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat-n">{totalHerramientas}</span>
          <span class="hero-stat-l">herramientas</span>
        </div>
        <div class="hero-stat-sep"></div>
        <div class="hero-stat">
          <span class="hero-stat-n">{comparativas.length}</span>
          <span class="hero-stat-l">categorías</span>
        </div>
        <div class="hero-stat-sep"></div>
        <div class="hero-stat">
          <span class="hero-stat-n">{allArticles.length}</span>
          <span class="hero-stat-l">reviews publicadas</span>
        </div>
      </div>

    </div>
  </section>

  <!-- ══ CATEGORY NAV ══════════════════════════════════ -->
  <nav class="cat-nav" aria-label="Saltar a categoría">
    <div class="wrap" style="padding-top:36px; padding-bottom:36px;">
      <div class="cat-grid">
        {comparativas.map(({ id, titulo, herramientas: h }) => {
          const m = catMeta[id];
          return (
            <a href={`#${id}`} class="cat-card" style={`--c:${m.color};`}>
              <span class="cat-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={m.icon} />
              </span>
              <span class="cat-name">{m.label}</span>
              <span class="cat-count">{h.length} herramientas</span>
            </a>
          );
        })}
      </div>
    </div>
  </nav>

  <!-- ══ MAIN CONTENT ══════════════════════════════════ -->
  <div class="wrap" style="padding-bottom:80px;">

    <!-- Hint comparador -->
    <div class="cmp-hint">
      <svg style="width:15px; height:15px; flex-shrink:0; margin-top:1px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path stroke-linecap="round" d="M12 8h.01M12 12v4"/></svg>
      <span>Pulsa <strong style="background:var(--accent); color:#fff; padding:1px 7px; border-radius:12px; font-size:13px; font-weight:700; margin:0 2px;">+</strong> en hasta 3 herramientas para compararlas lado a lado.</span>
    </div>

    <!-- Sections -->
    <div class="comp-sections">
      {comparativas.map(({ id, titulo, descripcion, herramientas }) => {
        const m = catMeta[id];
        const articulos = articulosPorCategoria[id as keyof typeof articulosPorCategoria] ?? [];
        return (
          <section id={id} class="comp-section" style={`--c:${m.color};`}>

            <!-- Section header -->
            <div class="comp-section-head">
              <span class="comp-cat-badge">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={m.icon} />
                {m.label}
              </span>
              <h2 class="comp-section-title">{titulo}</h2>
              <p class="comp-section-desc">{descripcion}</p>
              <span class="comp-section-meta">
                {herramientas.length} herramientas · Actualizado julio 2026
              </span>
            </div>

            <TablaComparativa herramientas={herramientas} comparador={true} />

            {articulos.length > 0 && (
              <div class="comp-articles">
                <p class="comp-articles-label">Artículos relacionados</p>
                <div class="comp-articles-grid">
                  {articulos.map(a => (
                    <a href={`/blog/${a.slug}`} class="comp-article-card" style={`--c:${m.color};`}>
                      <span class="comp-article-title">{a.data.title}</span>
                      <span class="comp-article-cta">Leer artículo →</span>
                    </a>
                  ))}
                </div>
              </div>
            )}

          </section>
        );
      })}
    </div>

    <!-- Nota legal -->
    <p style="margin-top:16px; font-size:12px; color:var(--muted); max-width:680px;">
      *GitHub Copilot migró a facturación por créditos AI en junio 2026; el coste real puede variar según uso. Los enlaces marcados como afiliados generan una comisión sin coste adicional para ti.
    </p>

  </div>

  <!-- ══ COMPARE TRAY ══════════════════════════════════ -->
  <div id="cmp-tray" role="status" aria-live="polite">
    <div class="wrap" style="padding-top:14px; padding-bottom:14px;">
      <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap;">
        <span style="font-size:13px; font-weight:600; color:var(--ink); white-space:nowrap; flex-shrink:0;">Comparando:</span>
        <span id="cmp-count" style="font-size:13px; color:var(--ink2); white-space:nowrap;"></span>
        <div id="cmp-pills" style="display:flex; gap:8px; flex:1; flex-wrap:nowrap; overflow-x:auto; min-width:0;"></div>
        <div style="display:flex; align-items:center; gap:12px; flex-shrink:0; margin-left:auto;">
          <button id="cmp-clear" style="font-size:13px; color:var(--ink3); background:none; border:none; cursor:pointer; padding:0; text-decoration:underline; font-family:'Geist',sans-serif; white-space:nowrap;">Limpiar</button>
          <button id="cmp-go" disabled style="display:inline-flex; align-items:center; gap:6px; background:var(--accent); color:#fff; border:none; cursor:pointer; padding:10px 18px; border-radius:10px; font-size:14px; font-weight:600; font-family:'Geist',sans-serif; transition:opacity .18s; white-space:nowrap;">
            Comparar
            <svg style="width:14px;height:14px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- ══ COMPARE MODAL ═════════════════════════════════ -->
  <div id="cmp-overlay" role="dialog" aria-modal="true" aria-labelledby="cmp-modal-title">
    <div id="cmp-modal">
      <div style="padding:20px 24px; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; gap:16px; flex-shrink:0;">
        <h2 id="cmp-modal-title" style="margin:0; font-size:18px; font-weight:700; color:var(--ink); font-family:'Newsreader',serif;">Comparativa</h2>
        <button id="cmp-close" aria-label="Cerrar comparación" style="background:none; border:none; cursor:pointer; color:var(--ink3); font-size:28px; line-height:1; padding:4px; flex-shrink:0;">×</button>
      </div>
      <div id="cmp-table-wrap"></div>
      <div style="padding:14px 24px; border-top:1px solid var(--border); text-align:right; flex-shrink:0;">
        <button id="cmp-modal-clear" style="font-size:13px; color:var(--ink3); background:none; border:none; cursor:pointer; text-decoration:underline; font-family:'Geist',sans-serif;">Limpiar comparación</button>
      </div>
    </div>
  </div>

</Layout>

<style>
  /* ── Hero ─────────────────────────────────────── */
  .comp-hero {
    border-bottom: 1px solid var(--border);
  }
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-top: 36px;
    flex-wrap: wrap;
  }
  .hero-stat { display: flex; flex-direction: column; gap: 2px; }
  .hero-stat-n {
    font-family: 'Newsreader', serif;
    font-size: 2rem;
    font-weight: 500;
    line-height: 1;
    color: var(--accent);
    letter-spacing: -0.02em;
  }
  .hero-stat-l {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink3);
  }
  .hero-stat-sep {
    width: 1px;
    height: 36px;
    background: var(--border2);
    flex-shrink: 0;
  }

  /* ── Category nav ─────────────────────────────── */
  .cat-nav {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
  }
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    gap: 12px;
  }
  .cat-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 9px;
    padding: 20px 12px;
    border-radius: 14px;
    border: 1px solid var(--border);
    background: var(--bg);
    text-decoration: none;
    text-align: center;
    transition: border-color .18s, box-shadow .18s, transform .18s;
  }
  .cat-card:hover {
    border-color: var(--c);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--c) 12%, transparent), 0 4px 16px var(--shadow);
    transform: translateY(-2px);
  }
  .cat-icon-wrap {
    width: 40px; height: 40px;
    border-radius: 12px;
    background: color-mix(in srgb, var(--c) 12%, transparent);
    color: var(--c);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background .18s;
  }
  .cat-card:hover .cat-icon-wrap {
    background: color-mix(in srgb, var(--c) 20%, transparent);
  }
  .cat-name {
    font-size: 13px;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.2;
  }
  .cat-count {
    font-family: 'Geist Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
  }

  /* ── Hint comparador ──────────────────────────── */
  .cmp-hint {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 11px 15px;
    border-radius: 10px;
    background: var(--accent-tint);
    border: 1px solid var(--accent);
    margin: 36px 0 0;
    font-size: 13px;
    color: var(--accent);
  }

  /* ── Sections ─────────────────────────────────── */
  .comp-sections { display: flex; flex-direction: column; gap: 0; }

  .comp-section {
    padding: 56px 0 0;
    scroll-margin-top: 80px;
  }
  .comp-section + .comp-section {
    border-top: 1px solid var(--border);
  }

  .comp-section-head {
    padding-left: 20px;
    border-left: 3px solid var(--c);
    margin-bottom: 8px;
  }
  .comp-cat-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    border-radius: 20px;
    background: color-mix(in srgb, var(--c) 12%, transparent);
    color: var(--c);
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 12px;
  }
  .comp-section-title {
    margin: 0;
    font-family: 'Newsreader', serif;
    font-weight: 500;
    font-size: clamp(1.5rem, 3vw, 2rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .comp-section-desc {
    margin: 10px 0 0;
    font-size: 15px;
    line-height: 1.55;
    color: var(--ink2);
    max-width: 580px;
  }
  .comp-section-meta {
    display: inline-block;
    margin-top: 10px;
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
  }

  /* ── Related articles ─────────────────────────── */
  .comp-articles { margin-top: 24px; }
  .comp-articles-label {
    margin: 0 0 12px;
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink3);
  }
  .comp-articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 10px;
  }
  .comp-article-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 14px 16px;
    border-radius: 10px;
    border: 1px solid var(--border);
    border-top: 3px solid var(--c);
    background: var(--surface);
    text-decoration: none;
    transition: box-shadow .18s, transform .18s;
  }
  .comp-article-card:hover {
    box-shadow: 0 4px 16px var(--shadow);
    transform: translateY(-2px);
  }
  .comp-article-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.35;
  }
  .comp-article-cta {
    font-size: 12px;
    color: var(--c);
    font-weight: 600;
  }

  /* ── Compare tray ─────────────────────────────── */
  #cmp-tray {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    z-index: 200;
    background: var(--surface);
    border-top: 1px solid var(--border);
    box-shadow: 0 -4px 24px var(--shadow);
    transform: translateY(100%);
    transition: transform .28s cubic-bezier(.22,1,.36,1);
  }

  /* ── Compare modal ────────────────────────────── */
  #cmp-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 300;
    background: rgba(0,0,0,.55);
    align-items: center;
    justify-content: center;
    padding: 20px;
    backdrop-filter: blur(3px);
  }
  #cmp-overlay.open { display: flex; }
  #cmp-modal {
    background: var(--surface);
    border-radius: 16px;
    width: 100%;
    max-width: 860px;
    max-height: 90vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 24px 60px rgba(0,0,0,.3);
  }
  #cmp-table-wrap { overflow: auto; flex: 1; }
  #cmp-go:disabled { opacity: 0.4; cursor: not-allowed; }

  /* móvil: contador en vez de pills */
  #cmp-count { display: none; }
  @media (max-width: 640px) {
    #cmp-pills  { display: none !important; }
    #cmp-count  { display: inline; }
  }
</style>

<script>
  interface Tool {
    nombre: string;
    precio: string;
    puntuacion: number;
    idealPara: string;
    enlaceAfiliado: string | null;
    badge: string | null;
  }

  let selected: Tool[] = [];

  // Pulso inicial: primer botón de cada sección
  document.querySelectorAll<HTMLElement>('section[id]').forEach((section, i) => {
    const btn = section.querySelector<HTMLElement>('.cmp-btn');
    if (btn) setTimeout(() => btn.classList.add('cmp-pulse'), i * 150);
  });
  setTimeout(() => {
    document.querySelectorAll<HTMLElement>('.cmp-pulse').forEach(b => b.classList.remove('cmp-pulse'));
  }, 4500);

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;

    const cmpBtn = target.closest<HTMLButtonElement>('.cmp-btn');
    if (cmpBtn?.dataset.tool) {
      const tool = JSON.parse(cmpBtn.dataset.tool) as Tool;
      const idx = selected.findIndex(t => t.nombre === tool.nombre);
      if (idx > -1) {
        selected.splice(idx, 1);
      } else {
        if (selected.length >= 3) return;
        selected.push(tool);
      }
      syncButtons();
      renderTray();
      return;
    }

    const pill = target.closest<HTMLElement>('[data-remove]');
    if (pill?.dataset.remove) {
      const nombre = pill.dataset.remove;
      selected = selected.filter(t => t.nombre !== nombre);
      syncButtons();
      renderTray();
      return;
    }

    if (target.closest('#cmp-go') && !(document.getElementById('cmp-go') as HTMLButtonElement).disabled) {
      openModal(); return;
    }
    if (target.closest('#cmp-clear'))       { clearAll(); return; }
    if (target.closest('#cmp-close'))       { closeModal(); return; }
    if (target.closest('#cmp-modal-clear')) { clearAll(); closeModal(); return; }
    if (target === document.getElementById('cmp-overlay')) { closeModal(); return; }
  });

  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

  function syncButtons() {
    document.querySelectorAll<HTMLButtonElement>('.cmp-btn').forEach(b => {
      if (!b.dataset.tool) return;
      const tool = JSON.parse(b.dataset.tool) as Tool;
      const isSel = selected.some(t => t.nombre === tool.nombre);
      const isFull = selected.length >= 3 && !isSel;
      b.classList.toggle('is-sel', isSel);
      b.disabled = isFull;
    });
  }

  function renderTray() {
    const tray = document.getElementById('cmp-tray')!;
    const pillsEl = document.getElementById('cmp-pills')!;
    const goBtn = document.getElementById('cmp-go') as HTMLButtonElement;

    tray.style.transform = selected.length ? 'translateY(0)' : 'translateY(100%)';
    goBtn.disabled = selected.length < 2;

    const countEl = document.getElementById('cmp-count');
    if (countEl) countEl.textContent = `${selected.length} herramienta${selected.length !== 1 ? 's' : ''} seleccionada${selected.length !== 1 ? 's' : ''}`;

    pillsEl.innerHTML = selected.map(t => `
      <span style="display:inline-flex;align-items:center;gap:5px;padding:5px 10px;border-radius:20px;background:var(--accent-tint);border:1px solid var(--accent);font-size:12px;font-weight:600;color:var(--accent);font-family:'Geist',sans-serif;white-space:nowrap;flex-shrink:0;">
        ${esc(t.nombre)}
        <button data-remove="${esc(t.nombre)}" style="background:none;border:none;cursor:pointer;color:var(--accent);font-size:16px;line-height:1;padding:0;flex-shrink:0;" aria-label="Quitar ${esc(t.nombre)}">×</button>
      </span>
    `).join('');
  }

  function clearAll() {
    selected = [];
    document.querySelectorAll<HTMLButtonElement>('.cmp-btn').forEach(b => {
      b.classList.remove('is-sel');
      b.disabled = false;
    });
    renderTray();
  }

  function openModal() {
    const overlay = document.getElementById('cmp-overlay')!;
    const wrap = document.getElementById('cmp-table-wrap')!;
    const title = document.getElementById('cmp-modal-title')!;

    title.textContent = `Comparando ${selected.length} herramientas`;

    const thCols = selected.map(t => `
      <th style="padding:16px 18px;text-align:center;font-size:14px;font-weight:700;color:var(--ink);border-left:1px solid var(--border);min-width:160px;">
        ${esc(t.nombre)}
        ${t.badge ? `<br><span style="display:inline-block;margin-top:5px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;padding:2px 7px;border-radius:4px;background:${/gratis|precio/i.test(t.badge)?'var(--good-bg)':'var(--accent-tint)'};color:${/gratis|precio/i.test(t.badge)?'var(--good)':'var(--accent)'};">${esc(t.badge)}</span>` : ''}
      </th>
    `).join('');

    const rows: { label: string; render: (t: Tool) => string }[] = [
      { label: 'Puntuación', render: t => stars(t.puntuacion) },
      { label: 'Precio',     render: t => `<span style="color:var(--ink2);">${esc(t.precio)}</span>` },
      { label: 'Ideal para', render: t => `<span style="font-size:13px;color:var(--ink2);">${esc(t.idealPara)}</span>` },
      { label: 'Enlace',     render: t => t.enlaceAfiliado
        ? `<a href="${esc(t.enlaceAfiliado)}" target="_blank" rel="noopener noreferrer sponsored" style="color:var(--accent);font-weight:600;font-size:13px;">Ver oferta →</a>`
        : `<span style="color:var(--muted)">—</span>` },
    ];

    const bodyRows = rows.map(row => `
      <tr style="border-top:1px solid var(--border);">
        <td style="padding:14px 18px;font-size:13px;font-weight:600;color:var(--ink3);white-space:nowrap;">${row.label}</td>
        ${selected.map(t => `<td style="padding:14px 18px;text-align:center;border-left:1px solid var(--border);">${row.render(t)}</td>`).join('')}
      </tr>
    `).join('');

    wrap.innerHTML = `
      <table style="width:100%;border-collapse:collapse;font-size:14px;">
        <thead>
          <tr style="background:var(--surface);">
            <th style="padding:16px 18px;text-align:left;font-size:11px;font-weight:600;color:var(--ink3);text-transform:uppercase;letter-spacing:.1em;white-space:nowrap;">Característica</th>
            ${thCols}
          </tr>
        </thead>
        <tbody>${bodyRows}</tbody>
      </table>
    `;

    overlay.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    document.getElementById('cmp-overlay')?.classList.remove('open');
    document.body.style.overflow = '';
  }

  function stars(score: number) {
    const s = Array.from({ length: 5 }, (_, i) =>
      `<svg style="width:15px;height:15px;color:${i < Math.round(score) ? '#fbbf24' : 'var(--border2)'};display:inline-block;" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>`
    ).join('');
    return `<span style="display:inline-flex;align-items:center;gap:2px;">${s}<span style="font-size:12px;color:var(--muted);margin-left:5px;font-family:'Geist Mono',monospace;">${score}</span></span>`;
  }

  function esc(str: string) {
    return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
</script>
