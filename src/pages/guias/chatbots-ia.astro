<script>
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          obs.unobserve(e.target);
        }
      });
    }, { rootMargin: '0px 0px -48px 0px', threshold: 0.06 });

    // Staggered grid items
    [
      { sel: '.bots-grid > *', mod: 2 },
      { sel: '.uses-grid > *', mod: 2 },
      { sel: '.arts-grid > *', mod: 3 },
    ].forEach(({ sel, mod }) => {
      document.querySelectorAll(sel).forEach((el, i) => {
        el.classList.add('reveal');
        el.style.transitionDelay = `${(i % mod) * 0.08}s`;
        obs.observe(el);
      });
    });

    // FAQs stagger
    document.querySelectorAll('.faq').forEach((el, i) => {
      el.classList.add('reveal');
      el.style.transitionDelay = `${Math.min(i, 4) * 0.07}s`;
      obs.observe(el);
    });

    // Timeline stagger
    document.querySelectorAll('.tl-item').forEach((el, i) => {
      el.classList.add('reveal');
      el.style.transitionDelay = `${i * 0.07}s`;
      obs.observe(el);
    });

    // Single elements
    document.querySelectorAll('.toc-box').forEach(el => {
      el.classList.add('reveal');
      obs.observe(el);
    });
  }
</script>
