---
import Layout from '../layouts/Layout.astro';

const siteUrl = 'https://iaenespanol.es';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Sergio',
  url: siteUrl,
  image: `${siteUrl}/images/sergio.jpg`,
  description: 'Analista de herramientas de inteligencia artificial y autor de IA en Español, blog de reviews y comparativas de IA en castellano.',
  jobTitle: 'Analista de herramientas IA',
  knowsAbout: [
    'Inteligencia Artificial',
    'Modelos de lenguaje grandes',
    'ChatGPT',
    'Claude',
    'Midjourney',
    'Herramientas de productividad con IA',
  ],
  sameAs: [siteUrl],
  worksFor: {
    '@type': 'Organization',
    name: 'IA en Español',
    url: siteUrl,
  },
};

const steps = [
  { num: '01', title: 'Uso real, no demos', text: 'Cada herramienta se prueba en tareas reales durante al menos una o dos semanas.' },
  { num: '02', title: 'Lo bueno y lo malo', text: 'Pros y contras claros. Si algo falla o no compensa, lo decimos sin rodeos.' },
  { num: '03', title: 'Precio sobre la mesa', text: 'Analizamos coste real y relación calidad/precio, no solo capacidades.' },
  { num: '04', title: 'Nota con criterio', text: 'Una nota que combina calidad, precio y experiencia, recalculada cada semana.' },
];
---

<Layout
  title="Sobre mí — IA en Español"
  description="Quién está detrás de IA en Español y por qué escribo sobre inteligencia artificial en castellano."
>
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

  <!-- Intro -->
  <section class="wrap--mid" style="padding-top:72px; display:flex; gap:48px; align-items:center; flex-wrap:wrap;">
    <img
      src="/images/sergio.jpg"
      alt="Sergio, autor de IA en Español"
      width="180"
      height="180"
      style="width:180px; height:180px; flex-shrink:0; border-radius:24px; object-fit:cover; object-position:center top; border:1px solid var(--border);"
      loading="eager"
      decoding="async"
    />
    <div style="flex:1; min-width:300px;">
      <span style="font-family:'Geist Mono',monospace; font-size:12px; letter-spacing:0.16em; text-transform:uppercase; color:var(--accent);">Sobre mí</span>
      <h1 style="margin:12px 0 0; font-family:'Newsreader',serif; font-weight:500; font-size:clamp(2rem,4vw,2.875rem); line-height:1.05; letter-spacing:-0.025em; color:var(--ink);">Hola, soy Sergio.<br>Pruebo IA para que tú no tengas que hacerlo.</h1>
    </div>
  </section>

  <!-- Bio -->
  <section class="wrap--narrow" style="padding-top:48px; font-size:18px; line-height:1.78; color:var(--ink2);">
    <p style="margin:0 0 24px;">Llevo años trabajando con herramientas de inteligencia artificial en proyectos reales y, con el tiempo, me cansé de las reviews infladas y los hilos llenos de humo. Tanta promesa y tan poca prueba de verdad.</p>
    <p style="margin:0;">Así que monté <strong style="color:var(--ink); font-weight:600;">IA en Español</strong>: un sitio donde cada herramienta se analiza con criterio, en español de verdad —sin anglicismos innecesarios— y diciendo lo bueno y lo malo. Si algo no merece la pena, lo digo.</p>
  </section>

  <!-- Metodología -->
  <section class="wrap--mid" style="padding-top:56px;">
    <h2 style="margin:0 0 28px; font-family:'Newsreader',serif; font-weight:500; font-size:32px; letter-spacing:-0.02em; color:var(--ink);">Cómo analizamos</h2>
    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:18px;">
      {steps.map(s => (
        <div style="background:var(--surface); border:1px solid var(--border); border-radius:16px; padding:24px;">
          <span style="font-family:'Newsreader',serif; font-size:30px; font-weight:600; color:var(--accent);">{s.num}</span>
          <h3 style="margin:12px 0 8px; font-size:16px; font-weight:600; color:var(--ink);">{s.title}</h3>
          <p style="margin:0; font-size:14px; line-height:1.55; color:var(--ink3);">{s.text}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Values band -->
  <section class="wrap--mid" style="padding-top:48px;">
    <div style="background:var(--band-bg); border-radius:22px; padding:48px;">
      <h2 style="margin:0; font-family:'Newsreader',serif; font-weight:500; font-size:34px; line-height:1.1; letter-spacing:-0.02em; color:#fafaf9; max-width:520px;">Sin humo significa una cosa: si te recomiendo algo, es porque lo usaría yo.</h2>
      <p style="margin:18px 0 0; font-size:16px; line-height:1.6; color:#a1a1aa; max-width:520px;">Algunos enlaces son de afiliado y ayudan a mantener el proyecto, pero nunca cambian el veredicto. La nota se la gana la herramienta, no su programa de afiliados.</p>
    </div>
  </section>

  <!-- Contacto -->
  <section class="wrap--mid" style="padding-top:48px; padding-bottom:80px; text-align:center;">
    <h2 style="margin:0; font-family:'Newsreader',serif; font-weight:500; font-size:30px; letter-spacing:-0.02em; color:var(--ink);">¿Hablamos?</h2>
    <p style="margin:12px auto 24px; font-size:16px; line-height:1.6; color:var(--ink2); max-width:420px;">¿Quieres que analice una herramienta concreta o tienes una duda? Escríbeme y la próxima review puede ser la tuya.</p>
    <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap;">
      <a href="/#newsletter" class="cta-primary">Suscribirme a la newsletter <span>→</span></a>
      <a href="/blog" class="cta-secondary">Ver el blog</a>
    </div>
  </section>
</Layout>

<style>
  .cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--ink);
    color: var(--bg);
    padding: 14px 24px;
    border-radius: 11px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    transition: all .18s;
  }
  .cta-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 10px 24px var(--shadow);
  }

  .cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--surface);
    color: var(--ink);
    border: 1px solid var(--border2);
    padding: 14px 24px;
    border-radius: 11px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    transition: all .18s;
  }
  .cta-secondary:hover { border-color: var(--ink); }

</style>
