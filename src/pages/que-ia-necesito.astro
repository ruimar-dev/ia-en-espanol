  const PENALIDADES: Penalidad[] = [
    {
      // Sin presupuesto → penaliza herramientas sin plan gratuito real
      condicion: (idx) => idx[1] === 0,
      factores: { midjourney: 0.15, runway: 0.10, notion: 0.20, copilot: 0.40, heygen: 0.20, bolt: 0.50 },
    },
    {
      // Programar + priorizar creatividad: incoherente con las herramientas de código
      condicion: (idx) => idx[0] === 2 && idx[3] === 2,
      factores: { midjourney: 0.20, firefly: 0.20 },
    },
    {
      // Principiante + Cursor: la curva de aprendizaje de Cursor es demasiado alta
      condicion: (idx) => idx[2] === 0,
      factores: { cursor: 0.50 },
    },
    {
      // Técnico + programar → bolt.new no es la herramienta para desarrolladores reales
      condicion: (idx) => idx[0] === 2 && idx[2] === 2,
      factores: { bolt: 0.15 },
    },
  ];

  function aplicarPenalidades(scores: Record<string, number>): Record<string, number> {
    const resultado = { ...scores };
    PENALIDADES.forEach(({ condicion, factores }) => {
      if (!condicion(respuestasIdx)) return;
      (Object.entries(factores) as [string, number][]).forEach(([ia, factor]) => {
        if (resultado[ia] !== undefined) resultado[ia] = resultado[ia] * factor;
      });
    });
    return resultado;
  }

  let preguntaActual = 0;
  let respuestas: (Puntos | null)[] = [];
  let respuestasIdx: (number | null)[] = [];
  let animating = false;

  const $ = (id: string) => document.getElementById(id) as HTMLElement;

  function show(id: string) { $(id).classList.remove('hidden'); }
  function hide(id: string) { $(id).classList.add('hidden'); }

  function esSaltada(qIdx: number): boolean {
    return !!(preguntas[qIdx].saltarSi?.(respuestasIdx));
  }

  function getTotalRelevante(): number {
    return preguntas.filter((_, i) => !esSaltada(i)).length;
  }

  function getPreguntaVisual(idx: number): number {
    let count = 0;
    for (let i = 0; i <= idx; i++) { if (!esSaltada(i)) count++; }
    return count;
  }

  function updateProgress(idx: number) {
    const total = getTotalRelevante();
    const visual = getPreguntaVisual(idx);
    const pct = Math.round(((visual - 1) / total) * 100);
    ($('progress-bar') as HTMLElement).style.width = `${pct}%`;
    $('progress-label').textContent = `Pregunta ${visual} de ${total}`;
    $('progress-pct').textContent = `${pct}%`;
    for (let i = 1; i <= preguntas.length; i++) {
      const dot = $(`dot-${i}`);
      const qIdx = i - 1;
      if (esSaltada(qIdx)) {
        dot.style.background = 'var(--accent-tint)';
      } else if (qIdx < idx) {
        dot.style.background = 'var(--accent)';
      } else if (qIdx === idx) {
        dot.style.background = 'var(--muted)';
      } else {
        dot.style.background = '';
      }
    }
  }

  function renderQuestion(idx: number) {
    const p = preguntas[idx];
    const card = $('question-card');

    $('q-numero').textContent = `Pregunta ${getPreguntaVisual(idx)}`;
    $('q-texto').textContent = p.pregunta;
    $('q-subtitulo').textContent = p.subtitulo;

    const grid = $('opciones-grid');
    grid.className = `grid gap-2.5 ${p.grid}`;
    grid.innerHTML = '';

    p.opciones.forEach((op, opIdx) => {
      const btn = document.createElement('button');
      btn.className = 'opcion-card rounded-xl p-3.5 text-left w-full';
      btn.innerHTML = `
        <div class="flex items-start gap-3">
          <span class="op-emoji text-lg leading-none flex-shrink-0 mt-0.5">${op.emoji}</span>
          <div>
            <div class="op-titulo font-semibold text-gray-900 dark:text-white text-sm leading-snug">${op.titulo}</div>
            <div class="op-desc text-xs text-gray-500 dark:text-gray-400 mt-0.5 leading-snug">${op.desc}</div>
          </div>
        </div>
      `;
      btn.addEventListener('click', () => selectOption(btn, op.puntos, opIdx));
      grid.appendChild(btn);
    });

    card.classList.remove('slide-out');
    void card.offsetWidth;
    card.classList.add('slide-in');
    card.addEventListener('animationend', () => card.classList.remove('slide-in'), { once: true });
  }

  function selectOption(btn: HTMLButtonElement, puntos: Puntos, opIdx: number) {
    if (animating) return;
    animating = true;

    $('opciones-grid').querySelectorAll('button').forEach(b => (b as HTMLButtonElement).disabled = true);
    btn.classList.add('selected');
    respuestas[preguntaActual] = puntos;
    respuestasIdx[preguntaActual] = opIdx;

    setTimeout(() => {
      const card = $('question-card');
      card.classList.add('slide-out');
      card.addEventListener('animationend', () => {
        preguntaActual++;
        // Saltar preguntas que no aplican y registrarlas como null
        while (preguntaActual < preguntas.length && esSaltada(preguntaActual)) {
          respuestasIdx[preguntaActual] = null;
          preguntaActual++;
        }
        if (preguntaActual < preguntas.length) {
          updateProgress(preguntaActual);
          renderQuestion(preguntaActual);
          animating = false;
        } else {
          showEmailCapture();
          animating = false;
        }
      }, { once: true });
    }, 380);
  }

  function showEmailCapture() {
    ($('progress-bar') as HTMLElement).style.width = '100%';
    $('progress-label').textContent = '¡Test completado!';
    $('progress-pct').textContent = '100%';
    for (let i = 1; i <= preguntas.length; i++) {
      $(`dot-${i}`).style.background = esSaltada(i - 1) ? 'var(--accent-tint)' : 'var(--accent)';
    }

    if (localStorage.getItem('quiz_email')) {
      hide('quiz-section');
      showResults();
      return;
    }

    const qCard = $('question-card');
    qCard.classList.add('hidden');
    qCard.classList.remove('slide-out');

    const eCard = $('email-card');
    eCard.classList.remove('hidden');
    void eCard.offsetWidth;
    eCard.classList.add('fade-in-up');
    eCard.addEventListener('animationend', () => eCard.classList.remove('fade-in-up'), { once: true });
  }

  async function submitEmail(email: string) {
    localStorage.setItem('quiz_email', email);
    try {
      await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
    } catch (_) {}
  }

  function goToResults() {
    hide('quiz-section');
    showResults();
  }

  function buildResultUrl(): string {
    const url = new URL(window.location.href);
    url.searchParams.set('r', respuestasIdx.map(i => i === null ? 'n' : i).join('-'));
    return url.toString();
  }

  function setupShareButtons(url: string, iaName: string) {
    const text = `Mi IA ideal según el test es ${iaName} 🤖 ¿Cuál es la tuya?`;
    ($('btn-share-x') as HTMLAnchorElement).href =
      `https://x.com/intent/tweet?text=${encodeURIComponent(text)}&url=${encodeURIComponent(url)}`;
    ($('btn-share-whatsapp') as HTMLAnchorElement).href =
      `https://wa.me/?text=${encodeURIComponent(text + ' ' + url)}`;
    $('btn-copy-link').onclick = async () => {
      try { await navigator.clipboard.writeText(url); } catch (_) {}
      $('btn-copy-text').textContent = '¡Enlace copiado!';
      setTimeout(() => { $('btn-copy-text').textContent = 'Copiar enlace'; }, 2000);
    };
  }

  function showRelatedArticles(iaId: string) {
    const dataEl = document.getElementById('articulos-data');
    if (!dataEl) return;
    type Articulo = { title: string; description: string; slug: string; imagen?: string };
    const map: Record<string, Articulo[]> = JSON.parse(dataEl.textContent ?? '{}');
    const articles = map[iaId] ?? [];
    if (articles.length === 0) { hide('related-section'); return; }
    $('related-grid').innerHTML = articles.map(({ title, description, slug, imagen }) => `
      <a href="/blog/${slug}" class="related-card">
        <div class="related-card-img">
          ${imagen
            ? `<img src="${imagen}" alt="" style="width:100%;height:100%;object-fit:cover;" loading="lazy"/>`
            : `<div style="width:100%;height:100%;background:var(--stripe-a);"></div>`}
        </div>
        <div style="min-width:0;flex:1;">
          <p class="related-card-title">${title}</p>
          <p class="related-card-desc">${description}</p>
        </div>
        <svg class="related-card-arrow" style="width:16px;height:16px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </a>`).join('');
    show('related-section');
  }

  function tryRestoreFromUrl(): boolean {
    const params = new URLSearchParams(window.location.search);
    const r = params.get('r');
    if (!r) return false;
    const tokens = r.split('-');
    if (tokens.length !== preguntas.length) return false;
    const indices: (number | null)[] = tokens.map(t => t === 'n' ? null : parseInt(t, 10));
    for (let i = 0; i < preguntas.length; i++) {
      const idx = indices[i];
      if (idx === null) {
        if (!preguntas[i].saltarSi?.(indices)) return false;
      } else {
        if (isNaN(idx) || idx < 0 || idx >= preguntas[i].opciones.length) return false;
      }
    }
    respuestasIdx = indices;
    respuestas = indices.map((optIdx, qIdx) =>
      optIdx === null ? null : preguntas[qIdx].opciones[optIdx].puntos
    );
    hide('intro');
    showResults();
    return true;
  }

  function calcularMatchPct(iaId: string, actualScore: number): number {
    let maxScore = 0;
    preguntas.forEach((p, i) => {
      if (esSaltada(i)) return;
      const max = Math.max(0, ...p.opciones.map((op) => op.puntos[iaId] ?? 0));
      maxScore += max;
    });
    if (maxScore === 0) return 0;
    return Math.round((actualScore / maxScore) * 100);
  }

  function calcularScores(): [string, number][] {
    const scores: Record<string, number> = {};
    respuestas.forEach((puntos) => {
      if (!puntos) return;
      Object.entries(puntos).forEach(([ia, pts]) => {
        scores[ia] = (scores[ia] ?? 0) + pts;
      });
    });
    return Object.entries(aplicarPenalidades(scores)).sort(([, a], [, b]) => b - a);
  }

  function spawnConfetti() {
    const container = $('confetti-container');
    const colors = ['#7C3AED', '#A78BFA', '#F59E0B', '#10B981', '#EF4444', '#3B82F6', '#EC4899'];
    for (let i = 0; i < 24; i++) {
      const piece = document.createElement('div');
      piece.className = 'confetti-piece';
      piece.style.left = `${10 + Math.random() * 80}%`;
      piece.style.top = '0';
      piece.style.background = colors[Math.floor(Math.random() * colors.length)];
      piece.style.animationDelay = `${Math.random() * 0.5}s`;
      piece.style.animationDuration = `${0.7 + Math.random() * 0.6}s`;
      piece.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
      container.appendChild(piece);
    }
  }

  function renderComparison(top3: [string, number][]) {
    const medals = ['🥇', '🥈', '🥉'];
    const podium = top3.map(([id, score], pos) => ({
      ia: IAs[id], id, pct: calcularMatchPct(id, score), pos,
    }));

    const logoCell = ({ ia, pos }: typeof podium[0]) => `
      <div style="display:flex;flex-direction:column;align-items:center;gap:8px;padding-top:4px;">
        <span style="font-size:20px;line-height:1;">${medals[pos]}</span>
        <div style="width:40px;height:40px;border-radius:10px;background:var(--surface);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;overflow:hidden;padding:6px;flex-shrink:0;">
          <img src="${ia.logo}" alt="${ia.nombre}" style="width:100%;height:100%;object-fit:contain;"
            onerror="this.style.display='none';this.nextElementSibling.style.display='block'"/>
          <div style="display:none;width:100%;height:100%;background:linear-gradient(135deg,${ia.colorFrom},${ia.colorTo});border-radius:6px;color:#fff;font-size:10px;font-weight:700;display:none;align-items:center;justify-content:center;">${ia.nombre.substring(0, 2).toUpperCase()}</div>
        </div>
        <span style="font-size:13px;font-weight:600;color:var(--ink);line-height:1.3;text-align:center;">${ia.nombre}</span>
      </div>`;

    $('comparison-table').innerHTML = `
      <table style="width:100%;border-collapse:collapse;">
        <thead>
          <tr style="border-bottom:1px solid var(--border);">
            <th class="comp-label" style="border-bottom:none;"></th>
            ${podium.map(p => `
              <th class="comp-cell" style="border-bottom:none;padding-bottom:16px;${p.pos === 0 ? `border-top:3px solid ${p.ia.colorFrom};` : ''}">
                ${logoCell(p)}
              </th>`).join('')}
          </tr>
        </thead>
        <tbody>
          <tr class="comp-row-alt">
            <td class="comp-label">Compatibilidad</td>
            ${podium.map(p => `
              <td class="comp-cell">
                <span style="font-size:18px;font-weight:800;color:${p.pos === 0 ? 'var(--accent)' : 'var(--ink2)'};">${p.pct}%</span>
              </td>`).join('')}
          </tr>
          <tr class="comp-divider">
            <td class="comp-label">Precio</td>
            ${podium.map(p => `
              <td class="comp-cell">
                <span style="font-size:12px;color:var(--ink2);line-height:1.5;">${p.ia.precio}</span>
              </td>`).join('')}
          </tr>
          <tr class="comp-divider comp-row-alt">
            <td class="comp-label">Puntos fuertes</td>
            ${podium.map(p => `
              <td class="comp-cell">
                <div style="display:flex;flex-direction:column;align-items:center;gap:4px;">
                  ${p.ia.pros.map(pro => `<span class="comp-pro-tag">${pro}</span>`).join('')}
                </div>
              </td>`).join('')}
          </tr>
          <tr class="comp-divider">
            <td class="comp-label">Probar</td>
            ${podium.map(p => `
              <td class="comp-cell" style="padding-bottom:16px;">
                <a href="${p.ia.web}" target="_blank" rel="noopener noreferrer" class="${p.pos === 0 ? 'comp-btn-primary' : 'comp-btn-secondary'}">
                  Probar
                  <svg style="width:12px;height:12px;flex-shrink:0;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                  </svg>
                </a>
              </td>`).join('')}
          </tr>
        </tbody>
      </table>`;
    show('comparison-section');
  }

  function showResults() {
    const ranked = calcularScores();
    const top3 = ranked.filter(([id]) => IAs[id]).slice(0, 3);
    if (top3.length === 0) return;
    const [winnerId, winnerScore] = top3[0];
    const winner = IAs[winnerId];
    if (!winner) return;

    const matchPct = calcularMatchPct(winnerId, winnerScore);

    $('winner-topbar').style.background = `linear-gradient(90deg, ${winner.colorFrom}, ${winner.colorTo})`;

    $('winner-emoji').innerHTML = `
      <div style="width:64px;height:64px;border-radius:16px;overflow:hidden;background:var(--hover);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;padding:10px;">
        <img src="${winner.logo}" alt="${winner.nombre}" style="width:100%;height:100%;object-fit:contain;"
          onerror="this.style.display='none';this.nextElementSibling.style.display='block'"/>
        <span style="display:none;font-size:28px;">${winner.emoji}</span>
      </div>`;
    $('winner-empresa').textContent = winner.empresa;
    $('winner-nombre').textContent = winner.nombre;
    $('winner-match').innerHTML = `<svg style="width:12px;height:12px;flex-shrink:0;" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>${matchPct}% de compatibilidad`;
    $('winner-tagline').textContent = winner.tagline;
    $('winner-desc').textContent = winner.descripcion;
    $('winner-precio').textContent = winner.precio;
    ($('winner-link') as HTMLAnchorElement).href = winner.web;

    $('winner-pros').innerHTML = winner.pros.map(p =>
      `<span style="display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:500;color:var(--accent);background:var(--accent-tint);padding:5px 12px;border-radius:7px;font-family:'Geist',sans-serif;">
        <svg style="width:12px;height:12px;flex-shrink:0;" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
        </svg>${p}</span>`
    ).join('');

    renderComparison(top3);

    show('results-section');
    const rs = $('results-section');
    rs.classList.add('fade-in-up');
    rs.addEventListener('animationend', () => rs.classList.remove('fade-in-up'), { once: true });

    spawnConfetti();

    const resultUrl = buildResultUrl();
    history.replaceState(null, '', resultUrl);
    setupShareButtons(resultUrl, winner.nombre);
    show('share-section');
    showRelatedArticles(winnerId);
  }

  function startQuiz() {
    hide('intro');
    show('quiz-section');
    preguntaActual = 0;
    respuestas = [];
    updateProgress(0);
    renderQuestion(0);
  }

  function restartQuiz() {
    hide('results-section');
    hide('share-section');
    hide('related-section');
    hide('comparison-section');
    history.replaceState(null, '', window.location.pathname);
    $('confetti-container').innerHTML = '';
    $('email-card').classList.add('hidden');
    const qCard = $('question-card');
    qCard.classList.remove('hidden', 'slide-out');
    respuestasIdx = [];
    startQuiz();
  }

  $('email-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const input = $('email-input') as HTMLInputElement;
    const error = $('email-error');

    if (!input.value || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(input.value)) {
      error.classList.remove('hidden');
      input.classList.add('border-red-400');
      return;
    }
    error.classList.add('hidden');
    input.classList.remove('border-red-400');

    const btn = $('btn-email-submit') as HTMLButtonElement;
    btn.disabled = true;
    $('btn-email-text').textContent = 'Enviando...';
    $('btn-email-arrow').classList.add('hidden');
    $('btn-email-spinner').classList.remove('hidden');

    await submitEmail(input.value);
    goToResults();
  });

  $('btn-skip-email').addEventListener('click', goToResults);
  $('btn-start').addEventListener('click', startQuiz);
  $('btn-restart').addEventListener('click', restartQuiz);

  tryRestoreFromUrl();
</script>
