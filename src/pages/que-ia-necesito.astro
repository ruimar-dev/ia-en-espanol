---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('blog', ({ data }) => !data.draft);

const IA_HERRAMIENTAS: Record<string, string[]> = {
  chatgpt:     ['ChatGPT'],
  claude:      ['Claude', 'Anthropic'],
  gemini:      ['Google Gemini', 'Gemini'],
  perplexity:  ['Perplexity AI', 'Perplexity'],
  midjourney:  ['Midjourney'],
  firefly:     ['Adobe Firefly'],
  cursor:      ['Cursor'],
  copilot:     ['GitHub Copilot'],
  elevenlabs:  ['ElevenLabs'],
  runway:      ['Runway'],
  notion:      ['Notion AI', 'Notion'],
  grok:        ['Grok', 'xAI'],
  deepseek:    ['DeepSeek', 'DeepSeek R1'],
  notebooklm:  ['NotebookLM'],
  heygen:      ['HeyGen'],
  bolt:        ['Bolt.new', 'Bolt'],
};

const articulosPorIA: Record<string, Array<{ title: string; description: string; slug: string; imagen?: string }>> = {};
for (const [iaId, names] of Object.entries(IA_HERRAMIENTAS)) {
  articulosPorIA[iaId] = allArticles
    .filter(a => a.data.herramientas.some(h => names.includes(h)))
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
    .slice(0, 2)
    .map(a => ({ title: a.data.title, description: a.data.description, slug: a.slug, imagen: a.data.imagen }));
}
---

<Layout
  title="¿Qué IA necesito? — Test interactivo | IA en Español"
  description="Responde 5 preguntas y descubre qué herramienta de inteligencia artificial es perfecta para ti. Quiz gratuito y personalizado."
>
  <!-- INTRO -->
  <section id="intro" class="wrap--narrow" style="padding-top:56px; padding-bottom:80px; text-align:center;">
    <span style="font-family:'Geist Mono',monospace; font-size:12px; letter-spacing:0.16em; text-transform:uppercase; color:var(--accent);">Recomendador</span>
    <h1 style="margin:12px 0 0; font-family:'Newsreader',serif; font-weight:500; font-size:clamp(2.2rem,5vw,2.875rem); line-height:1.05; letter-spacing:-0.025em; color:var(--ink);">¿Qué IA necesitas?</h1>
    <p style="margin:14px auto 0; font-size:18px; line-height:1.55; color:var(--ink2); max-width:440px;">5 preguntas rápidas y te decimos exactamente qué herramienta de IA usar. Sin tecnicismos, sin rodeos.</p>

    <div style="display:flex; flex-wrap:wrap; justify-content:center; gap:20px; margin:32px 0 36px;">
      <span style="display:flex; align-items:center; gap:8px; font-size:14px; color:var(--ink2);">
        <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        Solo 5 preguntas
      </span>
      <span style="display:flex; align-items:center; gap:8px; font-size:14px; color:var(--ink2);">
        <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
        Resultado personalizado
      </span>
      <span style="display:flex; align-items:center; gap:8px; font-size:14px; color:var(--ink2);">
        <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Gratis, sin registro
      </span>
    </div>

    <button
      id="btn-start"
      style="display:inline-flex; align-items:center; gap:8px; background:var(--ink); color:var(--bg); border:none; padding:15px 28px; border-radius:12px; font-family:'Geist',sans-serif; font-size:16px; font-weight:600; cursor:pointer; transition:all .18s;"
    >
      Empezar el test
      <svg style="width:16px;height:16px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
    </button>
  </section>

  <!-- QUIZ -->
  <section id="quiz-section" class="hidden wrap--narrow" style="padding-top:40px; padding-bottom:80px;">
    <!-- Progress -->
    <div style="margin-bottom:28px;">
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
        <span id="progress-label" style="font-family:'Geist Mono',monospace; font-size:12px; color:var(--muted);">Pregunta 1 de 5</span>
        <span id="progress-pct" style="font-family:'Geist Mono',monospace; font-size:12px; color:var(--muted);">0%</span>
      </div>
      <div style="height:6px; border-radius:99px; background:var(--hover); overflow:hidden;">
        <div id="progress-bar" style="height:100%; width:0%; background:var(--accent); border-radius:99px; transition:width .35s ease;"></div>
      </div>
      <div style="display:flex; gap:6px; margin-top:10px;">
        <div id="dot-1" style="height:3px; flex:1; border-radius:99px; transition:all .3s;"></div>
        <div id="dot-2" style="height:3px; flex:1; border-radius:99px; transition:all .3s;"></div>
        <div id="dot-3" style="height:3px; flex:1; border-radius:99px; transition:all .3s;"></div>
        <div id="dot-4" style="height:3px; flex:1; border-radius:99px; transition:all .3s;"></div>
        <div id="dot-5" style="height:3px; flex:1; border-radius:99px; transition:all .3s;"></div>
      </div>
    </div>

    <!-- Question card -->
    <div id="question-card" style="background:var(--surface); border:1px solid var(--border); border-radius:20px; padding:36px; box-shadow:0 1px 2px var(--shadow), 0 12px 32px var(--shadow);">
      <p id="q-numero" style="margin:0 0 16px; font-family:'Geist Mono',monospace; font-size:12px; letter-spacing:0.1em; text-transform:uppercase; color:var(--accent);"></p>
      <h2 id="q-texto" style="margin:0 0 8px; font-family:'Newsreader',serif; font-weight:500; font-size:28px; line-height:1.18; letter-spacing:-0.02em; color:var(--ink);"></h2>
      <p id="q-subtitulo" style="margin:0 0 24px; font-size:14px; line-height:1.5; color:var(--ink3);"></p>
      <div id="opciones-grid" class="grid gap-2.5"></div>
    </div>

    <!-- Email capture card -->
    <div id="email-card" class="hidden" style="background:var(--surface); border:1px solid var(--border); border-radius:20px; padding:40px; box-shadow:0 1px 2px var(--shadow), 0 12px 32px var(--shadow); text-align:center;">
      <div style="width:56px; height:56px; margin:0 auto 20px; background:var(--accent-tint); border-radius:16px; display:flex; align-items:center; justify-content:center;">
        <svg style="width:28px;height:28px;color:var(--accent);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <h2 style="margin:0 0 8px; font-family:'Newsreader',serif; font-weight:500; font-size:28px; line-height:1.12; letter-spacing:-0.02em; color:var(--ink);">Tu resultado te espera</h2>
      <p style="margin:0 auto 28px; font-size:15px; line-height:1.6; color:var(--ink2); max-width:300px;">Déjanos tu email y te enviamos las mejores reviews de herramientas IA cada semana. Sin spam, solo lo bueno.</p>

      <form id="email-form" novalidate style="max-width:320px; margin:0 auto; text-align:left;">
        <div style="margin-bottom:10px;">
          <input
            id="email-input"
            type="email"
            placeholder="tu@email.com"
            autocomplete="email"
            style="width:100%; padding:14px 18px; border:1px solid var(--border2); border-radius:11px; font-family:'Geist',sans-serif; font-size:15px; color:var(--ink); background:var(--bg); outline:none; box-sizing:border-box; transition:border-color .18s;"
          />
          <p id="email-error" class="hidden" style="font-size:12px; color:#ef4444; margin:6px 0 0 2px;">Introduce un email válido.</p>
        </div>
        <button
          type="submit"
          id="btn-email-submit"
          style="width:100%; display:flex; align-items:center; justify-content:center; gap:8px; background:var(--ink); color:var(--bg); border:none; padding:14px; border-radius:11px; font-family:'Geist',sans-serif; font-size:15px; font-weight:600; cursor:pointer; transition:all .18s;"
        >
          <span id="btn-email-text">Ver mi resultado</span>
          <svg id="btn-email-arrow" style="width:16px;height:16px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          <svg id="btn-email-spinner" class="hidden animate-spin" style="width:16px;height:16px;" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
          </svg>
        </button>
      </form>

      <button id="btn-skip-email" style="margin-top:20px; background:none; border:none; cursor:pointer; font-family:'Geist',sans-serif; font-size:13px; color:var(--ink3); padding:0; transition:color .15s;">Saltar y ver el resultado</button>
    </div>
  </section>

  <!-- RESULTS -->
  <section id="results-section" class="hidden wrap--narrow" style="padding-top:40px; padding-bottom:80px;">
    <div>
      <div style="text-align:center; margin-bottom:36px;">
        <div id="confetti-container" style="position:relative; height:32px; margin-bottom:8px; overflow:visible; pointer-events:none;"></div>
        <span style="font-family:'Geist Mono',monospace; font-size:12px; letter-spacing:0.16em; text-transform:uppercase; color:var(--accent);">Tu resultado</span>
        <h2 style="margin:10px 0 6px; font-family:'Newsreader',serif; font-weight:500; font-size:32px; line-height:1.1; letter-spacing:-0.02em; color:var(--ink);">Tu IA ideal es...</h2>
        <p style="font-size:14px; color:var(--ink3);">Basado en tus respuestas, aquí está tu recomendación personalizada.</p>
      </div>

      <!-- Winner card -->
      <div id="winner-card" style="background:var(--surface); border:1px solid var(--border); border-radius:20px; margin-bottom:24px; overflow:hidden; box-shadow:0 1px 2px var(--shadow), 0 12px 32px var(--shadow);">
        <div id="winner-topbar" style="height:4px;"></div>
        <div style="padding:28px;">
          <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:16px; margin-bottom:16px;">
            <div style="flex:1; min-width:0;">
              <p id="winner-empresa" style="margin:0 0 4px; font-size:11px; font-family:'Geist Mono',monospace; letter-spacing:0.1em; text-transform:uppercase; color:var(--muted);"></p>
              <h3 id="winner-nombre" style="margin:0; font-family:'Newsreader',serif; font-weight:500; font-size:clamp(1.8rem,5vw,2.2rem); line-height:1.05; letter-spacing:-0.02em; color:var(--ink);"></h3>
            </div>
            <div id="winner-emoji" style="flex-shrink:0;"></div>
          </div>
          <div style="margin-bottom:14px;">
            <span id="winner-match" style="display:inline-flex; align-items:center; gap:6px; font-size:12px; font-weight:600; color:var(--accent); background:var(--accent-tint); padding:5px 12px; border-radius:7px; font-family:'Geist',sans-serif;"></span>
          </div>
          <p id="winner-tagline" style="margin:0 0 8px; font-size:16px; font-weight:600; line-height:1.4; color:var(--ink);"></p>
          <p id="winner-desc" style="margin:0 0 20px; font-size:14px; line-height:1.6; color:var(--ink2);"></p>
          <div id="winner-pros" style="display:flex; flex-wrap:wrap; gap:8px; margin-bottom:24px;"></div>
          <div style="display:flex; flex-wrap:wrap; align-items:center; gap:12px; padding-top:20px; border-top:1px solid var(--border);">
            <a id="winner-link" href="#" target="_blank" rel="noopener noreferrer" class="winner-cta-btn">
              Probar ahora
              <svg style="width:14px;height:14px;flex-shrink:0;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </a>
            <span style="display:flex; align-items:center; gap:6px; font-family:'Geist Mono',monospace; font-size:12px; color:var(--muted);">
              <svg style="width:14px;height:14px;flex-shrink:0;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/>
              </svg>
              <span id="winner-precio"></span>
            </span>
          </div>
        </div>
      </div>

      <!-- Share -->
      <div id="share-section" class="hidden" style="margin-bottom:32px;">
        <p style="font-family:'Geist Mono',monospace; font-size:11px; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:var(--muted); margin:0 0 12px;">Comparte tu resultado</p>
        <div style="display:flex; flex-wrap:wrap; gap:8px;">
          <button id="btn-copy-link" class="share-btn">
            <svg style="width:16px;height:16px;flex-shrink:0;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/>
            </svg>
            <span id="btn-copy-text">Copiar enlace</span>
          </button>
          <a id="btn-share-x" href="#" target="_blank" rel="noopener noreferrer" class="share-btn">
            <svg style="width:16px;height:16px;flex-shrink:0;" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.259 5.63L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
            </svg>
            Compartir en X
          </a>
          <a id="btn-share-whatsapp" href="#" target="_blank" rel="noopener noreferrer" class="share-btn share-btn--wa">
            <svg style="width:16px;height:16px;flex-shrink:0;" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp
          </a>
        </div>
      </div>

      <!-- Comparison -->
      <div id="comparison-section" class="hidden" style="margin-bottom:40px;">
        <p style="font-family:'Geist Mono',monospace; font-size:11px; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:var(--muted); margin:0 0 16px;">Comparativa del podio</p>
        <div style="overflow-x:auto; margin:0 -20px;">
          <div style="padding:0 20px;">
            <div id="comparison-table" style="min-width:480px; border-radius:16px; border:1px solid var(--border); overflow:hidden;"></div>
          </div>
        </div>
      </div>

      <!-- Related articles -->
      <div id="related-section" class="hidden" style="margin-bottom:32px;">
        <p style="font-family:'Geist Mono',monospace; font-size:11px; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:var(--muted); margin:0 0 16px;">Sigue leyendo</p>
        <div id="related-grid" style="display:flex; flex-direction:column; gap:12px;"></div>
      </div>

      <!-- Restart -->
      <div style="text-align:center; padding-top:24px; border-top:1px solid var(--border);">
        <button id="btn-restart" style="display:inline-flex; align-items:center; gap:8px; background:none; border:none; cursor:pointer; font-family:'Geist',sans-serif; font-size:14px; font-weight:500; color:var(--ink3); padding:0; transition:color .15s;">
          <svg style="width:16px;height:16px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
          </svg>
          Repetir el test
        </button>
      </div>
    </div>
  </section>

  <script type="application/json" id="articulos-data" set:html={JSON.stringify(articulosPorIA)}></script>
</Layout>

<style>
  @keyframes slideInRight {
    from { transform: translateX(50px); opacity: 0; }
    to   { transform: translateX(0);    opacity: 1; }
  }
  @keyframes slideOutLeft {
    from { transform: translateX(0);     opacity: 1; }
    to   { transform: translateX(-50px); opacity: 0; }
  }
  @keyframes fadeInUp {
    from { transform: translateY(30px); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
  }
  @keyframes popIn {
    0%   { transform: scale(1); }
    35%  { transform: scale(1.04); }
    100% { transform: scale(1); }
  }
  @keyframes confettiFall {
    0%   { transform: translateY(0)    rotate(0deg);   opacity: 1; }
    100% { transform: translateY(80px) rotate(720deg); opacity: 0; }
  }

  .slide-in   { animation: slideInRight 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94) both; }
  .slide-out  { animation: slideOutLeft  0.25s cubic-bezier(0.55, 0, 0.75, 0.06)    both; }
  .fade-in-up { animation: fadeInUp      0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94) both; }

  /* Default color for progress dots (JS clears inline style to reset to this) */
  :global(#dot-1), :global(#dot-2), :global(#dot-3),
  :global(#dot-4), :global(#dot-5) {
    background: var(--border);
  }

  :global(.opcion-card) {
    cursor: pointer;
    border: 1px solid var(--border2) !important;
    background: var(--bg) !important;
    border-radius: 13px !important;
    padding: 18px 20px !important;
    transition: border-color 0.15s ease, background 0.15s ease, transform 0.15s ease;
  }
  :global(.op-emoji) {
    display: inline-block;
    transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  :global(.op-titulo) {
    color: var(--ink) !important;
    transition: color 0.15s ease;
  }
  :global(.op-desc) {
    color: var(--ink3) !important;
  }
  :global(.opcion-card:hover) {
    border-color: var(--accent) !important;
    background: var(--accent-tint) !important;
    transform: translateX(3px);
    box-shadow: none;
  }
  :global(.opcion-card:hover .op-emoji) {
    transform: scale(1.15);
  }
  :global(.opcion-card:hover .op-titulo) {
    color: var(--accent) !important;
  }
  :global(.opcion-card.selected) {
    border-color: var(--accent) !important;
    background: var(--accent-tint) !important;
    animation: popIn 0.25s ease;
  }
  :global(.opcion-card.selected .op-titulo) {
    color: var(--accent) !important;
  }
  :global(.opcion-card.selected .op-desc) {
    color: var(--ink2) !important;
  }
  :global(.confetti-piece) {
    position: absolute;
    width: 8px;
    height: 8px;
    border-radius: 2px;
    animation: confettiFall 0.9s ease-out forwards;
  }

  /* Winner card CTA */
  :global(.winner-cta-btn) {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--ink);
    color: var(--bg);
    padding: 12px 20px;
    border-radius: 11px;
    font-family: 'Geist', sans-serif;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.18s;
  }
  :global(.winner-cta-btn:hover) {
    transform: translateY(-1px);
    box-shadow: 0 8px 20px var(--shadow);
  }

  /* Share buttons */
  :global(.share-btn) {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    border-radius: 11px;
    border: 1px solid var(--border2);
    background: var(--surface);
    color: var(--ink2);
    font-family: 'Geist', sans-serif;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.15s;
  }
  :global(.share-btn:hover) {
    border-color: var(--accent);
