---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="¿Qué IA necesito? — Test interactivo | IA en Español"
  description="Responde 5 preguntas y descubre qué herramienta de inteligencia artificial es perfecta para ti. Quiz gratuito y personalizado."
>
  <!-- INTRO -->
  <section id="intro" class="relative overflow-hidden py-24 px-4 text-center">
    <div class="absolute inset-0 bg-gradient-to-b from-[#f0ebff] to-[#fafafa] dark:from-[#0f0f0f] dark:via-[#1a0a2e] dark:to-[#0f0f0f]" aria-hidden="true"></div>
    <div class="relative max-w-2xl mx-auto">
      <span class="inline-block bg-[#7C3AED]/10 dark:bg-white/10 text-[#7C3AED] dark:text-white/80 text-sm font-semibold px-4 py-1.5 rounded-full mb-6 border border-[#7C3AED]/20 dark:border-white/10">
        Test interactivo
      </span>
      <h1 class="font-extrabold text-gray-900 dark:text-white mb-4 leading-tight tracking-tight" style="font-size: clamp(2.5rem, 5vw, 4rem);">
        ¿Qué IA<br/>
        <span class="text-[#7C3AED] dark:text-[#A78BFA]">necesitas?</span>
      </h1>
      <p class="text-lg text-gray-600 dark:text-white/70 mb-10 max-w-lg mx-auto leading-relaxed">
        5 preguntas rápidas y te decimos exactamente qué herramienta de IA usar. Sin tecnicismos, sin rodeos.
      </p>
      <div class="flex flex-wrap justify-center gap-6 mb-10">
        <span class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400">
          <svg class="w-4 h-4 text-[#7C3AED] flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
          </svg>
          Solo 5 preguntas
        </span>
        <span class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400">
          <svg class="w-4 h-4 text-[#7C3AED] flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
          Resultado personalizado
        </span>
        <span class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400">
          <svg class="w-4 h-4 text-[#7C3AED] flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          Gratis, sin registro
        </span>
      </div>
      <button
        id="btn-start"
        class="inline-flex items-center gap-2 bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-bold px-8 py-4 rounded-xl text-base transition-colors shadow-lg shadow-[#7C3AED]/30"
      >
        Empezar el test
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </button>
    </div>
  </section>

  <!-- QUIZ -->
  <section id="quiz-section" class="hidden py-10 pb-24 px-4">
    <div class="max-w-2xl mx-auto">
      <!-- Progress -->
      <div class="mb-8">
        <div class="flex justify-between items-center mb-2">
          <span id="progress-label" class="text-sm font-medium text-gray-500 dark:text-gray-400">Pregunta 1 de 5</span>
          <span id="progress-pct" class="text-sm font-semibold text-[#7C3AED]">0%</span>
        </div>
        <div class="h-1.5 bg-gray-200 dark:bg-gray-800 rounded-full overflow-hidden">
          <div id="progress-bar" class="h-full bg-[#7C3AED] rounded-full transition-all duration-500" style="width: 0%"></div>
        </div>
        <div class="flex gap-1.5 mt-3">
          <div id="dot-1" class="h-1 flex-1 rounded-full bg-gray-200 dark:bg-gray-800 transition-all duration-300"></div>
          <div id="dot-2" class="h-1 flex-1 rounded-full bg-gray-200 dark:bg-gray-800 transition-all duration-300"></div>
          <div id="dot-3" class="h-1 flex-1 rounded-full bg-gray-200 dark:bg-gray-800 transition-all duration-300"></div>
          <div id="dot-4" class="h-1 flex-1 rounded-full bg-gray-200 dark:bg-gray-800 transition-all duration-300"></div>
          <div id="dot-5" class="h-1 flex-1 rounded-full bg-gray-200 dark:bg-gray-800 transition-all duration-300"></div>
        </div>
      </div>

      <!-- Question card -->
      <div id="question-card" class="bg-white dark:bg-[#1A1A1A] rounded-2xl border border-gray-200 dark:border-gray-800 p-6 sm:p-8">
        <p id="q-numero" class="text-xs font-semibold text-[#7C3AED] mb-3 uppercase tracking-widest">Pregunta 1</p>
        <h2 id="q-texto" class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white mb-1 leading-snug"></h2>
        <p id="q-subtitulo" class="text-sm text-gray-500 dark:text-gray-400 mb-6"></p>
        <div id="opciones-grid" class="grid gap-2.5"></div>
      </div>

      <!-- Email capture card -->
      <div id="email-card" class="hidden bg-white dark:bg-[#1A1A1A] rounded-2xl border border-gray-200 dark:border-gray-800 p-6 sm:p-10 text-center">
        <div class="w-14 h-14 mx-auto mb-5 bg-[#7C3AED]/10 dark:bg-[#7C3AED]/15 rounded-2xl flex items-center justify-center">
          <svg class="w-7 h-7 text-[#7C3AED]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <h2 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white mb-2 leading-snug">
          Tu resultado te espera
        </h2>
        <p class="text-gray-500 dark:text-gray-400 mb-8 max-w-xs mx-auto leading-relaxed text-sm">
          Déjanos tu email y te enviamos las mejores reviews de herramientas IA cada semana. Sin spam, solo lo bueno.
        </p>

        <form id="email-form" novalidate class="space-y-3 max-w-xs mx-auto text-left">
          <div>
            <input
              id="email-input"
              type="email"
              placeholder="tu@email.com"
              autocomplete="email"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:border-[#7C3AED] focus:ring-1 focus:ring-[#7C3AED] transition-colors text-sm"
            />
            <p id="email-error" class="hidden text-xs text-red-500 mt-1 ml-1">Introduce un email válido.</p>
          </div>
          <button
            type="submit"
            id="btn-email-submit"
            class="w-full bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-bold py-3 px-6 rounded-xl transition-colors flex items-center justify-center gap-2 text-sm"
          >
            <span id="btn-email-text">Ver mi resultado</span>
            <svg id="btn-email-arrow" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
            <svg id="btn-email-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
            </svg>
          </button>
        </form>

        <button id="btn-skip-email" class="mt-5 text-xs text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors">
          Saltar y ver el resultado
        </button>
      </div>
    </div>
  </section>

  <!-- RESULTS -->
  <section id="results-section" class="hidden py-10 pb-24 px-4">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-10">
        <div id="confetti-container" class="relative h-12 mb-4 overflow-visible pointer-events-none"></div>
        <p class="text-xs font-bold uppercase tracking-widest text-[#7C3AED] mb-2">Tu resultado</p>
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-2">Tu IA ideal es...</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Basado en tus respuestas, aquí está tu recomendación personalizada.</p>
      </div>

      <!-- Winner card -->
      <div id="winner-card" class="rounded-2xl mb-6 text-white overflow-hidden shadow-xl">
        <div class="p-6 sm:p-8">
          <div class="flex items-start justify-between gap-4 mb-5">
            <div>
              <p class="text-sm font-medium opacity-70 mb-1" id="winner-empresa"></p>
              <h3 class="text-3xl sm:text-4xl font-extrabold leading-tight" id="winner-nombre"></h3>
            </div>
            <div class="flex-shrink-0" id="winner-emoji"></div>
          </div>
          <p class="text-base font-semibold opacity-90 mb-3" id="winner-tagline"></p>
          <p class="opacity-75 mb-5 leading-relaxed text-sm" id="winner-desc"></p>
          <div class="flex flex-wrap gap-2 mb-5" id="winner-pros"></div>
          <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3 pt-5 border-t border-white/20">
            <a id="winner-link" href="#" target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-2 bg-white/20 hover:bg-white/30 border border-white/30 text-white font-semibold px-5 py-2.5 rounded-xl transition-colors text-sm">
              Probar ahora
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </a>
            <span class="flex items-center gap-1.5 text-sm opacity-70">
              <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/>
              </svg>
              <span id="winner-precio"></span>
            </span>
          </div>
        </div>
      </div>

      <!-- Alternatives -->
      <div class="mb-10">
        <p class="text-xs font-bold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-4">También puede interesarte</p>
        <div id="alt-grid" class="grid grid-cols-1 sm:grid-cols-2 gap-3"></div>
      </div>

      <!-- Restart -->
      <div class="text-center pt-6 border-t border-gray-200 dark:border-gray-800">
        <button id="btn-restart" class="inline-flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-[#7C3AED] dark:hover:text-[#7C3AED] font-medium transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
          </svg>
          Repetir el test
        </button>
      </div>
    </div>
  </section>
</Layout>

<style>
  @keyframes slideInRight {
    from { transform: translateX(50px); opacity: 0; }
    to   { transform: translateX(0);    opacity: 1; }
  }
  @keyframes slideOutLeft {
    from { transform: translateX(0);     opacity: 1; }
    to   { transform: translateX(-50px); opacity: 0; }
  }
  @keyframes fadeInUp {
    from { transform: translateY(30px); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
  }
  @keyframes popIn {
    0%   { transform: scale(1); }
    35%  { transform: scale(1.04); }
    100% { transform: scale(1); }
  }
  @keyframes confettiFall {
    0%   { transform: translateY(0)    rotate(0deg);   opacity: 1; }
    100% { transform: translateY(80px) rotate(720deg); opacity: 0; }
  }

  .slide-in   { animation: slideInRight 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94) both; }
  .slide-out  { animation: slideOutLeft  0.25s cubic-bezier(0.55, 0, 0.75, 0.06)    both; }
  .fade-in-up { animation: fadeInUp      0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94) both; }

  :global(.opcion-card) {
    cursor: pointer;
    border: 1.5px solid #E5E7EB;
    background: white;
    transition:
      transform    0.2s ease,
      box-shadow   0.2s ease,
      border-color 0.15s ease,
      background   0.15s ease;
  }
  :global(.dark .opcion-card) {
    background: #1A1A1A;
    border-color: #1F2937;
  }
  :global(.op-emoji) {
    display: inline-block;
    transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  :global(.op-titulo) {
    transition: color 0.15s ease;
  }
  :global(.opcion-card:hover) {
    border-color: #7C3AED;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(124, 58, 237, 0.14);
    background: rgba(124, 58, 237, 0.03);
  }
  :global(.dark .opcion-card:hover) {
    background: rgba(124, 58, 237, 0.07);
    border-color: #7C3AED;
  }
  :global(.opcion-card:hover .op-emoji) {
    transform: scale(1.2);
  }
  :global(.opcion-card:hover .op-titulo) {
    color: #7C3AED;
  }
  :global(.opcion-card.selected) {
    border-color: #7C3AED;
    background: #7C3AED !important;
    animation: popIn 0.25s ease;
  }
  :global(.opcion-card.selected .op-titulo) { color: white; }
  :global(.opcion-card.selected .op-desc)   { color: rgba(255,255,255,0.72); }
  :global(.confetti-piece) {
    position: absolute;
    width: 8px;
    height: 8px;
    border-radius: 2px;
    animation: confettiFall 0.9s ease-out forwards;
  }
</style>

<script>
  interface Puntos { [key: string]: number }

  interface Opcion {
    emoji: string;
    titulo: string;
    desc: string;
    puntos: Puntos;
  }

  interface Pregunta {
    pregunta: string;
    subtitulo: string;
    grid: string;
    opciones: Opcion[];
