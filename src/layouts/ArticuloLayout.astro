---
import Layout from './Layout.astro';
import FeedbackArticulo from '../components/FeedbackArticulo.astro';
import { CATEGORIA_LABELS } from '../content/config';
import type { Categoria } from '../content/config';
import { herramientas as herramientasData } from '../data/herramientas';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description: string;
  date: Date;
  dateModified?: Date;
  category: Categoria;
  herramientas: string[];
  afiliado?: string;
  imagen?: string;
  faqs?: Array<{ pregunta: string; respuesta: string }>;
  ratings?: Array<{ label: string; score: number }>;
  minutosLectura?: number;
}

const { title, description, date, dateModified, category, herramientas, afiliado, imagen, faqs, ratings, minutosLectura } = Astro.props;
const siteUrl = import.meta.env.SITE_URL || Astro.site?.toString() || 'https://iaenespanol.es';

const dateFormatted = date
  .toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' })
  .toUpperCase()
  .replace('.', '');

const dateModifiedFormatted = dateModified
  ? dateModified
      .toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' })
      .toUpperCase()
      .replace('.', '')
  : null;

// Buscar herramienta principal en herramientas.ts para mostrar el score en el sidebar
const herramientaPrincipal =
  herramientas.length > 0
    ? (herramientasData.find((h) =>
        herramientas.some(
          (n) =>
            n.toLowerCase().includes(h.nombre.toLowerCase()) ||
            h.nombre.toLowerCase().includes(n.toLowerCase().split(' ')[0])
        )
      ) ?? null)
    : null;
const score = herramientaPrincipal ? herramientaPrincipal.rating * 2 : null;

// Artículos relacionados (misma categoría, excluye el actual)
const todos = await getCollection('blog', ({ data }) => !data.draft);
const relacionados = todos
  .filter((a) => a.data.category === category && a.data.title !== title)
  .slice(0, 3);
---

<Layout
  title={title}
  description={description}
  image={imagen}
  article
  publishDate={date}
  dateModified={dateModified}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Inicio', item: siteUrl },
      { '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteUrl}/blog` },
      { '@type': 'ListItem', position: 3, name: title, item: `${siteUrl}${Astro.url.pathname}` },
    ],
  })} />
  {faqs && faqs.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqs.map((faq) => ({
        '@type': 'Question',
        name: faq.pregunta,
        acceptedAnswer: { '@type': 'Answer', text: faq.respuesta },
      })),
    })} />
  )}

  <!-- Article header -->
  <div class="art-header">
    <nav aria-label="Migas de pan" style="display:flex; align-items:center; gap:8px; font-family:'Geist Mono',monospace; font-size:12px; color:var(--muted); margin-bottom:28px;">
      <a href="/blog" style="color:var(--ink3); text-decoration:none;">Blog</a>
      <span>/</span>
      <span style="color:var(--accent);">{CATEGORIA_LABELS[category]}</span>
    </nav>

    <div style="display:flex; align-items:center; gap:10px; margin-bottom:20px;">
      <span style="font-size:12px; font-weight:600; color:var(--accent); background:var(--accent-tint); padding:5px 11px; border-radius:7px;">{CATEGORIA_LABELS[category]}</span>
      <time
        datetime={date.toISOString()}
        style="font-family:'Geist Mono',monospace; font-size:12px; color:var(--muted);"
      >
        {dateModified ? 'Actualizado · ' : ''}{dateModified ? dateModifiedFormatted : dateFormatted}
      </time>
    </div>

    <h1 style="margin:0; font-family:'Newsreader',serif; font-weight:500; font-size:clamp(2rem,4.5vw,3.125rem); line-height:1.08; letter-spacing:-0.025em; color:var(--ink);">{title}</h1>
    <p style="margin:22px 0 0; font-size:20px; line-height:1.55; color:var(--ink2);">{description}</p>

    <div style="display:flex; align-items:center; gap:14px; margin-top:30px; padding-bottom:36px; border-bottom:1px solid var(--border);">
      <img src="/images/sergio.jpg" alt="Sergio Ruiz" width="42" height="42" style="width:42px; height:42px; flex-shrink:0; border-radius:50%; object-fit:cover; object-position:center top; border:1px solid var(--border);" />
      <div>
        <div style="font-size:14px; font-weight:600; color:var(--ink);">Por Sergio Ruiz</div>
        <div style="font-family:'Geist Mono',monospace; font-size:12px; color:var(--muted); margin-top:2px;">
          {minutosLectura ? `${minutosLectura} min de lectura` : 'Probado en profundidad'}
          {dateModified ? ` · Actualizado ${dateModifiedFormatted}` : ''}
        </div>
      </div>
    </div>
  </div>

  <!-- Hero image -->
  <div class="art-hero">
    {imagen ? (
      <img
        src={imagen}
        alt={title}
        width="1200"
        height="675"
        style="width:100%; border-radius:18px; border:1px solid var(--border); aspect-ratio:16/9; object-fit:cover; display:block;"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    ) : (
      <div style="border-radius:18px; background-image:repeating-linear-gradient(135deg,var(--stripe-a),var(--stripe-a) 14px,var(--stripe-b) 14px,var(--stripe-b) 28px); border:1px solid var(--border); height:380px; display:flex; align-items:center; justify-content:center;" aria-hidden="true">
        <span style="font-family:'Geist Mono',monospace; font-size:13px; color:var(--muted);">[ imagen de portada ]</span>
      </div>
    )}
  </div>

  <!-- Body: prose + sidebar -->
  <div class="art-grid">
    <article class="article-prose">
      <slot />
      <FeedbackArticulo />
    </article>

    <aside class="art-sidebar">
      {ratings && ratings.length > 0 && score !== null && (
        <div style="background:var(--surface); border:1px solid var(--border); border-radius:18px; padding:24px; box-shadow:0 1px 2px var(--shadow), 0 12px 28px var(--shadow);">
          <div style="display:flex; align-items:baseline; gap:8px; margin-bottom:4px;">
            <span style="font-family:'Newsreader',serif; font-size:52px; font-weight:600; line-height:1; color:var(--ink);">{score.toFixed(1)}</span>
            <span style="font-family:'Geist Mono',monospace; font-size:13px; color:var(--muted);">/ 10</span>
          </div>
          <div style="font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:var(--accent); margin-bottom:22px;">Veredicto IA en Español</div>

          {ratings && ratings.length > 0 && (
            <div style="display:flex; flex-direction:column; gap:16px; margin-bottom:22px;">
              {ratings.map((rt) => (
                <div>
                  <div style="display:flex; justify-content:space-between; margin-bottom:7px;">
                    <span style="font-size:13px; font-weight:500; color:var(--ink2);">{rt.label}</span>
                    <span style="font-family:'Geist Mono',monospace; font-size:12px; color:var(--ink);">{rt.score.toFixed(1)}</span>
                  </div>
                  <div style="height:6px; border-radius:99px; background:var(--hover); overflow:hidden;">
                    <div style={`height:100%; width:${rt.score * 10}%; background:var(--accent); border-radius:99px;`}></div>
                  </div>
                </div>
              ))}
            </div>
          )}

          {(afiliado ?? herramientaPrincipal?.url) && (
            <a
              href={afiliado ?? herramientaPrincipal!.url}
              target="_blank"
              rel="noopener noreferrer nofollow"
              style="display:flex; align-items:center; justify-content:center; gap:8px; background:var(--ink); color:var(--bg); padding:13px; border-radius:11px; font-family:'Geist',sans-serif; font-size:14px; font-weight:600; text-decoration:none; transition:all .18s;"
            >
              Probar {herramientaPrincipal?.nombre ?? 'ahora'} →
            </a>
          )}
          {(afiliado ?? herramientaPrincipal?.url) && (
            <p style="margin:12px 0 0; font-family:'Geist Mono',monospace; font-size:10.5px; line-height:1.5; color:var(--muted); text-align:center;">Enlace de afiliado. No afecta a tu precio.</p>
          )}
        </div>
      )}

      {herramientas.length > 0 && (
        <div style="background:var(--surface); border:1px solid var(--border); border-radius:18px; padding:22px;">
          <h4 style="margin:0 0 14px; font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.1em; text-transform:uppercase; color:var(--muted); font-weight:500;">Herramientas analizadas</h4>
          <div style="display:flex; flex-direction:column; gap:10px;">
            {herramientas.map((h) => (
              <span style="font-size:14px; color:var(--ink2);">{h}</span>
            ))}
          </div>
        </div>
      )}
    </aside>
  </div>

  <!-- Related articles -->
  {relacionados.length > 0 && (
    <section class="art-related">
      <h2 style="margin:0 0 28px; font-family:'Newsreader',serif; font-weight:500; font-size:30px; letter-spacing:-0.02em; color:var(--ink);">Sigue leyendo</h2>
      <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:24px;">
        {relacionados.map((a) => (
          <a href={`/blog/${a.slug}`} style="display:block; text-decoration:none;">
            <article class="related-card" style="background:var(--surface); border:1px solid var(--border); border-radius:16px; padding:12px; height:100%; transition:all .2s;">
              {a.data.imagen ? (
                <img
                  src={a.data.imagen}
                  alt={a.data.title}
                  style="width:100%; height:150px; object-fit:cover; border-radius:11px; border:1px solid var(--border); display:block;"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div style="border-radius:11px; background-image:repeating-linear-gradient(135deg,var(--stripe-a),var(--stripe-a) 11px,var(--stripe-b) 11px,var(--stripe-b) 22px); border:1px solid var(--border); height:150px;" aria-hidden="true"></div>
              )}
              <div style="padding:16px 10px 10px;">
                <span style="font-size:11px; font-weight:600; color:var(--accent); background:var(--accent-tint); padding:4px 9px; border-radius:6px;">{CATEGORIA_LABELS[a.data.category]}</span>
                <h3 style="margin:12px 0 0; font-family:'Newsreader',serif; font-weight:500; font-size:20px; line-height:1.2; color:var(--ink);">{a.data.title}</h3>
              </div>
            </article>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Newsletter CTA -->
  <section class="art-newsletter">
    <div style="background:var(--surface); border:1px solid var(--border); border-radius:22px; padding:48px; text-align:center;">
      <h2 style="margin:0; font-family:'Newsreader',serif; font-weight:500; font-size:32px; letter-spacing:-0.02em; color:var(--ink);">¿Te ha sido útil esta review?</h2>
      <p style="margin:12px auto 24px; font-size:16px; line-height:1.6; color:var(--ink2); max-width:420px;">Recibe cada semana análisis honestos como este, directos a tu correo.</p>
      <a
        href="/#newsletter"
        style="display:inline-flex; align-items:center; gap:8px; background:var(--ink); color:var(--bg); padding:14px 24px; border-radius:11px; font-family:'Geist',sans-serif; font-size:15px; font-weight:600; text-decoration:none; transition:all .18s;"
      >
        Suscribirme a la newsletter →
      </a>
    </div>
  </section>
</Layout>

<style>
  /* Layout containers */
  .art-header {
    max-width: 760px;
    margin: 0 auto;
    padding-top: 48px;
    padding-inline: clamp(20px, 5vw, 32px);
  }
  .art-hero {
    max-width: 1000px;
    margin: 36px auto 0;
    padding-inline: clamp(20px, 5vw, 32px);
  }
  .art-grid {
    max-width: 1080px;
    margin: 0 auto;
    padding-top: 56px;
    padding-inline: clamp(20px, 5vw, 32px);
    display: grid;
    grid-template-columns: minmax(0, 1fr) 300px;
    gap: 60px;
    align-items: start;
  }
  .art-sidebar {
    position: sticky;
    top: 92px;
    align-self: start;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .art-related {
    max-width: 1080px;
    margin: 0 auto;
    padding-top: 72px;
    padding-bottom: 40px;
    padding-inline: clamp(20px, 5vw, 32px);
  }
  .art-newsletter {
    max-width: 1080px;
    margin: 0 auto;
    padding-top: 24px;
    padding-bottom: 80px;
    padding-inline: clamp(20px, 5vw, 32px);
  }

  /* Prose base */
  :global(.article-prose) {
    font-size: 17.5px;
    line-height: 1.78;
    color: var(--ink2);
    min-width: 0;
    overflow-wrap: break-word;
  }

  /* Drop cap on first paragraph */
  :global(.article-prose > p:first-of-type::first-letter) {
    font-family: 'Newsreader', serif;
    font-size: 62px;
    line-height: 0.82;
    font-weight: 600;
    color: var(--ink);
    float: left;
    padding: 6px 12px 0 0;
  }

  /* Headings */
  :global(.article-prose h1) {
    margin: 44px 0 16px;
    font-family: 'Newsreader', serif;
    font-weight: 500;
    font-size: 30px;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  :global(.article-prose h2) {
    margin: 44px 0 16px;
    font-family: 'Newsreader', serif;
    font-weight: 500;
    font-size: 30px;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  :global(.article-prose h3) {
    margin: 36px 0 14px;
    font-family: 'Newsreader', serif;
    font-weight: 500;
    font-size: 24px;
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--ink);
  }
  :global(.article-prose h4) {
    margin: 28px 0 12px;
    font-family: 'Geist', sans-serif;
    font-weight: 600;
    font-size: 18px;
    color: var(--ink);
  }

  /* Paragraphs */
  :global(.article-prose p) {
    margin: 0 0 24px;
    color: var(--ink2);
  }

  /* Links */
  :global(.article-prose a) {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--accent) 40%, transparent);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.15s;
  }
  :global(.article-prose a:hover) {
    text-decoration-color: var(--accent);
  }

  /* Emphasis */
  :global(.article-prose strong) { color: var(--ink); font-weight: 600; }
  :global(.article-prose em) { font-style: italic; }

  /* Lists */
  :global(.article-prose ul),
  :global(.article-prose ol) {
    margin: 0 0 24px;
    padding-left: 1.6em;
    color: var(--ink2);
  }
  :global(.article-prose li) {
    margin-bottom: 8px;
    line-height: 1.65;
  }
  :global(.article-prose li::marker) { color: var(--accent); }

  /* Blockquote */
  :global(.article-prose blockquote) {
    margin: 36px 0;
    padding: 28px 32px;
    border-left: 3px solid var(--accent);
    background: var(--surface);
    border-radius: 0 12px 12px 0;
  }
  :global(.article-prose blockquote p) {
    margin: 0;
    font-family: 'Newsreader', serif;
    font-style: italic;
    font-size: 24px;
    line-height: 1.4;
    color: var(--ink);
  }

  /* Code inline */
  :global(.article-prose :not(pre) > code) {
    font-family: 'Geist Mono', monospace;
    font-size: 0.85em;
    background: var(--code-bg);
    border: 1px solid var(--code-border);
    border-radius: 5px;
    padding: 2px 6px;
    color: var(--ink);
  }

  /* Code block — Shiki controla el background via inline style;
     solo sobreescribimos border, radio, padding y spacing */
  :global(.article-prose pre.astro-code) {
    border: 1px solid var(--code-border);
    border-radius: 12px;
    padding: 24px;
    overflow-x: auto;
    margin: 0 0 28px;
  }
  :global(.article-prose pre.astro-code code) {
    background: none !important;
    border: none;
    padding: 0;
    font-size: 14px;
    line-height: 1.65;
  }
  /* Activa el tema oscuro de Shiki cuando html.dark está activo */
  :global(html.dark .astro-code),
  :global(html.dark .astro-code span) {
    color: var(--shiki-dark) !important;
    background-color: var(--shiki-dark-bg) !important;
    font-style: var(--shiki-dark-font-style) !important;
    font-weight: var(--shiki-dark-font-weight) !important;
    text-decoration: var(--shiki-dark-text-decoration) !important;
  }

  /* Horizontal rule */
  :global(.article-prose hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 48px 0;
  }

  /* Inline images */
  :global(.article-prose img) {
    width: 100%;
    border-radius: 12px;
    border: 1px solid var(--border);
    margin: 8px 0 24px;
    display: block;
  }

  /* Related card hover */
  .related-card:hover {
    box-shadow: 0 14px 32px var(--shadow);
    transform: translateY(-3px);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .art-grid {
      grid-template-columns: 1fr !important;
    }
    .art-sidebar {
      position: static !important;
    }
  }
  @media (max-width: 640px) {
    :global(.article-prose > p:first-of-type::first-letter) {
      font-size: 48px;
    }
    :global(.article-prose blockquote p) {
      font-size: 20px;
    }
  }
</style>
