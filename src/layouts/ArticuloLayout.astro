---
import Layout from './Layout.astro';
import FeedbackArticulo from '../components/FeedbackArticulo.astro';
import { CATEGORIA_LABELS } from '../content/config';
import type { Categoria } from '../content/config';
import { herramientas as herramientasData } from '../data/herramientas';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description: string;
  date: Date;
  dateModified?: Date;
  category: Categoria;
  herramientas: string[];
  afiliado?: string;
  imagen?: string;
  faqs?: Array<{ pregunta: string; respuesta: string }>;
  ratings?: Array<{ label: string; score: number }>;
  minutosLectura?: number;
}

const { title, description, date, dateModified, category, herramientas, afiliado, imagen, faqs, ratings, minutosLectura } = Astro.props;
const siteUrl = (import.meta.env.SITE_URL || Astro.site?.toString() || 'https://iaenespanol.es').replace(/\/$/, '');

const dateFormatted = date
  .toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' })
  .toUpperCase()
  .replace('.', '');

const dateModifiedFormatted = dateModified
  ? dateModified
      .toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' })
      .toUpperCase()
      .replace('.', '')
  : null;

// Buscar herramienta principal respetando el orden del frontmatter (el primero que matchee gana)
const herramientaPrincipal: (typeof herramientasData)[0] | null = (() => {
  for (const n of herramientas) {
    const found = herramientasData.find(
      (h) =>
        n.toLowerCase().includes(h.nombre.toLowerCase()) ||
        h.nombre.toLowerCase().includes(n.toLowerCase().split(' ')[0])
    );
    if (found) return found;
  }
  return null;
})();
const score = herramientaPrincipal ? herramientaPrincipal.rating * 2 : null;

// Artículos relacionados (misma categoría, excluye el actual)
const todos = await getCollection('blog', ({ data }) => !data.draft);
const relacionados = todos
  .filter((a) => a.data.category === category && a.data.title !== title)
  .slice(0, 3);
---

<Layout
  title={title}
  description={description}
  image={imagen}
  article
  publishDate={date}
  dateModified={dateModified}
>
  <div id="reading-progress" aria-hidden="true"></div>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Inicio', item: siteUrl },
      { '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteUrl}/blog` },
      { '@type': 'ListItem', position: 3, name: title, item: `${siteUrl}${Astro.url.pathname}` },
    ],
  })} />
  {faqs && faqs.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqs.map((faq) => ({
        '@type': 'Question',
        name: faq.pregunta,
        acceptedAnswer: { '@type': 'Answer', text: faq.respuesta },
      })),
    })} />
  )}

  <!-- Article header -->
  <div class="art-header">
    <nav aria-label="Migas de pan" style="display:flex; align-items:center; gap:8px; font-family:'Geist Mono',monospace; font-size:12px; color:var(--muted); margin-bottom:28px;">
      <a href="/blog" style="color:var(--ink3); text-decoration:none;">Blog</a>
      <span>/</span>
      <span style="color:var(--accent);">{CATEGORIA_LABELS[category]}</span>
    </nav>

    <div style="display:flex; align-items:center; gap:10px; margin-bottom:20px;">
      <span style="font-size:12px; font-weight:600; color:var(--accent); background:var(--accent-tint); padding:5px 11px; border-radius:7px;">{CATEGORIA_LABELS[category]}</span>
      <time
        datetime={date.toISOString()}
        style="font-family:'Geist Mono',monospace; font-size:12px; color:var(--muted);"
      >
        {dateModified ? 'Actualizado · ' : ''}{dateModified ? dateModifiedFormatted : dateFormatted}
      </time>
    </div>

    <h1 style="margin:0; font-family:'Newsreader',serif; font-weight:500; font-size:clamp(2rem,4.5vw,3.125rem); line-height:1.08; letter-spacing:-0.025em; color:var(--ink);">{title}</h1>
    <p style="margin:22px 0 0; font-size:20px; line-height:1.55; color:var(--ink2);">{description}</p>

    <div style="display:flex; align-items:center; gap:14px; margin-top:30px; padding-bottom:36px; border-bottom:1px solid var(--border);">
      <img src="/images/sergio.jpg" alt="Sergio Ruiz" width="42" height="42" style="width:42px; height:42px; flex-shrink:0; border-radius:50%; object-fit:cover; object-position:center top; border:1px solid var(--border);" />
      <div>
        <div style="font-size:14px; font-weight:600; color:var(--ink);">Por Sergio Ruiz</div>
        <div style="font-family:'Geist Mono',monospace; font-size:12px; color:var(--muted); margin-top:2px;">
          {minutosLectura ? `${minutosLectura} min de lectura` : 'Probado en profundidad'}
          {dateModified ? ` · Actualizado ${dateModifiedFormatted}` : ''}
        </div>
      </div>
    </div>
  </div>

  <!-- Hero image -->
  <div class="art-hero">
    {imagen ? (
      <img
        src={imagen}
        alt={title}
        width="1200"
        height="675"
        style="width:100%; border-radius:18px; border:1px solid var(--border); aspect-ratio:16/9; object-fit:cover; display:block;"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    ) : (
      <div style="border-radius:18px; background-image:repeating-linear-gradient(135deg,var(--stripe-a),var(--stripe-a) 14px,var(--stripe-b) 14px,var(--stripe-b) 28px); border:1px solid var(--border); height:380px; display:flex; align-items:center; justify-content:center;" aria-hidden="true">
        <span style="font-family:'Geist Mono',monospace; font-size:13px; color:var(--muted);">[ imagen de portada ]</span>
      </div>
    )}
  </div>

  <!-- Table of contents (desktop only, auto-generated from H2s) -->
  <div id="toc-container"></div>

  <!-- Table of contents (mobile accordion, auto-generated from H2s) -->
  <div id="toc-mobile"></div>

  <!-- Body: prose + sidebar -->
  <div class="art-grid">
    <article class="article-prose">
      <slot />
      <FeedbackArticulo />
    </article>

    <aside class="art-sidebar">
      {ratings && ratings.length > 0 && score !== null && (
        <div style="background:var(--surface); border:1px solid var(--border); border-radius:18px; padding:24px; box-shadow:0 1px 2px var(--shadow), 0 12px 28px var(--shadow);">
          <div style="display:flex; align-items:baseline; gap:8px; margin-bottom:4px;">
            <span style="font-family:'Newsreader',serif; font-size:52px; font-weight:600; line-height:1; color:var(--ink);">{score.toFixed(1)}</span>
            <span style="font-family:'Geist Mono',monospace; font-size:13px; color:var(--muted);">/ 10</span>
          </div>
          <div style="font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:var(--accent); margin-bottom:22px;">Veredicto IA en Español</div>

          {ratings && ratings.length > 0 && (
            <div style="display:flex; flex-direction:column; gap:16px; margin-bottom:22px;">
              {ratings.map((rt) => (
                <div>
                  <div style="display:flex; justify-content:space-between; margin-bottom:7px;">
                    <span style="font-size:13px; font-weight:500; color:var(--ink2);">{rt.label}</span>
                    <span style="font-family:'Geist Mono',monospace; font-size:12px; color:var(--ink);">{rt.score.toFixed(1)}<span style="color:var(--muted)"> / 10</span></span>
                  </div>
                  <div style="height:6px; border-radius:99px; background:var(--hover); overflow:hidden;">
                    <div style={`height:100%; width:${rt.score * 10}%; background:var(--accent); border-radius:99px;`}></div>
                  </div>
                </div>
              ))}
            </div>
          )}

          {(afiliado ?? herramientaPrincipal?.url) && (
            <a
              href={afiliado ?? herramientaPrincipal!.url}
              target="_blank"
              rel="noopener noreferrer nofollow"
              style="display:flex; align-items:center; justify-content:center; gap:8px; background:var(--ink); color:var(--bg); padding:13px; border-radius:11px; font-family:'Geist',sans-serif; font-size:14px; font-weight:600; text-decoration:none; transition:all .18s;"
            >
              Probar {herramientaPrincipal?.nombre ?? 'ahora'} →
            </a>
          )}
          {(afiliado ?? herramientaPrincipal?.url) && (
            <p style="margin:12px 0 0; font-family:'Geist Mono',monospace; font-size:10.5px; line-height:1.5; color:var(--muted); text-align:center;">Enlace de afiliado. No afecta a tu precio.</p>
          )}
        </div>
      )}

      {herramientas.length > 0 && (
        <div style="background:var(--surface); border:1px solid var(--border); border-radius:18px; padding:22px;">
          <h4 style="margin:0 0 14px; font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.1em; text-transform:uppercase; color:var(--muted); font-weight:500;">Herramientas analizadas</h4>
          <div style="display:flex; flex-direction:column; gap:10px;">
            {herramientas.map((h) => (
              <span style="font-size:14px; color:var(--ink2);">{h}</span>
            ))}
          </div>
        </div>
      )}
    </aside>
  </div>

  <!-- Share buttons -->
  <div class="art-share">
    <span class="share-label">Compartir</span>
    <div class="share-btns">
      <a
        href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(siteUrl + Astro.url.pathname)}`}
        target="_blank"
        rel="noopener noreferrer"
        class="share-btn share-btn--x"
        aria-label="Compartir en X"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.259 5.629 5.905-5.629Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        X
      </a>
      <a
        href={`https://wa.me/?text=${encodeURIComponent(title + ' — ' + siteUrl + Astro.url.pathname)}`}
        target="_blank"
        rel="noopener noreferrer"
        class="share-btn share-btn--wa"
        aria-label="Compartir en WhatsApp"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a13 13 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
        WhatsApp
      </a>
      <button class="share-btn share-btn--copy" id="share-copy-btn" data-url={siteUrl + Astro.url.pathname} aria-label="Copiar enlace">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
        <span id="share-copy-label">Copiar enlace</span>
      </button>
    </div>
  </div>

  <!-- Related articles -->
  {relacionados.length > 0 && (
    <section class="art-related">
      <h2 style="margin:0 0 28px; font-family:'Newsreader',serif; font-weight:500; font-size:30px; letter-spacing:-0.02em; color:var(--ink);">Sigue leyendo</h2>
      <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:24px;">
        {relacionados.map((a) => (
          <a href={`/blog/${a.slug}`} style="display:block; text-decoration:none;">
            <article class="related-card" style="background:var(--surface); border:1px solid var(--border); border-radius:16px; padding:12px; height:100%; transition:all .2s;">
              {a.data.imagen ? (
                <img
                  src={a.data.imagen}
                  alt={a.data.title}
                  style="width:100%; height:150px; object-fit:cover; border-radius:11px; border:1px solid var(--border); display:block;"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div style="border-radius:11px; background-image:repeating-linear-gradient(135deg,var(--stripe-a),var(--stripe-a) 11px,var(--stripe-b) 11px,var(--stripe-b) 22px); border:1px solid var(--border); height:150px;" aria-hidden="true"></div>
              )}
              <div style="padding:16px 10px 10px;">
                <span style="font-size:11px; font-weight:600; color:var(--accent); background:var(--accent-tint); padding:4px 9px; border-radius:6px;">{CATEGORIA_LABELS[a.data.category]}</span>
                <h3 style="margin:12px 0 0; font-family:'Newsreader',serif; font-weight:500; font-size:20px; line-height:1.2; color:var(--ink);">{a.data.title}</h3>
              </div>
            </article>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Newsletter CTA -->
  <section class="art-newsletter">
    <div style="background:var(--surface); border:1px solid var(--border); border-radius:22px; padding:48px; text-align:center;">
      <h2 style="margin:0; font-family:'Newsreader',serif; font-weight:500; font-size:32px; letter-spacing:-0.02em; color:var(--ink);">¿Te ha sido útil esta review?</h2>
      <p style="margin:12px auto 24px; font-size:16px; line-height:1.6; color:var(--ink2); max-width:420px;">Recibe cada semana análisis honestos como este, directos a tu correo.</p>
      <a
        href="/#newsletter"
        style="display:inline-flex; align-items:center; gap:8px; background:var(--ink); color:var(--bg); padding:14px 24px; border-radius:11px; font-family:'Geist',sans-serif; font-size:15px; font-weight:600; text-decoration:none; transition:all .18s;"
      >
        Suscribirme a la newsletter →
      </a>
    </div>
  </section>
</Layout>

<style>
  /* Reading progress bar */
  #reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 3px;
    width: 0%;
    background: var(--accent);
    z-index: 51;
    transition: width 0.1s linear;
    pointer-events: none;
    border-radius: 0 2px 2px 0;
  }

  /* Layout containers */
  .art-header {
    max-width: 760px;
    margin: 0 auto;
    padding-top: 48px;
    padding-inline: clamp(20px, 5vw, 32px);
  }
  .art-hero {
    max-width: 1000px;
    margin: 36px auto 0;
    padding-inline: clamp(20px, 5vw, 32px);
  }
  .art-grid {
    max-width: 1080px;
    margin: 0 auto;
    padding-top: 56px;
    padding-inline: clamp(20px, 5vw, 32px);
    display: grid;
    grid-template-columns: minmax(0, 1fr) 300px;
    gap: 60px;
    align-items: start;
  }
  .art-sidebar {
    position: sticky;
    top: 92px;
    align-self: start;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .art-related {
    max-width: 1080px;
    margin: 0 auto;
    padding-top: 72px;
    padding-bottom: 40px;
    padding-inline: clamp(20px, 5vw, 32px);
  }
  .art-newsletter {
    max-width: 1080px;
    margin: 0 auto;
    padding-top: 24px;
    padding-bottom: 80px;
    padding-inline: clamp(20px, 5vw, 32px);
  }

  /* Prose base */
  :global(.article-prose) {
    font-size: 17.5px;
    line-height: 1.78;
    color: var(--ink2);
    min-width: 0;
    overflow-wrap: break-word;
  }

  /* Drop cap on first paragraph */
  :global(.article-prose > p:first-of-type::first-letter) {
    font-family: 'Newsreader', serif;
    font-size: 62px;
    line-height: 0.82;
    font-weight: 600;
    color: var(--ink);
    float: left;
    padding: 6px 12px 0 0;
  }

  /* Headings */
  :global(.article-prose h1) {
    margin: 44px 0 16px;
    font-family: 'Newsreader', serif;
    font-weight: 500;
    font-size: 30px;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  :global(.article-prose h2) {
    margin: 44px 0 16px;
    font-family: 'Newsreader', serif;
    font-weight: 500;
    font-size: 30px;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  :global(.article-prose h3) {
    margin: 36px 0 14px;
    font-family: 'Newsreader', serif;
    font-weight: 500;
    font-size: 24px;
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--ink);
  }
  :global(.article-prose h4) {
    margin: 28px 0 12px;
    font-family: 'Geist', sans-serif;
    font-weight: 600;
    font-size: 18px;
    color: var(--ink);
  }

  /* Paragraphs */
  :global(.article-prose p) {
    margin: 0 0 24px;
    color: var(--ink2);
  }

  /* Links */
  :global(.article-prose a) {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--accent) 40%, transparent);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.15s;
  }
  :global(.article-prose a:hover) {
    text-decoration-color: var(--accent);
  }

  /* Emphasis */
  :global(.article-prose strong) { color: var(--ink); font-weight: 600; }
  :global(.article-prose em) { font-style: italic; }

  /* Lists */
  :global(.article-prose ul),
  :global(.article-prose ol) {
    margin: 0 0 24px;
    padding-left: 1.6em;
    color: var(--ink2);
  }
  :global(.article-prose li) {
    margin-bottom: 8px;
    line-height: 1.65;
  }
  :global(.article-prose li::marker) { color: var(--accent); }

  /* Blockquote */
  :global(.article-prose blockquote) {
    margin: 36px 0;
    padding: 28px 32px;
    border-left: 3px solid var(--accent);
    background: var(--surface);
    border-radius: 0 12px 12px 0;
  }
  :global(.article-prose blockquote p) {
    margin: 0;
    font-family: 'Newsreader', serif;
    font-style: italic;
    font-size: 24px;
    line-height: 1.4;
    color: var(--ink);
  }

  /* Code inline */
  :global(.article-prose :not(pre) > code) {
    font-family: 'Geist Mono', monospace;
    font-size: 0.85em;
    background: var(--code-bg);
    border: 1px solid var(--code-border);
    border-radius: 5px;
    padding: 2px 6px;
    color: var(--ink);
  }

  /* Code block — Shiki controla el background via inline style;
     solo sobreescribimos border, radio, padding y spacing */
  :global(.article-prose pre.astro-code) {
    border: 1px solid var(--code-border);
    border-radius: 12px;
    padding: 24px;
    overflow-x: auto;
    margin: 0 0 28px;
  }
  :global(.article-prose pre.astro-code code) {
    background: none !important;
    border: none;
    padding: 0;
    font-size: 14px;
    line-height: 1.65;
  }
  /* Activa el tema oscuro de Shiki cuando html.dark está activo */
  :global(html.dark .astro-code),
  :global(html.dark .astro-code span) {
    color: var(--shiki-dark) !important;
    background-color: var(--shiki-dark-bg) !important;
    font-style: var(--shiki-dark-font-style) !important;
    font-weight: var(--shiki-dark-font-weight) !important;
    text-decoration: var(--shiki-dark-text-decoration) !important;
  }

  /* Horizontal rule */
  :global(.article-prose hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 48px 0;
  }

  /* Inline images */
  :global(.article-prose img) {
    width: 100%;
    border-radius: 12px;
    border: 1px solid var(--border);
    margin: 8px 0 24px;
    display: block;
  }

  /* Tables */
  :global(.article-prose table) {
    width: 100%;
    border-collapse: collapse;
    margin: 0 0 28px;
    font-size: 15px;
    line-height: 1.5;
    min-width: 0;
    overflow-wrap: break-word;
  }
  :global(.article-prose thead tr) {
    background: var(--surface);
    border-bottom: 2px solid var(--border);
  }
  :global(.article-prose th) {
    padding: 11px 14px;
    text-align: left;
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }
  :global(.article-prose td) {
    padding: 11px 14px;
    color: var(--ink2);
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }
  :global(.article-prose tbody tr:last-child td) {
    border-bottom: none;
  }
  :global(.article-prose tbody tr:hover td) {
    background: var(--hover);
  }
  :global(.article-prose td strong) {
    color: var(--ink);
  }

  /* Share buttons */
  .art-share {
    max-width: 1080px;
    margin: 0 auto;
    padding-top: 40px;
    padding-bottom: 8px;
    padding-inline: clamp(20px, 5vw, 32px);
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .share-label {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 500;
    white-space: nowrap;
  }
  .share-btns {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 13px;
    border-radius: 8px;
    font-family: 'Geist', sans-serif;
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--ink2);
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .share-btn:hover {
    background: var(--hover);
    color: var(--ink);
    border-color: var(--border2);
  }
  .share-btn--x:hover  { color: #000; border-color: #000; }
  :global(html.dark) .share-btn--x:hover { color: #fff; border-color: #fff; }
  .share-btn--wa:hover { color: #25d366; border-color: #25d366; }
  .share-btn--copy { font-family: inherit; }
  .share-btn--copy.copied { color: var(--good); border-color: var(--good); background: color-mix(in srgb, var(--good) 10%, transparent); }

  /* Related card hover */
  .related-card:hover {
    box-shadow: 0 14px 32px var(--shadow);
    transform: translateY(-3px);
  }

  /* TOC above article */
  #toc-container {
    max-width: 1080px;
    margin: 28px auto 0;
    padding-inline: clamp(20px, 5vw, 32px);
  }

  /* TOC móvil */
  #toc-mobile {
    display: none;
    max-width: 1080px;
    margin: 20px auto 0;
    padding-inline: clamp(20px, 5vw, 32px);
  }
  #toc-mobile details summary::-webkit-details-marker { display: none; }
  #toc-mobile details summary { list-style: none; }
  #toc-mobile details[open] .toc-chevron { transform: rotate(90deg); }
  .toc-chevron { transition: transform 0.2s ease; display: inline-block; }

  /* Responsive */
  @media (max-width: 900px) {
    .art-grid {
      grid-template-columns: 1fr !important;
    }
    .art-sidebar {
      position: static !important;
    }
    #toc-container {
      display: none;
    }
    #toc-mobile {
      display: block;
    }
  }
  @media (max-width: 640px) {
    :global(.article-prose > p:first-of-type::first-letter) {
      font-size: 48px;
    }
    :global(.article-prose blockquote p) {
      font-size: 20px;
    }
  }
</style>

<script>
// Reading progress bar
(function () {
  const bar = document.getElementById('reading-progress');
  const article = document.querySelector('.article-prose');
  if (!bar || !article) return;

  function update() {
    const articleTop = article.getBoundingClientRect().top + window.scrollY;
    const articleBottom = articleTop + article.offsetHeight;
    const scrolled = window.scrollY - articleTop;
    const total = articleBottom - articleTop - window.innerHeight;
    bar.style.width = Math.min(100, Math.max(0, (scrolled / total) * 100)) + '%';
  }

  window.addEventListener('scroll', update, { passive: true });
  update();
})();

// Copy link button
(function () {
  const btn = document.getElementById('share-copy-btn');
  const label = document.getElementById('share-copy-label');
  if (!btn || !label) return;
  btn.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(btn.dataset.url);
    } catch {
      const ta = document.createElement('textarea');
      ta.value = btn.dataset.url;
      ta.style.cssText = 'position:fixed;left:-9999px';
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
    }
    label.textContent = '¡Copiado!';
    btn.classList.add('copied');
    setTimeout(() => { label.textContent = 'Copiar enlace'; btn.classList.remove('copied'); }, 2000);
  });
})();

// TOC
(function () {
  const prose = document.querySelector('.article-prose');
  const container = document.getElementById('toc-container');
  if (!prose || !container) return;

  const headings = Array.from(prose.querySelectorAll('h2'));
  if (headings.length < 5) return;

  // Assign IDs to headings
  headings.forEach((h, i) => {
    if (!h.id) {
      const slug = h.textContent.trim()
        .toLowerCase()
        .normalize('NFD').replace(/[̀-ͯ]/g, '')
        .replace(/[^a-z0-9\s-]/g, '')
        .replace(/\s+/g, '-')
        .replace(/-+/g, '-')
        .replace(/^-|-$/g, '') || `seccion-${i}`;
      h.id = slug;
    }
  });

  // Build TOC nav
  const nav = document.createElement('nav');
  nav.setAttribute('aria-label', 'Tabla de contenidos');
  nav.style.cssText = 'background:var(--surface); border:1px solid var(--border); border-radius:14px; padding:20px 24px;';

  const label = document.createElement('p');
  label.textContent = 'En este artículo';
  label.style.cssText = 'margin:0 0 14px; font-family:"Geist Mono",monospace; font-size:11px; letter-spacing:0.1em; text-transform:uppercase; color:var(--muted); font-weight:500;';
  nav.appendChild(label);

  const ol = document.createElement('ol');
  ol.style.cssText = 'margin:0; padding:0; list-style:none; display:flex; flex-direction:column; gap:2px;';

  headings.forEach((h) => {
    const li = document.createElement('li');
    const a = document.createElement('a');
    a.href = `#${h.id}`;
    a.textContent = h.textContent.replace(/[#]+$/, '').trim();
    a.dataset.tocId = h.id;
    a.style.cssText = 'display:block; font-size:14px; line-height:1.4; color:var(--ink2); text-decoration:none; padding:6px 10px; border-radius:7px; border-left:2px solid transparent; transition:color .15s, background .15s, border-color .15s;';
    li.appendChild(a);
    ol.appendChild(li);
  });

  nav.appendChild(ol);
  container.appendChild(nav);

  // Hover styles
  ol.addEventListener('mouseover', e => {
    const a = e.target.closest('a[data-toc-id]');
    if (a) { a.style.color = 'var(--accent)'; a.style.borderLeftColor = 'var(--accent)'; a.style.background = 'var(--accent-tint)'; }
  });
  ol.addEventListener('mouseout', e => {
    const a = e.target.closest('a[data-toc-id]');
    if (a) { a.style.color = 'var(--ink2)'; a.style.borderLeftColor = 'transparent'; a.style.background = 'transparent'; }
  });

  // Smooth scroll with offset for sticky header
  ol.addEventListener('click', e => {
    const a = e.target.closest('a[data-toc-id]');
    if (!a) return;
    e.preventDefault();
    const target = document.getElementById(a.dataset.tocId);
    if (!target) return;
    const y = target.getBoundingClientRect().top + window.scrollY - 96;
    window.scrollTo({ top: y, behavior: 'smooth' });
  });

  // Mobile accordion TOC
  const mobileContainer = document.getElementById('toc-mobile');
  if (mobileContainer) {
    const details = document.createElement('details');
    details.style.cssText = 'background:var(--surface); border:1px solid var(--border); border-radius:14px; overflow:hidden;';

    const summary = document.createElement('summary');
    summary.style.cssText = 'padding:14px 18px; font-family:"Geist Mono",monospace; font-size:11px; letter-spacing:0.1em; text-transform:uppercase; color:var(--ink); font-weight:600; cursor:pointer; display:flex; justify-content:space-between; align-items:center; user-select:none;';

    const labelSpan = document.createElement('span');
    labelSpan.textContent = 'En este artículo';

    const chevron = document.createElement('span');
    chevron.className = 'toc-chevron';
    chevron.textContent = '›';
    chevron.style.cssText = 'font-size:20px; color:var(--muted); line-height:1;';

    summary.appendChild(labelSpan);
    summary.appendChild(chevron);

    const body = document.createElement('div');
    body.style.cssText = 'padding:4px 14px 14px; border-top:1px solid var(--border);';

    const olMobile = document.createElement('ol');
    olMobile.style.cssText = 'margin:0; padding:0; list-style:none; display:flex; flex-direction:column; gap:1px;';

    headings.forEach((h) => {
      const li = document.createElement('li');
      const a = document.createElement('a');
      a.href = `#${h.id}`;
      a.textContent = h.textContent.replace(/[#]+$/, '').trim();
      a.dataset.tocId = h.id;
      a.style.cssText = 'display:block; font-size:14px; line-height:1.4; color:var(--ink2); text-decoration:none; padding:7px 10px; border-radius:7px; border-left:2px solid transparent; transition:color .15s, background .15s, border-color .15s;';
      li.appendChild(a);
      olMobile.appendChild(li);
    });

    olMobile.addEventListener('mouseover', e => {
      const a = e.target.closest('a[data-toc-id]');
      if (a) { a.style.color = 'var(--accent)'; a.style.borderLeftColor = 'var(--accent)'; a.style.background = 'var(--accent-tint)'; }
    });
    olMobile.addEventListener('mouseout', e => {
      const a = e.target.closest('a[data-toc-id]');
      if (a) { a.style.color = 'var(--ink2)'; a.style.borderLeftColor = 'transparent'; a.style.background = 'transparent'; }
    });

    olMobile.addEventListener('click', e => {
      const a = e.target.closest('a[data-toc-id]');
      if (!a) return;
      e.preventDefault();
      const target = document.getElementById(a.dataset.tocId);
      if (!target) return;
      details.removeAttribute('open');
      const y = target.getBoundingClientRect().top + window.scrollY - 96;
      window.scrollTo({ top: y, behavior: 'smooth' });
    });

    body.appendChild(olMobile);
    details.appendChild(summary);
    details.appendChild(body);
    mobileContainer.appendChild(details);
  }
})();
</script>
