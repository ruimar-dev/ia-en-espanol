---
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
---

{!compact ? (
  <div class="newsletter-container bg-gradient-to-br from-[#7C3AED]/5 to-[#5B21B6]/10 dark:from-[#7C3AED]/10 dark:to-[#5B21B6]/20 rounded-3xl p-8 sm:p-10 border border-[#7C3AED]/20">
    <div class="max-w-xl mx-auto text-center">
      <span class="inline-block bg-[#7C3AED]/10 text-[#7C3AED] text-xs font-semibold px-3 py-1 rounded-full mb-4 uppercase tracking-wider">
        Newsletter
      </span>
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">
        Mantente al día con la IA
      </h2>
      <p class="text-gray-600 dark:text-gray-400 text-sm mb-6">
        Reviews, comparativas y guías directamente en tu bandeja. Sin spam.
      </p>

      <form class="newsletter-form flex flex-col sm:flex-row gap-3">
        <input
          type="email"
          class="newsletter-email flex-1 px-4 py-3 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-[#111] text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#7C3AED]/50 focus:border-[#7C3AED] transition-all text-sm"
          placeholder="tu@email.com"
          required
        />
        <button
          type="submit"
          class="newsletter-btn inline-flex items-center justify-center gap-2 bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-semibold px-5 py-3 rounded-xl transition-colors text-sm whitespace-nowrap disabled:opacity-60 disabled:cursor-not-allowed"
        >
          <span class="newsletter-btn-text">Suscribirme</span>
          <svg class="newsletter-spinner w-4 h-4 animate-spin hidden" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
        </button>
      </form>

      <p class="newsletter-success hidden text-sm text-green-600 dark:text-green-400 mt-4 font-medium">
        ¡Suscrito! Te avisaremos cuando publiquemos algo nuevo.
      </p>
      <p class="newsletter-error hidden text-sm text-red-500 dark:text-red-400 mt-4"></p>
    </div>
  </div>
) : (
  <div class="newsletter-container">
    <h4 class="font-semibold text-gray-900 dark:text-white mb-3 text-sm uppercase tracking-wider">
      Newsletter
    </h4>
    <p class="text-xs text-gray-500 dark:text-gray-400 mb-3 leading-relaxed">
      Reviews y novedades de IA directo a tu email.
    </p>

    <form class="newsletter-form flex flex-col gap-2">
      <input
        type="email"
        class="newsletter-email w-full px-3 py-2.5 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-[#111] text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#7C3AED]/50 focus:border-[#7C3AED] transition-all text-sm"
        placeholder="tu@email.com"
        required
      />
      <button
        type="submit"
        class="newsletter-btn w-full inline-flex items-center justify-center gap-2 bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-semibold px-4 py-2.5 rounded-lg transition-colors text-sm disabled:opacity-60 disabled:cursor-not-allowed"
      >
        <span class="newsletter-btn-text">Suscribirme</span>
        <svg class="newsletter-spinner w-3.5 h-3.5 animate-spin hidden" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
        </svg>
      </button>
    </form>

    <p class="newsletter-success hidden text-xs text-green-600 dark:text-green-400 mt-2 font-medium">
      ¡Suscrito! Gracias.
    </p>
    <p class="newsletter-error hidden text-xs text-red-500 dark:text-red-400 mt-2"></p>
  </div>
)}

<script>
  document.querySelectorAll<HTMLFormElement>('.newsletter-form').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const container = form.closest<HTMLElement>('.newsletter-container')!;
      const emailInput = form.querySelector<HTMLInputElement>('.newsletter-email')!;
      const btn = form.querySelector<HTMLButtonElement>('.newsletter-btn')!;
      const btnText = form.querySelector<HTMLElement>('.newsletter-btn-text')!;
      const spinner = form.querySelector<HTMLElement>('.newsletter-spinner')!;
      const successMsg = container.querySelector<HTMLElement>('.newsletter-success')!;
      const errorMsg = container.querySelector<HTMLElement>('.newsletter-error')!;

      btn.disabled = true;
      btnText.textContent = 'Enviando...';
      spinner.classList.remove('hidden');
      successMsg.classList.add('hidden');
      errorMsg.classList.add('hidden');

      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: emailInput.value.trim() }),
        });

        const data = await res.json();

        if (res.ok) {
          form.classList.add('hidden');
          successMsg.classList.remove('hidden');
        } else {
          errorMsg.textContent = data.error ?? 'Error al suscribirse. Inténtalo de nuevo.';
          errorMsg.classList.remove('hidden');
          btn.disabled = false;
          btnText.textContent = 'Suscribirme';
          spinner.classList.add('hidden');
        }
      } catch {
        errorMsg.textContent = 'Error de conexión. Inténtalo de nuevo.';
        errorMsg.classList.remove('hidden');
        btn.disabled = false;
        btnText.textContent = 'Suscribirme';
        spinner.classList.add('hidden');
      }
    });
  });
</script>
