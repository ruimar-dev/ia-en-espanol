---
interface Props {
  titulo: string;
  descripcion: string;
  cta: string;
  url: string;
  badge?: string;
}

const { titulo, descripcion, cta, url, badge } = Astro.props;
---

<div style="margin:32px 0; border-radius:16px; background:var(--accent-tint); border:1px solid color-mix(in srgb, var(--accent) 30%, transparent); padding:24px 28px; display:flex; flex-direction:column; gap:16px;" class="banner-afiliado">
  <div style="flex:1;">
    {badge && (
      <span style="display:inline-block; font-family:'Geist Mono',monospace; font-size:11px; font-weight:500; letter-spacing:0.1em; text-transform:uppercase; color:var(--accent); margin-bottom:10px;">{badge}</span>
    )}
    <h3 style="margin:0 0 6px; font-family:'Geist',sans-serif; font-size:17px; font-weight:600; line-height:1.3; color:var(--ink);">{titulo}</h3>
    <p style="margin:0; font-size:14px; line-height:1.6; color:var(--ink2);">{descripcion}</p>
  </div>
  <a
    href={url}
    target="_blank"
    rel="noopener noreferrer sponsored"
    style="align-self:flex-start; display:inline-flex; align-items:center; gap:8px; background:var(--ink); color:var(--bg); padding:11px 20px; border-radius:10px; font-family:'Geist',sans-serif; font-size:14px; font-weight:600; text-decoration:none; transition:all .18s; white-space:nowrap;"
    class="banner-cta"
  >
    {cta}
    <svg style="width:14px; height:14px; flex-shrink:0;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
    </svg>
  </a>
</div>

<style>
  @media (min-width: 560px) {
    .banner-afiliado {
      flex-direction: row !important;
      align-items: center !important;
    }
    .banner-cta {
      align-self: center !important;
      flex-shrink: 0;
    }
  }
  .banner-cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 20px var(--shadow);
  }
</style>
