---
interface Props {
  titulo: string;
  descripcion: string;
  cta: string;
  url: string;
  badge?: string;
}

const { titulo, descripcion, cta, url, badge } = Astro.props;
---

<div class="not-prose my-8 relative overflow-hidden rounded-2xl bg-gradient-to-r from-[#7C3AED] to-[#6D28D9] p-6 text-white">
  <div class="absolute inset-0 opacity-10 pointer-events-none" aria-hidden="true">
    <svg class="w-full h-full" viewBox="0 0 200 100" preserveAspectRatio="xMidYMid slice">
      <circle cx="170" cy="20" r="70" fill="white" />
      <circle cx="30" cy="90" r="50" fill="white" />
    </svg>
  </div>

  <div class="relative flex flex-col sm:flex-row sm:items-center gap-5">
    <div class="flex-1">
      {badge && (
        <span class="inline-block text-xs font-semibold bg-white/20 text-white px-2.5 py-1 rounded-full mb-2">
          {badge}
        </span>
      )}
      <h3 class="font-bold text-lg leading-snug mb-1">{titulo}</h3>
      <p class="text-white/80 text-sm leading-relaxed">{descripcion}</p>
    </div>
    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer sponsored"
      class="flex-shrink-0 inline-flex items-center justify-center gap-2 bg-white text-[#7C3AED] hover:bg-white/90 font-bold px-5 py-2.5 rounded-xl transition-colors text-sm"
    >
      {cta}
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
      </svg>
    </a>
  </div>
</div>
