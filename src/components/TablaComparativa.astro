---
interface Herramienta {
  nombre: string;
  precio: string;
  puntuacion: number;
  idealPara: string;
  enlaceAfiliado?: string;
  badge?: string;
}

interface Props {
  titulo?: string;
  herramientas: Herramienta[];
}

const { titulo, herramientas } = Astro.props;
---

<div style="margin:32px 0; overflow:hidden; border-radius:14px; border:1px solid var(--border);">
  {titulo && (
    <div style="padding:14px 18px; background:var(--surface); border-bottom:1px solid var(--border);">
      <p style="margin:0; font-size:14px; font-weight:600; color:var(--ink);">{titulo}</p>
    </div>
  )}
  <div style="overflow-x:auto;">
    <table style="width:100%; border-collapse:collapse; font-size:14px; min-width:500px;">
      <thead>
        <tr style="background:var(--ink); color:var(--bg); text-align:left;">
          <th style="padding:13px 10px; width:44px;" aria-label="Comparar"></th>
          <th style="padding:13px 18px; font-weight:600; font-size:13px;">Herramienta</th>
          <th style="padding:13px 18px; font-weight:600; font-size:13px;">Precio</th>
          <th style="padding:13px 18px; font-weight:600; font-size:13px;">Puntuación</th>
          <th style="padding:13px 18px; font-weight:600; font-size:13px; display:none;" class="col-ideal">Ideal para</th>
          <th style="padding:13px 18px; font-weight:600; font-size:13px;">Enlace</th>
        </tr>
      </thead>
      <tbody>
        {herramientas.map((h, i) => (
          <tr style={`border-top:1px solid var(--border); background:${i % 2 === 1 ? 'var(--stripe-a)' : 'var(--surface)'};`} class="tabla-row">
            <td style="padding:13px 10px; text-align:center;">
              <button
                class="cmp-btn"
                data-tool={JSON.stringify({
                  nombre: h.nombre,
                  precio: h.precio,
                  puntuacion: h.puntuacion,
                  idealPara: h.idealPara,
                  enlaceAfiliado: h.enlaceAfiliado ?? null,
                  badge: h.badge ?? null,
                })}
                title={`Añadir ${h.nombre} a comparación`}
                aria-label={`Añadir ${h.nombre} a comparación`}
              >
                <span class="cmp-plus" aria-hidden="true">+</span>
                <span class="cmp-check" aria-hidden="true">✓</span>
              </button>
            </td>
            <td style="padding:13px 18px; font-weight:600; color:var(--ink);">
              {h.nombre}
              {h.badge && (
                <span style={`display:inline-block; margin-left:7px; font-size:10px; font-weight:700; padding:2px 7px; border-radius:5px; text-transform:uppercase; letter-spacing:0.06em; vertical-align:middle; background:${/gratis|precio/i.test(h.badge) ? 'var(--good-bg)' : 'var(--accent-tint)'}; color:${/gratis|precio/i.test(h.badge) ? 'var(--good)' : 'var(--accent)'};`}>{h.badge}</span>
              )}
            </td>
            <td style="padding:13px 18px; color:var(--ink2); white-space:nowrap;">{h.precio}</td>
            <td style="padding:13px 18px;">
              <div style="display:flex; align-items:center; gap:4px;" role="img" aria-label={`${h.puntuacion} de 5`}>
                {Array.from({ length: 5 }, (_, j) => (
                  <svg
                    style={`width:14px; height:14px; color:${j < Math.round(h.puntuacion) ? '#fbbf24' : 'var(--border2)'};`}
                    fill="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                  </svg>
                ))}
                <span style="font-family:'Geist Mono',monospace; font-size:12px; color:var(--muted); margin-left:4px;">{h.puntuacion}</span>
              </div>
            </td>
            <td style="padding:13px 18px; color:var(--ink2);" class="col-ideal">{h.idealPara}</td>
            <td style="padding:13px 18px;">
              {h.enlaceAfiliado ? (
                <a
                  href={h.enlaceAfiliado}
                  target="_blank"
                  rel="noopener noreferrer sponsored"
                  style="color:var(--accent); font-weight:600; text-decoration:none; display:inline-flex; align-items:center; gap:4px;"
                >
                  Ver
                  <svg style="width:14px; height:14px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              ) : (
                <span style="color:var(--muted);">—</span>
              )}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>

<style is:global>
  .cmp-btn {
    width: 30px; height: 30px;
    border-radius: 50%;
    border: 2px solid var(--border2);
    background: var(--surface);
    color: var(--muted);
    cursor: pointer;
    font-size: 17px;
    font-weight: 700;
    line-height: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: border-color .15s, background .15s, color .15s;
    padding: 0;
    flex-shrink: 0;
  }
  .cmp-btn:hover:not(:disabled) {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-tint);
  }
  .cmp-btn.is-sel {
    border-color: var(--accent);
    background: var(--accent);
    color: #fff;
  }
  .cmp-btn:disabled { opacity: 0.3; cursor: not-allowed; }
  .cmp-btn .cmp-check { display: none; }
  .cmp-btn.is-sel .cmp-plus { display: none; }
  .cmp-btn.is-sel .cmp-check { display: inline; }
</style>

<style>
  .tabla-row:hover { background: var(--hover) !important; }
  @media (min-width: 640px) { .col-ideal { display: table-cell !important; } }
</style>
