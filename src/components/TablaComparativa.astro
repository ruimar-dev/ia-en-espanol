---
interface Herramienta {
  nombre: string;
  precio: string;
  puntuacion: number;
  idealPara: string;
  enlaceAfiliado?: string;
}

interface Props {
  titulo?: string;
  herramientas: Herramienta[];
}

const { titulo, herramientas } = Astro.props;
---

<div class="my-8 overflow-hidden rounded-2xl border border-gray-200 dark:border-gray-800 not-prose">
  {titulo && (
    <div class="px-5 py-3.5 bg-gray-50 dark:bg-[#111] border-b border-gray-200 dark:border-gray-800">
      <p class="font-semibold text-sm text-gray-700 dark:text-gray-300">{titulo}</p>
    </div>
  )}

  <div class="overflow-x-auto">
    <table class="w-full text-sm min-w-[500px]">
      <thead>
        <tr class="bg-[#7C3AED] text-white text-left">
          <th class="px-4 py-3 font-semibold">Herramienta</th>
          <th class="px-4 py-3 font-semibold">Precio</th>
          <th class="px-4 py-3 font-semibold">Puntuación</th>
          <th class="px-4 py-3 font-semibold hidden sm:table-cell">Ideal para</th>
          <th class="px-4 py-3 font-semibold">Enlace</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200 dark:divide-gray-800">
        {herramientas.map((h, i) => (
          <tr
            class:list={[
              'hover:bg-gray-50 dark:hover:bg-white/5 transition-colors',
              i % 2 === 1 && 'bg-gray-50/60 dark:bg-white/[0.02]',
            ]}
          >
            <td class="px-4 py-3 font-medium text-gray-900 dark:text-white whitespace-nowrap">{h.nombre}</td>
            <td class="px-4 py-3 text-gray-600 dark:text-gray-400 whitespace-nowrap">{h.precio}</td>
            <td class="px-4 py-3">
              <div class="flex items-center gap-1" role="img" aria-label={`${h.puntuacion} de 5`}>
                {Array.from({ length: 5 }, (_, j) => (
                  <svg
                    class:list={['w-3.5 h-3.5', j < Math.round(h.puntuacion) ? 'text-yellow-400' : 'text-gray-300 dark:text-gray-600']}
                    fill="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                  </svg>
                ))}
                <span class="text-xs text-gray-500 dark:text-gray-400 ml-1">{h.puntuacion}</span>
              </div>
            </td>
            <td class="px-4 py-3 text-gray-600 dark:text-gray-400 hidden sm:table-cell">{h.idealPara}</td>
            <td class="px-4 py-3">
              {h.enlaceAfiliado ? (
                <a
                  href={h.enlaceAfiliado}
                  target="_blank"
                  rel="noopener noreferrer sponsored"
                  class="inline-flex items-center gap-1 text-[#7C3AED] hover:text-[#6D28D9] font-semibold transition-colors"
                >
                  Ver
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              ) : (
                <span class="text-gray-400 dark:text-gray-600">—</span>
              )}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>
