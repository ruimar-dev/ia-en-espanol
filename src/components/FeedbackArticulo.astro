---
---

<div
  id="feedback-widget"
  class="mt-12 p-6 bg-white dark:bg-[#1A1A1A] rounded-2xl border border-gray-200 dark:border-gray-800 text-center"
>
  <!-- Estado: pregunta -->
  <div id="feedback-question">
    <p class="font-semibold text-gray-900 dark:text-white mb-4">
      ¿Te ha resultado útil esta publicación?
    </p>
    <div class="flex items-center justify-center gap-3">
      <button
        id="feedback-yes"
        class="flex items-center gap-2 px-5 py-2.5 rounded-xl border-2 border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:border-green-400 hover:bg-green-50 dark:hover:bg-green-950/30 hover:text-green-600 dark:hover:text-green-400 transition-all font-medium text-sm"
      >
        <span class="text-xl" aria-hidden="true">👍</span>
        Sí, mucho
      </button>
      <button
        id="feedback-no"
        class="flex items-center gap-2 px-5 py-2.5 rounded-xl border-2 border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:border-red-400 hover:bg-red-50 dark:hover:bg-red-950/30 hover:text-red-500 dark:hover:text-red-400 transition-all font-medium text-sm"
      >
        <span class="text-xl" aria-hidden="true">👎</span>
        Mejorable
      </button>
    </div>
  </div>

  <!-- Estado: gracias -->
  <div id="feedback-thanks" class="hidden">
    <p class="text-2xl mb-2" aria-hidden="true" id="feedback-emoji">🙏</p>
    <p class="font-semibold text-gray-900 dark:text-white mb-1" id="feedback-title">
      ¡Gracias por tu opinión!
    </p>
    <p class="text-sm text-gray-500 dark:text-gray-400" id="feedback-subtitle">
      Tu feedback ayuda a mejorar el blog.
    </p>
  </div>
</div>

<script>
  const slug = window.location.pathname.replace(/^\/blog\//, '').replace(/\/$/, '');
  const KEY = `feedback-${slug}`;

  const elQuestion = document.getElementById('feedback-question')!;
  const elThanks   = document.getElementById('feedback-thanks')!;
  const elEmoji    = document.getElementById('feedback-emoji')!;
  const elTitle    = document.getElementById('feedback-title')!;
  const elSubtitle = document.getElementById('feedback-subtitle')!;

  function showThanks(vote: 'yes' | 'no') {
    elQuestion.classList.add('hidden');
    elThanks.classList.remove('hidden');
    if (vote === 'yes') {
      elEmoji.textContent   = '🎉';
      elTitle.textContent   = '¡Gracias! Me alegra que haya sido útil.';
      elSubtitle.textContent = 'Compártelo si crees que puede ayudar a alguien más.';
    } else {
      elEmoji.textContent   = '🙏';
      elTitle.textContent   = 'Gracias por tu honestidad.';
      elSubtitle.textContent = 'Intentaré mejorar este artículo. Cualquier sugerencia es bienvenida.';
    }
  }

  // Restore previous vote
  const saved = localStorage.getItem(KEY) as 'yes' | 'no' | null;
  if (saved) showThanks(saved);

  document.getElementById('feedback-yes')?.addEventListener('click', () => {
    localStorage.setItem(KEY, 'yes');
    showThanks('yes');
  });

  document.getElementById('feedback-no')?.addEventListener('click', () => {
    localStorage.setItem(KEY, 'no');
    showThanks('no');
  });
</script>
