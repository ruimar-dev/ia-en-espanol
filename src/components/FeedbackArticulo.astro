---
---

<div
  id="feedback-widget"
  style="margin-top:48px; padding:28px 32px; background:var(--surface); border:1px solid var(--border); border-radius:18px; text-align:center;"
>
  <div id="feedback-question">
    <p style="margin:0 0 18px; font-size:16px; font-weight:600; color:var(--ink);">
      ¿Te ha resultado útil esta publicación?
    </p>
    <div style="display:flex; align-items:center; justify-content:center; gap:12px;">
      <button
        id="feedback-yes"
        style="display:flex; align-items:center; gap:8px; padding:11px 20px; border-radius:11px; border:1px solid var(--border2); background:var(--bg); color:var(--ink2); font-family:'Geist',sans-serif; font-size:14px; font-weight:500; cursor:pointer; transition:all .15s;"
        class="feedback-btn"
        data-vote="yes"
      >
        <span aria-hidden="true">👍</span>
        Sí, mucho
      </button>
      <button
        id="feedback-no"
        style="display:flex; align-items:center; gap:8px; padding:11px 20px; border-radius:11px; border:1px solid var(--border2); background:var(--bg); color:var(--ink2); font-family:'Geist',sans-serif; font-size:14px; font-weight:500; cursor:pointer; transition:all .15s;"
        class="feedback-btn"
        data-vote="no"
      >
        <span aria-hidden="true">👎</span>
        Mejorable
      </button>
    </div>
  </div>

  <div id="feedback-thanks" class="hidden">
    <p style="font-size:28px; margin:0 0 8px;" id="feedback-emoji">🙏</p>
    <p style="margin:0 0 4px; font-size:16px; font-weight:600; color:var(--ink);" id="feedback-title">
      ¡Gracias por tu opinión!
    </p>
    <p style="margin:0; font-size:14px; color:var(--ink3);" id="feedback-subtitle">
      Tu feedback ayuda a mejorar el blog.
    </p>
  </div>
</div>

<script>
  const slug = window.location.pathname.replace(/^\/blog\//, '').replace(/\/$/, '');
  const KEY = `feedback-${slug}`;

  const elQuestion = document.getElementById('feedback-question')!;
  const elThanks   = document.getElementById('feedback-thanks')!;
  const elEmoji    = document.getElementById('feedback-emoji')!;
  const elTitle    = document.getElementById('feedback-title')!;
  const elSubtitle = document.getElementById('feedback-subtitle')!;

  function showThanks(vote: 'yes' | 'no') {
    elQuestion.classList.add('hidden');
    elThanks.classList.remove('hidden');
    if (vote === 'yes') {
      elEmoji.textContent    = '🎉';
      elTitle.textContent    = '¡Gracias! Me alegra que haya sido útil.';
      elSubtitle.textContent = 'Compártelo si crees que puede ayudar a alguien más.';
    } else {
      elEmoji.textContent    = '🙏';
      elTitle.textContent    = 'Gracias por tu honestidad.';
      elSubtitle.textContent = 'Intentaré mejorar este artículo. Cualquier sugerencia es bienvenida.';
    }
  }

  const saved = localStorage.getItem(KEY) as 'yes' | 'no' | null;
  if (saved) showThanks(saved);

  document.querySelectorAll<HTMLButtonElement>('.feedback-btn').forEach((btn) => {
    btn.addEventListener('mouseenter', () => {
      btn.style.borderColor = 'var(--accent)';
      btn.style.color = 'var(--accent)';
    });
    btn.addEventListener('mouseleave', () => {
      btn.style.borderColor = 'var(--border2)';
      btn.style.color = 'var(--ink2)';
    });
    btn.addEventListener('click', () => {
      const vote = btn.dataset.vote as 'yes' | 'no';
      localStorage.setItem(KEY, vote);
      showThanks(vote);
    });
  });
</script>
