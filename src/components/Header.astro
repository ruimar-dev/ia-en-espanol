---
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [
  { href: '/blog', label: 'Blog' },
  { href: '/ranking', label: 'Ranking' },
  { href: '/comparativas', label: 'Comparativas' },
  { href: '/herramientas', label: 'Herramientas' },
  { href: '/que-ia-necesito', label: '¿Qué IA?' },
  { href: '/sobre-mi', label: 'Sobre mí' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-[#FAFAFA]/80 dark:bg-[#0F0F0F]/80 backdrop-blur-md border-b border-gray-200 dark:border-gray-800">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-1.5 font-bold text-xl">
        <span class="text-[#7C3AED]">IA</span>
        <span class="text-gray-900 dark:text-white">en Español</span>
      </a>

      <nav class="hidden md:flex items-center gap-6">
        {navLinks.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              'text-sm font-medium transition-colors hover:text-[#7C3AED]',
              currentPath.startsWith(href)
                ? 'text-[#7C3AED]'
                : 'text-gray-600 dark:text-gray-400',
            ]}
          >
            {label}
          </a>
        ))}
      </nav>

      <div class="flex items-center gap-1">
        <!-- Search button -->
        <button
          id="search-btn"
          aria-label="Buscar"
          class="flex items-center gap-2 px-3 py-1.5 rounded-xl text-sm text-gray-500 dark:text-gray-400 bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <span class="hidden sm:inline">Buscar</span>
          <kbd class="hidden sm:inline text-xs bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded px-1.5 py-0.5 font-mono leading-none">⌘K</kbd>
        </button>

        <ThemeToggle />

        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 rounded-lg text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
          aria-label="Menú de navegación"
          aria-expanded="false"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path id="icon-hamburger" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            <path id="icon-close" stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" class="hidden" />
          </svg>
        </button>
      </div>
    </div>

    <div id="mobile-menu" class="hidden md:hidden pb-4 border-t border-gray-200 dark:border-gray-800 pt-4">
      <nav class="flex flex-col gap-1">
        {navLinks.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              'px-3 py-2.5 rounded-lg text-sm font-medium transition-colors',
              currentPath.startsWith(href)
                ? 'bg-[#7C3AED]/10 text-[#7C3AED]'
                : 'text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800',
            ]}
          >
            {label}
          </a>
        ))}
        <a
          href="/buscar"
          class="flex items-center gap-2 px-3 py-2.5 rounded-lg text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          Buscar
        </a>
      </nav>
    </div>
  </div>
</header>

<script>
  // Mobile menu
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconHamburger = document.getElementById('icon-hamburger');
  const iconClose = document.getElementById('icon-close');

  function setMenuOpen(open: boolean) {
    mobileMenu?.classList.toggle('hidden', !open);
    mobileBtn?.setAttribute('aria-expanded', String(open));
    iconHamburger?.classList.toggle('hidden', open);
    iconClose?.classList.toggle('hidden', !open);
  }

  mobileBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = !mobileMenu?.classList.contains('hidden');
    setMenuOpen(!isOpen);
  });

  document.addEventListener('click', (e) => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    if (isOpen && !mobileMenu?.contains(e.target as Node)) {
      setMenuOpen(false);
    }
  });

  // Search button → navigate to /buscar
  document.getElementById('search-btn')?.addEventListener('click', () => {
    window.location.href = '/buscar';
  });

  // Ctrl+K / Cmd+K shortcut
  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      if (window.location.pathname === '/buscar') {
        (document.getElementById('search-input') as HTMLInputElement | null)?.focus();
      } else {
        window.location.href = '/buscar';
      }
    }
  });
</script>
