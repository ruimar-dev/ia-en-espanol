---
// Banner promocional del ebook "50 Prompts de IA para Autónomos y Pymes"
// Se inserta al final de los artículos del blog
---

<aside class="banner-ebook" aria-label="Recurso descargable">
  <div class="ebook-inner">
    <div class="ebook-img-wrap" aria-hidden="true">
      <img
        src="/images/ebook-portada.png"
        alt="Portada del ebook 50 Prompts de IA para Autónomos y Pymes"
        width="335"
        height="189"
        loading="lazy"
        decoding="async"
        class="ebook-cover"
      />
    </div>
    <div class="ebook-content">
      <span class="ebook-eyebrow">Pack de prompts · IA en Español</span>
      <h3 class="ebook-title">50 Prompts de IA para tu negocio</h3>
      <p class="ebook-desc">
        Copia, rellena los corchetes y pégalo en ChatGPT, Claude o Gemini. Emails, redes, ventas, gestión y productividad — sin improvisar.
      </p>

      <div class="ebook-lead-wrap" id="ebook-lead-wrap">
        <p class="ebook-lead-label">Consigue 5 prompts gratis ahora mismo:</p>
        <form class="ebook-lead-form" data-form="lead-magnet">
          <input
            type="email"
            class="ebook-lead-input"
            placeholder="tu@email.com"
            required
            autocomplete="email"
          />
          <button type="submit" class="ebook-lead-btn">
            <span class="ebook-lead-btn-text">Envíamelos</span>
            <svg class="ebook-lead-spinner" width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity=".25"/>
              <path d="M4 12a8 8 0 018-8" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
            </svg>
          </button>
        </form>
        <p class="ebook-lead-success" aria-live="polite">¡Listo! Revisa tu bandeja de entrada.</p>
        <p class="ebook-lead-error" aria-live="polite"></p>
        <p class="ebook-lead-note">
          ¿Prefieres el pack completo?
          <a href="https://iaenespanol.gumroad.com/l/50-prompts-para-autonomos-y-pymes" target="_blank" rel="noopener noreferrer">
            Descargar los 50 por €9.99 →
          </a>
        </p>
      </div>
    </div>
  </div>
</aside>

<style>
  .banner-ebook {
    margin: 40px 0 8px;
    border-radius: 18px;
    border: 1px solid color-mix(in srgb, var(--accent) 25%, var(--border));
    background: var(--accent-tint);
    overflow: hidden;
  }

  .ebook-inner {
    display: flex;
    gap: 0;
    align-items: stretch;
  }

  .ebook-img-wrap {
    flex-shrink: 0;
    width: 240px;
    background: linear-gradient(160deg, #4c1d95, #7c3aed);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px 16px;
  }

  .ebook-cover {
    width: 100%;
    border-radius: 8px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.4);
    display: block;
  }

  .ebook-content {
    flex: 1;
    padding: 24px 26px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .ebook-eyebrow {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .ebook-title {
    margin: 0;
    font-family: 'Newsreader', serif;
    font-weight: 500;
    font-size: 20px;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--ink);
  }

  .ebook-desc {
    margin: 0;
    font-size: 14px;
    line-height: 1.6;
    color: var(--ink2);
  }

  .ebook-bullets {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 6px 16px;
  }

  .ebook-bullets li {
    font-size: 12.5px;
    color: var(--ink2);
  }

  .ebook-lead-wrap {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 4px;
  }

  .ebook-lead-label {
    margin: 0;
    font-size: 12.5px;
    font-weight: 600;
    color: var(--accent);
  }

  .ebook-lead-form {
    display: flex;
    gap: 8px;
  }

  .ebook-lead-input {
    flex: 1;
    min-width: 0;
    padding: 9px 14px;
    border: 1.5px solid var(--border);
    border-radius: 9px;
    background: var(--bg);
    color: var(--ink);
    font-family: 'Geist', sans-serif;
    font-size: 13.5px;
    outline: none;
    transition: border-color .15s;
  }

  .ebook-lead-input:focus {
    border-color: var(--accent);
  }

  .ebook-lead-btn {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--accent);
    color: #fff;
    padding: 9px 16px;
    border: none;
    border-radius: 9px;
    font-family: 'Geist', sans-serif;
    font-size: 13.5px;
    font-weight: 600;
    cursor: pointer;
    transition: filter .15s, transform .15s;
  }

  .ebook-lead-btn:hover:not(:disabled) {
    filter: brightness(1.1);
    transform: translateY(-1px);
  }

  .ebook-lead-btn:disabled { opacity: .65; cursor: not-allowed; }

  .ebook-lead-spinner {
    display: none;
    animation: spin .7s linear infinite;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .ebook-lead-success {
    display: none;
    margin: 0;
    font-size: 13px;
    font-weight: 600;
    color: #16a34a;
  }

  .ebook-lead-error {
    display: none;
    margin: 0;
    font-size: 13px;
    color: #dc2626;
  }

  .ebook-lead-note {
    margin: 0;
    font-size: 12px;
    color: var(--muted);
  }

  .ebook-lead-note a {
    color: var(--accent);
    font-weight: 600;
    text-decoration: none;
  }

  .ebook-lead-note a:hover { text-decoration: underline; }

  /* Mobile: stack vertically */
  @media (max-width: 540px) {
    .ebook-inner { flex-direction: column; }
    .ebook-img-wrap { width: 100%; padding: 20px; }
    .ebook-cover { max-width: 240px; margin: 0 auto; }
    .ebook-content { padding: 20px; }
    .ebook-lead-form { flex-direction: column; }
    .ebook-lead-btn { width: 100%; justify-content: center; }
  }
</style>

<script>
  document.querySelectorAll<HTMLFormElement>('[data-form="lead-magnet"]').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const wrap = form.closest<HTMLElement>('.ebook-lead-wrap')!;
      const input = form.querySelector<HTMLInputElement>('input[type="email"]')!;
      const btn = form.querySelector<HTMLButtonElement>('button')!;
      const btnText = btn.querySelector<HTMLElement>('.ebook-lead-btn-text')!;
      const spinner = btn.querySelector<SVGElement>('.ebook-lead-spinner')!;
      const success = wrap.querySelector<HTMLElement>('.ebook-lead-success')!;
      const error = wrap.querySelector<HTMLElement>('.ebook-lead-error')!;

      btn.disabled = true;
      btnText.textContent = 'Enviando...';
      spinner.style.display = 'block';
      success.style.display = 'none';
      error.style.display = 'none';

      try {
        const res = await fetch('/api/lead-magnet', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: input.value.trim() }),
        });
        const data = await res.json();

        if (res.ok) {
          form.style.display = 'none';
          success.style.display = 'block';
        } else {
          error.textContent = data.error ?? 'Error al enviar. Inténtalo de nuevo.';
          error.style.display = 'block';
          btn.disabled = false;
          btnText.textContent = 'Envíamelos';
          spinner.style.display = 'none';
        }
      } catch {
        error.textContent = 'Error de conexión. Inténtalo de nuevo.';
        error.style.display = 'block';
        btn.disabled = false;
        btnText.textContent = 'Envíamelos';
        spinner.style.display = 'none';
      }
    });
  });
</script>
