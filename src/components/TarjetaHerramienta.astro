---
import { CATEGORIA_LABELS } from '../content/config';
import type { Categoria } from '../content/config';

interface Props {
  nombre: string;
  descripcion: string;
  categoria: Categoria;
  rating: number;
  logo?: string;
  url?: string;
  hubUrl?: string;
}

const { nombre, descripcion, categoria, rating, logo, url, hubUrl } = Astro.props;

const clampedRating = Math.min(5, Math.max(0, rating));
const stars = Array.from({ length: 5 }, (_, i) => i < Math.round(clampedRating));
---

<div class="bg-white dark:bg-[#1A1A1A] rounded-2xl p-5 border border-gray-200 dark:border-gray-800 hover:border-[#7C3AED]/50 transition-all duration-300 hover:shadow-lg hover:shadow-[#7C3AED]/10 flex flex-col gap-4 h-full">
  <div class="flex items-start gap-3">
    <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-[#7C3AED]/20 to-[#6D28D9]/30 flex items-center justify-center flex-shrink-0 overflow-hidden">
      {logo ? (
        <>
          <img
            src={logo}
            alt={`Logo de ${nombre}`}
            class="w-full h-full object-cover rounded-xl"
            loading="lazy"
            onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
          />
          <span class="text-[#7C3AED] font-bold text-lg hidden" aria-hidden="true">{nombre[0]}</span>
        </>
      ) : (
        <span class="text-[#7C3AED] font-bold text-lg" aria-hidden="true">{nombre[0]}</span>
      )}
    </div>
    <div class="flex-1 min-w-0">
      <h3 class="font-semibold text-gray-900 dark:text-white truncate">
        {hubUrl
          ? <a href={hubUrl} class="hover:text-[#7C3AED] transition-colors">{nombre}</a>
          : nombre
        }
      </h3>
      <span class="inline-block text-xs text-[#7C3AED] font-medium bg-[#7C3AED]/10 px-2 py-0.5 rounded-full mt-0.5">
        {CATEGORIA_LABELS[categoria]}
      </span>
    </div>
  </div>

  <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-3 flex-1">
    {descripcion}
  </p>

  <div class="flex items-center gap-1" role="img" aria-label={`Puntuación: ${clampedRating} de 5 estrellas`}>
    {stars.map((filled) => (
      <svg
        class:list={['w-4 h-4', filled ? 'text-yellow-400' : 'text-gray-300 dark:text-gray-600']}
        fill="currentColor"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
      </svg>
    ))}
    <span class="text-xs text-gray-500 dark:text-gray-400 ml-1">{clampedRating.toFixed(1)}</span>
  </div>

  {url && (
    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center justify-center gap-2 w-full py-2.5 rounded-xl bg-[#7C3AED] hover:bg-[#6D28D9] text-white text-sm font-semibold transition-colors mt-auto"
    >
      Ver herramienta
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
      </svg>
    </a>
  )}
</div>
