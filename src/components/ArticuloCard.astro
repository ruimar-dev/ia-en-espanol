---
import { CATEGORIA_LABELS } from '../content/config';
import type { Categoria } from '../content/config';

interface Props {
  title: string;
  description: string;
  date: Date;
  category: Categoria;
  slug: string;
  imagen?: string;
  readingTime?: number;
}

const { title, description, date, category, slug, imagen, readingTime = 5 } = Astro.props;

const dateFormatted = date.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group bg-white dark:bg-[#1A1A1A] rounded-2xl overflow-hidden border border-gray-200 dark:border-gray-800 hover:border-[#7C3AED]/50 transition-all duration-300 hover:shadow-lg hover:shadow-[#7C3AED]/10 flex flex-col">
  <a href={`/blog/${slug}`} class="block aspect-video bg-gradient-to-br from-[#7C3AED]/20 to-[#6D28D9]/30 relative overflow-hidden flex-shrink-0">
    {imagen ? (
      <img
        src={imagen}
        alt={title}
        width="1200"
        height="675"
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
        decoding="async"
        onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
      />
      <div class="absolute inset-0 items-center justify-center hidden">
        <svg class="w-10 h-10 text-[#7C3AED]/30" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
        </svg>
      </div>
    ) : (
      <div class="absolute inset-0 flex items-center justify-center">
        <svg class="w-10 h-10 text-[#7C3AED]/30" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
        </svg>
      </div>
    )}
    <span class="absolute top-3 left-3 bg-[#7C3AED] text-white text-xs font-semibold px-2.5 py-1 rounded-full">
      {CATEGORIA_LABELS[category]}
    </span>
  </a>

  <div class="p-5 flex flex-col flex-1">
    <div class="flex items-center gap-3 text-xs text-gray-500 dark:text-gray-400 mb-3">
      <time datetime={date.toISOString()}>{dateFormatted}</time>
      <span aria-hidden="true">·</span>
      <span>{readingTime} min de lectura</span>
    </div>

    <a href={`/blog/${slug}`} class="block mb-2 flex-1">
      <h3 class="font-semibold text-gray-900 dark:text-white line-clamp-2 group-hover:text-[#7C3AED] transition-colors leading-snug">
        {title}
      </h3>
    </a>

    <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-3 mb-4">
      {description}
    </p>

    <a
      href={`/blog/${slug}`}
      class="inline-flex items-center gap-1 text-sm font-medium text-[#7C3AED] hover:text-[#6D28D9] transition-colors mt-auto"
    >
      Leer más
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</article>
