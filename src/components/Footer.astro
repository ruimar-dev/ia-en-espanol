---
const year = new Date().getFullYear();

const secciones = [
  { href: '/blog',          label: 'Blog' },
  { href: '/ranking',       label: 'Ranking semanal' },
  { href: '/comparativas',  label: 'Comparativas' },
  { href: '/herramientas',  label: 'Herramientas' },
  { href: '/que-ia-necesito', label: '¿Qué IA necesito?' },
  { href: '/sobre-mi',      label: 'Sobre mí' },
];

const categorias = [
  { href: '/blog?cat=generacion-texto',   label: 'Generación de texto' },
  { href: '/blog?cat=generacion-imagen',  label: 'Generación de imagen' },
  { href: '/blog?cat=codigo',             label: 'Código' },
  { href: '/blog?cat=audio',              label: 'Audio' },
  { href: '/blog?cat=video',              label: 'Vídeo' },
  { href: '/blog?cat=productividad',      label: 'Productividad' },
];
---

<footer style="margin-top:80px; border-top:1px solid var(--border); background:var(--surface);">
  <div class="wrap" style="padding-top:56px; padding-bottom:40px;">

    <!-- Grid principal -->
    <div class="footer-grid">

      <!-- Columna 1: Marca -->
      <div>
        <a href="/" class="footer-logo">
          <span style="color:var(--accent);">IA</span>
          <span style="color:var(--ink);">en Español</span>
        </a>
        <p style="margin:14px 0 0; font-size:14px; line-height:1.65; color:var(--ink2); max-width:240px;">
          Reviews y comparativas de herramientas de IA en español. Sin anglicismos, con criterio.
        </p>
      </div>

      <!-- Columna 2: Secciones -->
      <div>
        <p class="footer-heading">Secciones</p>
        <ul class="footer-list">
          {secciones.map(({ href, label }) => (
            <li><a href={href} class="footer-link">{label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Columna 3: Categorías -->
      <div>
        <p class="footer-heading">Categorías</p>
        <ul class="footer-list">
          {categorias.map(({ href, label }) => (
            <li><a href={href} class="footer-link">{label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Columna 4: Newsletter -->
      <div>
        <p class="footer-heading">Newsletter</p>
        <p style="font-size:13px; line-height:1.6; color:var(--ink3); margin:0 0 14px;">
          Reviews y novedades de IA directo a tu email. Sin spam.
        </p>
        <form class="footer-nl-form">
          <input
            type="email"
            class="footer-nl-input"
            placeholder="tu@email.com"
            required
          />
          <button type="submit" class="footer-nl-btn">
            <span class="footer-nl-text">Suscribirme</span>
          </button>
        </form>
        <p class="footer-nl-ok" style="display:none; margin-top:10px; font-size:13px; color:var(--good);">¡Suscrito! Gracias.</p>
        <p class="footer-nl-err" style="display:none; margin-top:10px; font-size:13px; color:var(--bad);"></p>
      </div>
    </div>

    <!-- Copyright -->
    <div style="margin-top:48px; padding-top:24px; border-top:1px solid var(--border); display:flex; flex-wrap:wrap; justify-content:space-between; align-items:center; gap:12px;">
      <p style="margin:0; font-size:12px; color:var(--muted);">© {year} IA en Español. Algunos enlaces son de afiliado.</p>
      <p style="margin:0; font-size:12px; color:var(--muted);">
        Hecho con <a href="https://astro.build" style="color:var(--accent); text-decoration:none;" target="_blank" rel="noopener">Astro</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-weight: 700;
    font-size: 18px;
    text-decoration: none;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }
  @media (min-width: 560px) {
    .footer-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 900px) {
    .footer-grid { grid-template-columns: 1.4fr 1fr 1fr 1.2fr; gap: 48px; }
  }

  .footer-heading {
    margin: 0 0 16px;
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .footer-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-link {
    font-size: 14px;
    color: var(--ink2);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-link:hover { color: var(--accent); }

  /* Newsletter form */
  .footer-nl-form {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .footer-nl-input {
    width: 100%;
    padding: 10px 14px;
    border: 1px solid var(--border2);
    border-radius: 9px;
    font-family: 'Geist', sans-serif;
    font-size: 13px;
    color: var(--ink);
    background: var(--bg);
    outline: none;
    box-sizing: border-box;
    transition: border-color 0.15s;
  }
  .footer-nl-input:focus { border-color: var(--accent); }
  .footer-nl-btn {
    width: 100%;
    padding: 10px 14px;
    border: none;
    border-radius: 9px;
    background: var(--ink);
    color: var(--bg);
    font-family: 'Geist', sans-serif;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
  }
  .footer-nl-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 16px var(--shadow); }
  .footer-nl-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; box-shadow: none; }
</style>

<script>
  document.querySelectorAll<HTMLFormElement>('.footer-nl-form').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const footer = form.closest('footer')!;
      const input = form.querySelector<HTMLInputElement>('.footer-nl-input')!;
      const btn   = form.querySelector<HTMLButtonElement>('.footer-nl-btn')!;
      const text  = form.querySelector<HTMLElement>('.footer-nl-text')!;
      const okEl  = footer.querySelector<HTMLElement>('.footer-nl-ok')!;
      const errEl = footer.querySelector<HTMLElement>('.footer-nl-err')!;

      btn.disabled = true;
      text.textContent = 'Enviando…';
      okEl.style.display  = 'none';
      errEl.style.display = 'none';

      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: input.value.trim() }),
        });
        if (res.ok) {
          form.style.display = 'none';
          okEl.style.display = 'block';
        } else {
          const data = await res.json();
          errEl.textContent = data.error ?? 'Error al suscribirse.';
          errEl.style.display = 'block';
          btn.disabled = false;
          text.textContent = 'Suscribirme';
        }
      } catch {
        errEl.textContent = 'Error de conexión. Inténtalo de nuevo.';
        errEl.style.display = 'block';
        btn.disabled = false;
        text.textContent = 'Suscribirme';
      }
    });
  });
</script>
