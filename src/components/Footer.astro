---
const year = new Date().getFullYear();
---

<footer class="mt-20 border-t border-gray-200 dark:border-gray-800 bg-white dark:bg-[#1A1A1A]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <a href="/" class="flex items-center gap-1.5 font-bold text-xl mb-3">
          <span class="text-[#7C3AED]">IA</span>
          <span class="text-gray-900 dark:text-white">en Español</span>
        </a>
        <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
          Reviews y comparativas de herramientas de IA en español. Sin anglicismos, con criterio.
        </p>
      </div>

      <div>
        <h4 class="font-semibold text-gray-900 dark:text-white mb-4 text-sm uppercase tracking-wider">Secciones</h4>
        <ul class="space-y-2.5">
          {[
            { href: '/blog', label: 'Blog' },
            { href: '/ranking', label: 'Ranking semanal' },
            { href: '/comparativas', label: 'Comparativas' },
            { href: '/herramientas', label: 'Herramientas' },
            { href: '/sobre-mi', label: 'Sobre mí' },
          ].map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm text-gray-600 dark:text-gray-400 hover:text-[#7C3AED] transition-colors">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-semibold text-gray-900 dark:text-white mb-4 text-sm uppercase tracking-wider">Categorías</h4>
        <ul class="space-y-2.5">
          {[
            { href: '/blog?cat=generacion-texto', label: 'Generación de texto' },
            { href: '/blog?cat=generacion-imagen', label: 'Generación de imagen' },
            { href: '/blog?cat=codigo', label: 'Código' },
            { href: '/blog?cat=audio', label: 'Audio' },
            { href: '/blog?cat=video', label: 'Video' },
            { href: '/blog?cat=productividad', label: 'Productividad' },
          ].map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm text-gray-600 dark:text-gray-400 hover:text-[#7C3AED] transition-colors">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-8 border-t border-gray-200 dark:border-gray-800 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-xs text-gray-500">
        © {year} IA en Español. Algunos enlaces son de afiliado.
      </p>
      <p class="text-xs text-gray-500">
        Hecho con <a href="https://astro.build" class="text-[#7C3AED] hover:underline" target="_blank" rel="noopener">Astro</a> y Tailwind CSS
      </p>
    </div>
  </div>
</footer>
